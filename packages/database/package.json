{
  "name": "@his/database",
  "version": "0.1.0",
  "private": true,
  "description": "Cliente Prisma y seeds para HIS Multipaís",
  "license": "UNLICENSED",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/index.ts"
  },
  "files": [
    "src",
    "prisma"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "seed:sv-extra": "tsx --env-file=.env seed-sv-extra.ts",
    "seed:manchester": "tsx --env-file=.env seed-manchester.ts",
    "seed:vaccines": "tsx --env-file=.env seed-vaccines-sv.ts",
    "seed:notif-defaults": "tsx --env-file=.env seed-notifications-defaults.ts",
    "db:seed:demo-hospitalario": "tsx --env-file=.env scripts/seed-demo-hospitalario.mjs",
    "db:seed:demo-obstetrico": "node --env-file=.env scripts/seed-demo-obstetrico.mjs",
    "db:seed:demo-quirurgico": "node --env-file=.env scripts/seed-demo-quirurgico.mjs",
    "studio": "prisma studio",
    "validate": "prisma validate",
    "format": "prisma format",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "db:seed:demo": "node --env-file=.env scripts/seed-demo-ambulatorio.mjs",
    "db:seed:icd10-full": "node --env-file=.env scripts/seed-icd10-full.mjs",
    "db:seed:go-live-defaults": "node --env-file=.env scripts/seed-go-live-defaults.mjs",
    "db:seed:go-live-verify": "node --env-file=.env scripts/seed-go-live-verify.mjs",
    "db:seed:uat": "node --env-file=.env scripts/seed-uat-patients.mjs",
    "db:seed:uat:clean": "node --env-file=.env scripts/cleanup-uat-patients.mjs",
    "db:seed:uat:dry-clean": "node --env-file=.env scripts/cleanup-uat-patients.mjs --dry-run",
    "db:ingest:chat": "node --env-file=.env scripts/ingest-chat-knowledge.mjs",
    "test": "vitest run --passWithNoTests"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@his/contracts": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "@types/node": "^22.19.20",
    "pg": "^8.21.0",
    "vitest": "^2.1.8"
  }
}
