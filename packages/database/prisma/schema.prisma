/// TDR §7.3.1 — tipo de paciente (ambulatorio, hospitalizado, emergencia...).
model PatientType {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  encounters Encounter[]

  @@schema("public")
}

/// TDR §7.3.1 — categoría de paciente (privado, ISSS, MINSAL, FOSALUD...).
model PatientCategory {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  encounters Encounter[]

  @@schema("public")
}

/// TDR §7.3.1 — clasificación etaria (neonato, lactante...).
model AgeBand {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(30)
  name      String    @db.VarChar(80)
  minDays   Int
  maxDays   Int? /// null = sin límite superior.
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  @@schema("public")
}

/// TDR §7.3.4 — especialidad médica.
model MedicalSpecialty {
  id        String    @id @default(uuid()) @db.Uuid
  parentId  String?   @db.Uuid /// sub-especialidad.
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  parent   MedicalSpecialty?  @relation("SpecialtyTree", fields: [parentId], references: [id], onDelete: Restrict)
  children MedicalSpecialty[] @relation("SpecialtyTree")
  services ServiceUnit[]

  @@schema("public")
}

/// TDR §7.3.4 — servicio/unidad funcional (UCI, sala de partos, consulta externa).
model ServiceUnit {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  establishmentId String   @db.Uuid
  specialtyId     String?  @db.Uuid
  code            String   @db.VarChar(40)
  name            String   @db.VarChar(120)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  establishment Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  specialty     MedicalSpecialty?  @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  beds          Bed[]
  encounters    Encounter[]
  triages       TriageEvaluation[]
  // Finance — sql/127
  invoiceItems  InvoiceItem[]      @relation("InvoiceItemServiceUnit")
  // Nivel A — sql/60
  assignments   UserServiceUnitAssignment[] @relation("ServiceUnitAssignments")
  // Nivel B — sql/61
  operatingRooms OperatingRoom[]

  @@unique([establishmentId, code])
  @@schema("public")
}

/// Scoping de usuarios a unidades operativas — sql/60 (Nivel A).
/// Sin entries para un usuario = sin restricción (compat backward).
/// Con entries = el usuario solo ve sidebar/rutas de esos servicios.
/// Roles cross-servicio (ADMIN, DIR, COO, CFO, CEO, MEDICAL_DIRECTOR, AUDITOR)
/// bypassean este filtro y ven todo dentro de la org.
model UserServiceUnitAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  serviceUnitId  String    @db.Uuid
  /// Si NULL: aplica con cualquier rol del usuario. Si presente: solo cuando
  /// el usuario actúa con ese rol específico.
  roleId         String?   @db.Uuid
  validFrom      DateTime  @default(now()) @db.Timestamptz()
  validTo        DateTime? @db.Timestamptz()
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdBy      String?   @db.Uuid

  user        User        @relation("UserAssignedServiceUnits", fields: [userId], references: [id], onDelete: Cascade)
  serviceUnit ServiceUnit @relation("ServiceUnitAssignments", fields: [serviceUnitId], references: [id], onDelete: Cascade)
  role        Role?       @relation("RoleAssignedServiceUnits", fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, serviceUnitId, roleId], map: "user_service_role_unique")
  @@index([userId])
  @@index([serviceUnitId])
  @@schema("public")
}

/// TDR §7.3.2 — sistema de codificación clínica (CIE-10, CIE-11, SNOMED CT, LOINC, CIAP-2).
model CodeSystem {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(40) /// ICD10, ICD11, SNOMED, LOINC, CIAP2, ATC.
  name      String   @db.VarChar(120)
  version   String   @db.VarChar(40)
  uri       String?  @db.VarChar(200)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  concepts ClinicalConcept[]

  @@schema("public")
}

/// TDR §7.3.2 — concepto clínico genérico (diagnóstico, procedimiento, observación, prueba).
/// 4NF: una sola tabla evita duplicar columnas por sistema. Mapeos cruzados en ClinicalConceptMap.
model ClinicalConcept {
  id           String    @id @default(uuid()) @db.Uuid
  codeSystemId String    @db.Uuid
  code         String    @db.VarChar(60)
  display      String    @db.VarChar(400)
  isAbstract   Boolean   @default(false)
  active       Boolean   @default(true)
  validFrom    DateTime  @default(now()) @db.Date
  validTo      DateTime? @db.Date
  version      Int       @default(1)
  createdAt    DateTime  @default(now()) @db.Timestamptz()

  codeSystem CodeSystem           @relation(fields: [codeSystemId], references: [id], onDelete: Restrict)
  mapsFrom   ClinicalConceptMap[] @relation("MapFrom")
  mapsTo     ClinicalConceptMap[] @relation("MapTo")

  @@unique([codeSystemId, code])
  @@index([codeSystemId])
  @@schema("public")
}

/// TDR §7.3.2 — mapeo cruzado entre sistemas de codificación.
model ClinicalConceptMap {
  id            String   @id @default(uuid()) @db.Uuid
  fromConceptId String   @db.Uuid
  toConceptId   String   @db.Uuid
  equivalence   String   @db.VarChar(40) /// equivalent, broader, narrower, related.
  createdAt     DateTime @default(now()) @db.Timestamptz()

  from ClinicalConcept @relation("MapFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  to   ClinicalConcept @relation("MapTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([fromConceptId, toConceptId, equivalence])
  @@schema("public")
}

// =============================================================================
// 5. MPI / PACIENTE  (TDR §8.1)
// =============================================================================

/// TDR §8.1 — paciente único en el MPI institucional.
/// Soft delete vía `deletedAt` (TDR §5.5 regla 7).
model Patient {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @db.Uuid /// organización propietaria del registro maestro.
  mrn                String    @db.VarChar(40) /// medical record number interno.
  expediente         String?   @unique @db.VarChar(20) /// CC-0002 §6: {PAIS}{AA}{NNNNN}. Inmutable tras asignarse. Server-generated.
  documentType       DocumentType?            /// CC-0002 §3: documento de registro. DUI_RESP = doc del responsable (menores).
  documentNumber     String?   @db.VarChar(40) /// CC-0002 §5: dedup 1:1 para docs propios; DUI_RESP es compartible.
  /// CC-0008 §6 — switch "el paciente trae documento de identidad" (default ON). OFF habilita registro sin documento + responsable.
  traeDocumento      Boolean   @default(true)
  firstName          String    @db.VarChar(120) /// primer nombre.
  middleName         String?   @db.VarChar(120) /// segundo nombre.
  thirdName          String?   @db.VarChar(120) /// CC-0008 §6 — tercer nombre.
  lastName           String    @db.VarChar(120) /// primer apellido.
  secondLastName     String?   @db.VarChar(120) /// segundo apellido.
  marriedLastName    String?   @db.VarChar(120) /// CC-0008 §6 — apellido de casada.
  preferredName      String?   @db.VarChar(120)
  /// CC-0007 RF-01.3 — paciente de la comunidad LGBTIQ+ (activa banner de nombre de pila)
  esLgbtiq           Boolean?  @map("es_lgbtiq")
  birthDate          DateTime? @db.Date
  birthDateEstimated Boolean   @default(false)
  birthPlaceGeoId    String?   @db.Uuid
  biologicalSexId    String    @db.Uuid
  genderId           String?   @db.Uuid
  maritalStatusId    String?   @db.Uuid
  educationLevelId   String?   @db.Uuid
  occupationId       String?   @db.Uuid
  bloodTypeAbo       String?   @db.VarChar(3) /// A, B, AB, O.
  bloodRh            String?   @db.VarChar(3) /// +, -.
  isUnknown          Boolean   @default(false) /// NN.
  unknownLabel       String?   @db.VarChar(40) /// NN-AAAAMMDD-NNN.
  motherPatientId    String?   @db.Uuid /// vínculo neonato↔madre.
  active             Boolean   @default(true)
  /// AI(8018) GSRN — asignado automáticamente al confirmar admisión hospitalaria (US.F2.6.1).
  gsrn               String?   @unique @db.Char(18)
  /// F2-S15-C: paciente absorbido en merge NTEC; apunta al canónico. NULL = registro activo.
  mergedIntoId       String?   @db.Uuid
  deletedAt          DateTime? @db.Timestamptz()
  deletedBy          String?   @db.Uuid
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  createdBy          String?   @db.Uuid
  updatedAt          DateTime  @updatedAt @db.Timestamptz()
  updatedBy          String?   @db.Uuid

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  biologicalSex  BiologicalSex   @relation(fields: [biologicalSexId], references: [id], onDelete: Restrict)
  gender         Gender?         @relation(fields: [genderId], references: [id], onDelete: SetNull)
  maritalStatus  MaritalStatus?  @relation(fields: [maritalStatusId], references: [id], onDelete: SetNull)
  educationLevel EducationLevel? @relation(fields: [educationLevelId], references: [id], onDelete: SetNull)
  occupation     Occupation?     @relation(fields: [occupationId], references: [id], onDelete: SetNull)
  mother         Patient?        @relation("MotherChild", fields: [motherPatientId], references: [id], onDelete: SetNull)
  children       Patient[]       @relation("MotherChild")

  identifiers            PatientIdentifier[]
  addresses              PatientAddress[]
  phones                 PatientPhone[]
  emails                 PatientEmail[]
  emergencyContacts      PatientEmergencyContact[]
  ethnicities            PatientEthnicity[]
  religions              PatientReligion[]
  languages              PatientLanguage[]
  allergies              PatientAllergy[]
  consents               PatientConsent[]
  mergeHistoryFrom       PatientMerge[]            @relation("MergeFrom")
  mergeHistoryTo         PatientMerge[]            @relation("MergeTo")
  encounters             Encounter[]
  triages                TriageEvaluation[]
  vaccinations           PatientVaccination[]
  deathCertificate       DeathCertificate?
  outpatientAppointments OutpatientAppointment[]   @relation("PatAppointments")
  inpatientAdmissions    InpatientAdmission[]      @relation("PatInpatientAdmissions")
  emergencyVisits        EmergencyVisit[]          @relation("PatEmergencyVisits")
  surgeryCases           SurgeryCase[]             @relation("PatSurgeryCases")
  imagingOrders          ImagingOrder[]            @relation("PatImagingOrders")
  labOrders              LabOrder[]                @relation("PatLabOrders")
  coverages              PatientCoverage[]         @relation("PatCoverages")
  respiratoryOrders      RespiratoryOrder[]        @relation("PatRespiratoryOrders")
  dietPlans              DietPlan[]                @relation("PatDietPlans")
  nutritionAssessments   NutritionAssessment[]     @relation("PatNutritionAssessments")
  nutritionOrders        NutritionOrder[]          @relation("PatNutritionOrders")
  transfusionRequests    TransfusionRequest[]
  // Beta.17 — Patología
  pathologyOrders        PathologyOrder[]          @relation("PatPathologyOrders")
  // Beta.20 — Portal del Paciente
  portalAccount          PortalAccount?
  guardianRelationships  GuardianRelationship[]    @relation("GuardianWard")
  // F2-S7 — GS1 Bedside
  pharmacyOrders         PharmacyOrder[]           @relation("PatPharmacyOrders")
  pharmacyReservations   PharmacyReservation[]     @relation("PatPharmacyReservations")
  // F2-S7 — Carrito Unidosis
  pharmacyCarts          PharmacyCart[]            @relation("PatientPharmacyCarts")
  // F2-S7 — Patient ID via pulsera GSRN (US.F2.6.37-40)
  gsrnHistory            GsrnHistory[]
  // F2-S15-C — MPI Dedup + ARCO
  mergedInto             Patient?           @relation("PatientMergedInto", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedPatients         Patient[]          @relation("PatientMergedInto")
  ecePatientMergesCanon  EcePatientMerge[]  @relation("EceMergeCanonical")
  ecePatientMergesMerged EcePatientMerge[]  @relation("EceMergeMerged")
  solicitudesArco        SolicitudArco[]    @relation("PatientSolicitudesArco")
  // Finance — sql/127
  invoices               Invoice[]          @relation("InvoicePatient")
  // CC-0002 §7 — cuentas de paciente
  patientAccounts        PatientAccount[]   @relation("PatientAccounts")

  @@unique([organizationId, mrn])
  @@index([lastName, firstName])
  @@index([birthDate])
  @@index([mergedIntoId])
  @@schema("public")
}

/// US.F2.6.37-40 — historial inmutable de pulseras GSRN por paciente.
/// Registra cada emisión y revocación. Una sola fila ACTIVE por paciente/org.
model GsrnHistory {
  id               String    @id @default(uuid()) @db.Uuid
  patientId        String    @db.Uuid
  organizationId   String    @db.Uuid
  gsrn             String    @unique @db.Char(18)
  status           GsrnStatus @default(ACTIVE)
  assignedAt       DateTime  @default(now()) @db.Timestamptz()
  revokedAt        DateTime? @db.Timestamptz()
  assignedById     String?   @db.Uuid
  revokedById      String?   @db.Uuid
  motivoRevocacion String?   @db.Text
  createdAt        DateTime  @default(now()) @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([organizationId])
  @@index([gsrn])
  @@schema("public")
}

enum GsrnStatus {
  ACTIVE
  REVOKED

  @@schema("public")
}

/// TDR §14.5 - catalogo de vacunas (PAI SV + universal).
model Vaccine {
  id           String   @id @default(uuid()) @db.Uuid
  countryId    String?  @db.Uuid /// null = global
  code         String   @db.VarChar(40) /// BCG, HepB, DPT, etc.
  name         String   @db.VarChar(120)
  manufacturer String?  @db.VarChar(120)
  routeOfAdmin String?  @db.VarChar(40) /// IM, SC, oral, intradermal
  scheduleNote String?  @db.Text /// edades recomendadas
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  vaccinations PatientVaccination[]

  @@unique([countryId, code])
  @@schema("public")
}

/// TDR §14.5 - registro de vacunacion aplicada al paciente.
model PatientVaccination {
  id                String    @id @default(uuid()) @db.Uuid
  patientId         String    @db.Uuid
  vaccineId         String    @db.Uuid
  organizationId    String    @db.Uuid
  establishmentId   String?   @db.Uuid
  doseNumber        Int       @default(1)
  administeredAt    DateTime  @db.Timestamptz()
  lotNumber         String?   @db.VarChar(60)
  expirationDate    DateTime? @db.Date
  anatomicalSite    String?   @db.VarChar(40)
  administeredById  String?   @db.Uuid /// User id
  reactionsObserved String?   @db.Text
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  createdBy         String?   @db.Uuid

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vaccine      Vaccine      @relation(fields: [vaccineId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([patientId])
  @@index([vaccineId])
  @@schema("public")
}

/// TDR §8.7 - certificado medico de defuncion digital.
/// 1:1 con Patient (un certificado por fallecimiento).
model DeathCertificate {
  id                        String    @id @default(uuid()) @db.Uuid
  patientId                 String    @unique @db.Uuid
  encounterId               String?   @db.Uuid /// encounter en el que se constato
  organizationId            String    @db.Uuid
  establishmentId           String    @db.Uuid
  occurredAt                DateTime  @db.Timestamptz() /// fecha y hora del fallecimiento
  certifiedById             String    @db.Uuid /// medico que certifica (User)
  certifiedAt               DateTime  @default(now()) @db.Timestamptz()
  /// Causas CIE-10 (codigo + descripcion libre porque puede no estar en ClinicalConcept aun).
  basicCauseCode            String    @db.VarChar(20) /// causa basica
  basicCauseDesc            String    @db.VarChar(300)
  intermediateCauseCode     String?   @db.VarChar(20)
  intermediateCauseDesc     String?   @db.VarChar(300)
  directCauseCode           String?   @db.VarChar(20)
  directCauseDesc           String?   @db.VarChar(300)
  contributingCauses        String?   @db.Text
  manner                    String?   @db.VarChar(40) /// natural, accident, suicide, homicide, undetermined
  notifiedToCivilRegistryAt DateTime? @db.Timestamptz()
  notes                     String?   @db.Text
  createdAt                 DateTime  @default(now()) @db.Timestamptz()
  updatedAt                 DateTime  @updatedAt @db.Timestamptz()

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([organizationId, occurredAt])
  @@schema("public")
}

/// TDR §8.1 — identificador del paciente (DUI, NIT, pasaporte). 4NF: relación independiente.
/// Un paciente puede tener N identificadores; cada tipo puede repetirse históricamente.
model PatientIdentifier {
  id               String                @id @default(uuid()) @db.Uuid
  patientId        String                @db.Uuid
  identifierTypeId String                @db.Uuid
  kind             PatientIdentifierKind
  value            String                @db.VarChar(80)
  countryOfIssue   String?               @db.Uuid
  issuedAt         DateTime?             @db.Date
  expiresAt        DateTime?             @db.Date
  isPrimary        Boolean               @default(false)
  createdAt        DateTime              @default(now()) @db.Timestamptz()

  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  identifierType IdentifierType @relation(fields: [identifierTypeId], references: [id], onDelete: Restrict)

  @@unique([identifierTypeId, value])
  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — direcciones (multivalor). 4NF: tabla independiente vs teléfonos/emails.
model PatientAddress {
  id            String    @id @default(uuid()) @db.Uuid
  patientId     String    @db.Uuid
  geoDivisionId String?   @db.Uuid
  line1         String    @db.VarChar(300)
  line2         String?   @db.VarChar(300)
  postalCode    String?   @db.VarChar(20)
  isPrimary     Boolean   @default(false)
  validFrom     DateTime  @default(now()) @db.Date
  validTo       DateTime? @db.Date
  createdAt     DateTime  @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — teléfonos (multivalor independiente).
model PatientPhone {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  phone     String   @db.VarChar(40)
  kind      String   @db.VarChar(20) /// móvil, casa, trabajo.
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — correos (multivalor independiente).
model PatientEmail {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  email     String   @db.Citext
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — contactos de emergencia.
model PatientEmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  patientId    String   @db.Uuid
  fullName     String   @db.VarChar(200)
  relationship String   @db.VarChar(60)
  phone        String?  @db.VarChar(40)
  email        String?  @db.Citext
  priority     Int      @default(1)
  createdAt    DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔etnia (multivalor 4NF independiente de idiomas y religiones).
model PatientEthnicity {
  patientId   String   @db.Uuid
  ethnicityId String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz()

  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ethnicity Ethnicity @relation(fields: [ethnicityId], references: [id], onDelete: Restrict)

  @@id([patientId, ethnicityId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔religión (multivalor 4NF independiente).
model PatientReligion {
  patientId  String   @db.Uuid
  religionId String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz()

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  religion Religion @relation(fields: [religionId], references: [id], onDelete: Restrict)

  @@id([patientId, religionId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔idioma (multivalor 4NF independiente).
model PatientLanguage {
  patientId   String   @db.Uuid
  languageId  String   @db.Uuid
  isPreferred Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Restrict)

  @@id([patientId, languageId])
  @@schema("public")
}

/// TDR §8.1 — alergia conocida del paciente. 4NF: independiente de idiomas, etnias, religiones.
model PatientAllergy {
  id                 String    @id @default(uuid()) @db.Uuid
  patientId          String    @db.Uuid
  substanceConceptId String?   @db.Uuid /// referencia a ClinicalConcept (RxNorm/ATC/SNOMED).
  substanceText      String    @db.VarChar(200) /// texto libre si no hay concepto.
  reaction           String?   @db.VarChar(400)
  severity           String    @db.VarChar(20) /// mild, moderate, severe, life-threatening.
  onsetDate          DateTime? @db.Date
  verified           Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  createdBy          String?   @db.Uuid
  updatedAt          DateTime  @updatedAt @db.Timestamptz()
  updatedBy          String?   @db.Uuid

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §6.4 / §8.1 — consentimientos del paciente (datos, telemedicina, transfusión, MPI cross-org).
model PatientConsent {
  id         String    @id @default(uuid()) @db.Uuid
  patientId  String    @db.Uuid
  purpose    String    @db.VarChar(80) /// data_processing, mpi_cross_org, transfusion, ...
  granted    Boolean
  scope      Json? /// detalles parametrizables (organizaciones, finalidades).
  signedAt   DateTime  @default(now()) @db.Timestamptz()
  signedById String?   @db.Uuid /// usuario que registra el consentimiento.
  validFrom  DateTime  @db.Timestamptz()
  validTo    DateTime? @db.Timestamptz()
  revokedAt  DateTime? @db.Timestamptz()

  patient  Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  signedBy User?   @relation("ConsentAuthor", fields: [signedById], references: [id], onDelete: SetNull)

  @@index([patientId, purpose])
  @@schema("public")
}

/// TDR §8.1 — historial de fusiones MPI (cuando se identifica un NN o se descubre duplicado).
model PatientMerge {
  id            String   @id @default(uuid()) @db.Uuid
  fromPatientId String   @db.Uuid /// registro absorbido (lógicamente eliminado).
  toPatientId   String   @db.Uuid /// registro superviviente.
  reason        String   @db.VarChar(200)
  mergedAt      DateTime @default(now()) @db.Timestamptz()
  mergedBy      String?  @db.Uuid

  from Patient @relation("MergeFrom", fields: [fromPatientId], references: [id], onDelete: Restrict)
  to   Patient @relation("MergeTo", fields: [toPatientId], references: [id], onDelete: Restrict)

  @@index([toPatientId])
  @@schema("public")
}

// =============================================================================
// 6. ADT — ADMISIÓN, ALTAS, TRASLADOS  (TDR §8)
// =============================================================================

/// TDR §8.6 — cama (recurso físico).
model Bed {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  establishmentId String    @db.Uuid
  serviceUnitId   String    @db.Uuid
  code            String    @db.VarChar(40)
  room            String?   @db.VarChar(40)
  status          BedStatus @default(FREE)
  isolation       String?   @db.VarChar(40) /// contacto, gotitas, respiratorio, protector.
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  establishment Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  serviceUnit   ServiceUnit     @relation(fields: [serviceUnitId], references: [id], onDelete: Restrict)
  assignments   BedAssignment[]

  @@unique([establishmentId, code])
  @@index([status])
  @@schema("public")
}

/// TDR §8.3 — encuentro asistencial (admisión / consulta / emergencia / hospitalización).
/// Es la unidad transaccional que aglutina ADT en una visita.
model Encounter {
  id                 String         @id @default(uuid()) @db.Uuid
  countryId          String         @db.Uuid
  organizationId     String         @db.Uuid
  establishmentId    String         @db.Uuid
  serviceUnitId      String?        @db.Uuid
  patientId          String         @db.Uuid
  patientTypeId      String?        @db.Uuid
  patientCategoryId  String?        @db.Uuid
  admissionType      AdmissionType
  encounterNumber    String         @db.VarChar(40) /// identificador legible "ADM-2026-000123".
  admittedAt         DateTime       @db.Timestamptz()
  dischargedAt       DateTime?      @db.Timestamptz()
  dischargeType      DischargeType?
  primaryDiagnosisId String?        @db.Uuid /// ClinicalConcept (CIE-10/11).
  currencyId         String         @db.Uuid
  exchangeRateToFunc Decimal        @db.Decimal(18, 8)
  // Wave 10 — imputación a centro de costo productivo (migration cost_center_id_clinical_modules_2026_05_25)
  costCenterId           String?  @db.Uuid
  // H2-01 (audit Stream A — P1 ALTA): campos capturados en wizard de admisión
  // que no persistían. sql/104_encounter_admission_fields.sql agrega las columnas a BD.
  chiefComplaint         String?  @db.VarChar(500)
  accompanyingPersonName String?  @db.VarChar(200)
  /// Lista de pertenencias declaradas. Almacenada como JSON array de strings.
  valuables              Json?
  isReferral             Boolean  @default(false)
  referralOrigin         String?  @db.VarChar(200)
  createdAt              DateTime @default(now()) @db.Timestamptz()
  createdBy          String?        @db.Uuid
  updatedAt          DateTime       @updatedAt @db.Timestamptz()
  updatedBy          String?        @db.Uuid

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  establishment   Establishment    @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  serviceUnit     ServiceUnit?     @relation(fields: [serviceUnitId], references: [id], onDelete: SetNull)
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  patientType     PatientType?     @relation(fields: [patientTypeId], references: [id], onDelete: SetNull)
  patientCategory PatientCategory? @relation(fields: [patientCategoryId], references: [id], onDelete: SetNull)
  currency        Currency         @relation("EncounterCurrency", fields: [currencyId], references: [id], onDelete: Restrict)
  costCenter      CostCenter?      @relation("EncounterCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)

  bedAssignments         BedAssignment[]
  transfers              EncounterTransfer[]
  triages                TriageEvaluation[]
  deathCertificates      DeathCertificate[]
  outpatientConsultation OutpatientConsultation? @relation("EncOutpatientConsult")
  diagnoses              EncounterDiagnosis[]    @relation("EncDiagnoses")
  inpatientAdmission     InpatientAdmission?     @relation("EncInpatientAdmission")
  emergencyVisit         EmergencyVisit?         @relation("EncEmergencyVisit")
  surgeryCases           SurgeryCase[]           @relation("EncSurgeryCases")
  imagingOrders          ImagingOrder[]          @relation("EncImagingOrders")
  labOrders              LabOrder[]              @relation("EncLabOrders")
  authorizationRequests  AuthorizationRequest[]  @relation("EncAuthRequests")
  respiratoryOrders      RespiratoryOrder[]      @relation("EncRespiratoryOrders")
  dietPlans              DietPlan[]              @relation("EncDietPlans")
  nutritionAssessments   NutritionAssessment[]   @relation("EncNutritionAssessments")
  nutritionOrders        NutritionOrder[]        @relation("EncNutritionOrders")
  transfusionRequests    TransfusionRequest[]
  transfusions           Transfusion[]           @relation("TransfusionEncounter")
  // Beta.17 — Patología
  pathologyOrders        PathologyOrder[]        @relation("EncPathologyOrders")
  // F2-S7 — GS1 Bedside
  pharmacyOrders         PharmacyOrder[]         @relation("EncPharmacyOrders")
  // Finance — sql/127
  invoices               Invoice[]               @relation("InvoiceEncounter")
  // CC-0002 §7 — cuentas y servicios vinculados al encuentro
  accounts               PatientAccount[]        @relation("EncounterAccounts")
  accountServices        PatientAccountService[] @relation("EncounterAccountServices")

  @@unique([organizationId, encounterNumber])
  @@index([patientId])
  @@index([organizationId, admittedAt])
  @@schema("public")
}

/// TDR §8.3 / §8.4 — asignación de cama (historiable). 4NF: separa la MVD encuentro↔cama.
model BedAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  encounterId String    @db.Uuid
  bedId       String    @db.Uuid
  assignedAt  DateTime  @default(now()) @db.Timestamptz()
  releasedAt  DateTime? @db.Timestamptz()
  reason      String?   @db.VarChar(200)
  createdBy   String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  bed       Bed       @relation(fields: [bedId], references: [id], onDelete: Restrict)

  @@index([encounterId])
  @@index([bedId, assignedAt])
  @@schema("public")
}

/// TDR §8.4 — traslado interno (cambio de servicio o nivel de cuidado).
model EncounterTransfer {
  id            String   @id @default(uuid()) @db.Uuid
  encounterId   String   @db.Uuid
  fromServiceId String?  @db.Uuid
  toServiceId   String   @db.Uuid
  fromBedId     String?  @db.Uuid
  toBedId       String?  @db.Uuid
  reason        String   @db.VarChar(200)
  occurredAt    DateTime @default(now()) @db.Timestamptz()
  createdBy     String?  @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz()

  /// Handoff de recepción interna (sql/56) — paciente sale → alguien lo recibe.
  /// SENT (default al crear) → RECEIVED (confirmado por receptor) | CANCELLED.
  status        EncounterTransferStatus @default(SENT)
  receivedAt    DateTime?               @db.Timestamptz()
  receivedById  String?                 @db.Uuid
  receivedNote  String?                 @db.VarChar(400)

  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  receivedBy  User?     @relation("TransferReceiver", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([encounterId])
  @@index([status])
  @@index([toServiceId, status])
  @@schema("public")
}

/// Handoff interno de paciente — sql/56_transfer_handoff.sql.
enum EncounterTransferStatus {
  SENT
  RECEIVED
  CANCELLED

  @@schema("public")
}

// =============================================================================
// 7. TRIAGE MANCHESTER  (TDR §9)
// =============================================================================

/// TDR §9.1 / §9.3 — nivel Manchester parametrizable por organización.
model TriageLevel {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  color          TriageColor
  priority       Int /// 1=rojo .. 5=azul.
  name           String      @db.VarChar(40)
  maxWaitMinutes Int
  uiColorHex     String?     @db.VarChar(9)
  active         Boolean     @default(true)
  validFrom      DateTime    @default(now()) @db.Date
  validTo        DateTime?   @db.Date
  version        Int         @default(1)
  createdAt      DateTime    @default(now()) @db.Timestamptz()
  updatedAt      DateTime    @updatedAt @db.Timestamptz()

  flowcharts     TriageFlowchart[]
  discriminators TriageDiscriminator[]
  evaluations    TriageEvaluation[]

  @@unique([organizationId, color])
  @@unique([organizationId, priority])
  @@schema("public")
}

/// TDR §9.2 / §9.3 — flujograma de presentación Manchester (52 estándar + locales).
model TriageFlowchart {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  code           String    @db.VarChar(60) /// chest_pain, dyspnea, ...
  name           String    @db.VarChar(200)
  isPediatric    Boolean   @default(false)
  defaultLevelId String?   @db.Uuid /// nivel por defecto si ningún discriminador.
  active         Boolean   @default(true)
  validFrom      DateTime  @default(now()) @db.Date
  validTo        DateTime? @db.Date
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  defaultLevel   TriageLevel?               @relation(fields: [defaultLevelId], references: [id], onDelete: SetNull)
  discriminators TriageDiscriminator[]
  vitalSigns     TriageFlowchartVitalSign[]
  evaluations    TriageEvaluation[]

  @@unique([organizationId, code])
  @@schema("public")
}

/// TDR §9.2 — discriminador clínico (vía aérea, shock, dolor severo...).
/// El primer discriminador positivo determina el nivel.
model TriageDiscriminator {
  id            String    @id @default(uuid()) @db.Uuid
  flowchartId   String    @db.Uuid
  resultLevelId String    @db.Uuid
  code          String    @db.VarChar(60)
  text          String    @db.VarChar(400)
  ordinal       Int /// orden de evaluación dentro del flujograma.
  active        Boolean   @default(true)
  validFrom     DateTime  @default(now()) @db.Date
  validTo       DateTime? @db.Date
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  flowchart   TriageFlowchart          @relation(fields: [flowchartId], references: [id], onDelete: Cascade)
  resultLevel TriageLevel              @relation(fields: [resultLevelId], references: [id], onDelete: Restrict)
  hits        TriageDiscriminatorHit[]

  @@unique([flowchartId, ordinal])
  @@index([flowchartId])
  @@schema("public")
}

/// TDR §9.3 — signos vitales obligatorios por flujograma. 4NF: independiente de discriminadores.
model TriageFlowchartVitalSign {
  flowchartId String  @db.Uuid
  vitalCode   String  @db.VarChar(40) /// SpO2, BP, ECG, GLUC, GCS, PAIN, TEMP, HR, RR.
  required    Boolean @default(true)

  flowchart TriageFlowchart @relation(fields: [flowchartId], references: [id], onDelete: Cascade)

  @@id([flowchartId, vitalCode])
  @@schema("public")
}

/// TDR §9.2 — evaluación de triage de un encuentro.
model TriageEvaluation {
  id                     String       @id @default(uuid()) @db.Uuid
  countryId              String       @db.Uuid
  organizationId         String       @db.Uuid
  establishmentId        String       @db.Uuid
  serviceUnitId          String?      @db.Uuid
  patientId              String       @db.Uuid
  encounterId            String?      @db.Uuid
  flowchartId            String       @db.Uuid
  assignedLevelId        String       @db.Uuid /// nivel resultante.
  systemSuggestedLevelId String?      @db.Uuid /// lo que el sistema sugirió.
  overrideJustification  String?      @db.Text
  status                 TriageStatus @default(IN_PROGRESS)
  startedAt              DateTime     @default(now()) @db.Timestamptz()
  completedAt            DateTime?    @db.Timestamptz()
  reTriageOfId           String?      @db.Uuid /// si es re-triage, apunta al original.
  triagistUserId         String?      @db.Uuid
  createdAt              DateTime     @default(now()) @db.Timestamptz()
  createdBy              String?      @db.Uuid
  updatedAt              DateTime     @updatedAt @db.Timestamptz()
  updatedBy              String?      @db.Uuid

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  establishment   Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  serviceUnit     ServiceUnit?       @relation(fields: [serviceUnitId], references: [id], onDelete: SetNull)
  patient         Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  encounter       Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  flowchart       TriageFlowchart    @relation(fields: [flowchartId], references: [id], onDelete: Restrict)
  assignedLevel   TriageLevel        @relation(fields: [assignedLevelId], references: [id], onDelete: Restrict)
  reTriageOf      TriageEvaluation?  @relation("ReTriage", fields: [reTriageOfId], references: [id], onDelete: SetNull)
  reTriageOf_back TriageEvaluation[] @relation("ReTriage")

  vitalSigns        TriageVitalSign[]
  discriminatorHits TriageDiscriminatorHit[]
  emergencyVisits   EmergencyVisit[]          @relation("EmergencyTriageEval")

  @@index([patientId])
  @@index([organizationId, startedAt])
  @@index([assignedLevelId, startedAt])
  @@schema("public")
}

/// TDR §9.2 — signos vitales medidos durante el triage. 4NF: separación por tipo en filas.
model TriageVitalSign {
  id           String   @id @default(uuid()) @db.Uuid
  evaluationId String   @db.Uuid
  vitalCode    String   @db.VarChar(40)
  valueNumeric Decimal? @db.Decimal(10, 3)
  valueText    String?  @db.VarChar(120)
  unit         String?  @db.VarChar(20)
  measuredAt   DateTime @default(now()) @db.Timestamptz()

  evaluation TriageEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, vitalCode, measuredAt])
  @@index([evaluationId])
  @@schema("public")
}

/// TDR §9.2 — registro de discriminadores positivos durante la evaluación.
model TriageDiscriminatorHit {
  id              String   @id @default(uuid()) @db.Uuid
  evaluationId    String   @db.Uuid
  discriminatorId String   @db.Uuid
  positive        Boolean
  observedAt      DateTime @default(now()) @db.Timestamptz()
  notes           String?  @db.VarChar(400)

  evaluation    TriageEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  discriminator TriageDiscriminator @relation(fields: [discriminatorId], references: [id], onDelete: Restrict)

  @@unique([evaluationId, discriminatorId])
  @@schema("public")
}

// =============================================================================
// §10 Outpatient — Consulta Externa (Sprint 4 / Phase 2 entry)
// =============================================================================

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  NO_SHOW
  COMPLETED
  CANCELLED

  @@schema("public")
}

enum ReasonCategory {
  ROUTINE
  FOLLOWUP
  ACUTE
  PREVENTIVE
  CHRONIC
  OTHER

  @@schema("public")
}

/// TDR §10.1 — citas de consulta externa programadas.
model OutpatientAppointment {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @db.Uuid
  establishmentId String            @db.Uuid
  patientId       String            @db.Uuid
  providerId      String            @db.Uuid /// User (médico que atiende).
  specialtyId     String?           @db.Uuid /// MedicalSpecialty.
  serviceUnitId   String?           @db.Uuid
  scheduledAt     DateTime          @db.Timestamptz()
  durationMinutes Int               @default(20)
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?           @db.VarChar(500)
  reasonCategory  ReasonCategory?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @db.Timestamptz()
  createdBy       String?           @db.Uuid
  updatedAt       DateTime          @updatedAt @db.Timestamptz()
  updatedBy       String?           @db.Uuid
  deletedAt       DateTime?         @db.Timestamptz()

  organization  Organization             @relation("OrgAppointments", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment            @relation("EstAppointments", fields: [establishmentId], references: [id], onDelete: Restrict)
  patient       Patient                  @relation("PatAppointments", fields: [patientId], references: [id], onDelete: Restrict)
  provider      User                     @relation("ProviderAppointments", fields: [providerId], references: [id], onDelete: Restrict)
  consultations OutpatientConsultation[]

  @@unique([providerId, scheduledAt], name: "outpatient_appointment_provider_slot_unique")
  @@index([organizationId, scheduledAt])
  @@index([patientId])
  @@index([status])
  @@schema("public")
}

/// TDR §10.2 — registro SOAP de la consulta externa (vinculada a appointment + Encounter OUTPATIENT).
model OutpatientConsultation {
  id             String          @id @default(uuid()) @db.Uuid
  appointmentId  String?         @db.Uuid /// nullable para walk-ins sin cita.
  encounterId    String          @unique @db.Uuid /// Encounter de tipo OUTPATIENT.
  reasonOfVisit  String          @db.VarChar(500)
  reasonCategory ReasonCategory?
  subjective     String?         @db.Text
  objective      String?         @db.Text
  assessment     String?         @db.Text
  plan           String?         @db.Text
  signedAt       DateTime?       @db.Timestamptz()
  signedById     String?         @db.Uuid
  createdAt      DateTime        @default(now()) @db.Timestamptz()
  updatedAt      DateTime        @updatedAt @db.Timestamptz()

  appointment OutpatientAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  encounter   Encounter              @relation("EncOutpatientConsult", fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@schema("public")
}

// =============================================================================
// §15 Pharmacy — Drugs, Prescriptions, Dispense (Sprint 4 / Phase 4 entry)
// =============================================================================

enum PharmaceuticalForm {
  TABLET
  CAPSULE
  SYRUP
  INJECTION
  CREAM
  OINTMENT
  DROPS
  INHALER
  SUPPOSITORY
  PATCH
  OTHER

  @@schema("public")
}

enum DispensingClass {
  OTC
  RX
  RX_CONTROLLED

  @@schema("public")
}

enum PrescriptionStatus {
  DRAFT
  SIGNED
  DISPENSED
  PARTIALLY_DISPENSED
  CANCELLED
  EXPIRED

  @@schema("public")
}

enum AdminRoute {
  ORAL
  IV
  IM
  SC
  TOPICAL
  INHALED
  RECTAL
  SUBLINGUAL
  OPHTHALMIC
  OTIC
  NASAL

  @@schema("public")
}

/// TDR §15.1 — catálogo de medicamentos. organizationId NULL = global; not-null = formulario propio.
/// Ley Reguladora de Drogas SV: requiresControlledLog flag para psicotrópicos.
model Drug {
  id                    String             @id @default(uuid()) @db.Uuid
  organizationId        String?            @db.Uuid
  genericName           String             @db.VarChar(200)
  brandName             String?            @db.VarChar(200)
  atcCode               String?            @db.VarChar(20) /// ATC OMS clasificación.
  pharmaceuticalForm    PharmaceuticalForm
  strengthValue         Decimal            @db.Decimal(12, 4)
  strengthUnit          String             @db.VarChar(20) /// mg, ml, mcg, UI, %.
  /// Margen de tolerancia terapéutica para compras (guía GS1 El Salvador Nivel 1), SQL 174.
  marginTolerance       Decimal?           @map("margin_tolerance") @db.Decimal(12, 4)
  marginToleranceUnit   String?            @map("margin_tolerance_unit") @db.VarChar(20)
  dispensingClass       DispensingClass    @default(RX)
  requiresControlledLog Boolean            @default(false)
  active                Boolean            @default(true)
  /// Excipientes con potencial alergénico (GS1/WHO INN). Array TEXT[].
  allergyExcipients     String[]           @default([])
  /// JCI IPSG.3 ME 1 — ISMP High-Alert level: standard | high | very_high | critical
  alertLevel            String             @default("standard")
  /// Justificación ISMP para el nivel de alerta (ej. "ISMP High-Alert: insulin")
  alertRationale        String?
  createdAt             DateTime           @default(now()) @db.Timestamptz()
  updatedAt             DateTime           @updatedAt @db.Timestamptz()

  prescriptionItems PrescriptionItem[]
  classifiers       DrugClassifier[]

  @@index([genericName])
  @@index([organizationId])
  @@index([alertLevel])
  @@schema("public")
}

/// Mapeo N:M de un medicamento a vocabularios controlados externos
/// (ATC, SNOMED CT, UNSPSC, RxNorm, ...). Guía GS1 El Salvador Nivel 1:
/// permite múltiples clasificadores simultáneos. SQL 172.
model DrugClassifier {
  id        String   @id @default(uuid()) @db.Uuid
  drugId    String   @db.Uuid
  standard  String /// ATC | SNOMED | UNSPSC | RXNORM | CIE10 | LOINC
  value     String
  createdAt DateTime @default(now()) @db.Timestamptz()

  drug Drug @relation(fields: [drugId], references: [id], onDelete: Cascade)

  @@unique([drugId, standard, value])
  @@index([drugId])
  @@index([standard, value])
  @@schema("public")
}

/// TDR §15.2 — receta médica. Cabecera; los ítems son hijos.
model Prescription {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  encounterId    String             @db.Uuid
  prescriberId   String             @db.Uuid /// User (médico).
  patientId      String             @db.Uuid
  prescribedAt   DateTime           @default(now()) @db.Timestamptz()
  status         PrescriptionStatus @default(DRAFT)
  notes          String?            @db.Text
  signedAt       DateTime?          @db.Timestamptz()
  signedHash     String?            @db.VarChar(120) /// firma electrónica futura.
  createdAt      DateTime           @default(now()) @db.Timestamptz()
  updatedAt      DateTime           @updatedAt @db.Timestamptz()

  items PrescriptionItem[]

  @@index([organizationId, prescribedAt])
  @@index([encounterId])
  @@index([patientId])
  @@schema("public")
}

/// TDR §15.2 — ítem de receta (un medicamento por línea con dosificación).
/// Beta.8: prescribedQty + administeredQty para cumulative-qty enforcement.
model PrescriptionItem {
  id              String     @id @default(uuid()) @db.Uuid
  prescriptionId  String     @db.Uuid
  drugId          String     @db.Uuid
  dosage          String     @db.VarChar(120) /// "500mg cada 8h"
  route           AdminRoute
  frequency       String     @db.VarChar(80) /// "QID", "BID", "PRN"
  durationDays    Int?
  prnAsNeeded     Boolean    @default(false)
  notes           String?    @db.Text
  /// Cantidad total prescrita (unidades de dosis) — base para enforcement de qty.
  prescribedQty   Decimal    @default(0) @db.Decimal(12, 4)
  /// Qty acumulada de administraciones con status=ADMINISTERED. Actualizada por trigger.
  administeredQty Decimal    @default(0) @db.Decimal(12, 4)

  prescription    Prescription               @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug            Drug                       @relation(fields: [drugId], references: [id], onDelete: Restrict)
  dispenses       MedicationDispense[]
  administrations MedicationAdministration[] @relation("MedAdminItem")

  @@index([prescriptionId])
  @@schema("public")
}

/// US.F2.6.8 — Reserva lógica de unidad GS1 (GTIN+lote+serie) al paciente.
/// Expira automáticamente en 4 h si no se confirma el despacho.
/// El índice parcial uq_pharma_reservation_active en SQL 89 previene doble RESERVED.
model PharmacyReservation {
  id              String                    @id @default(uuid()) @db.Uuid
  organizationId  String                    @db.Uuid
  pharmacyOrderId String                    @db.Uuid /// FK a PharmacyOrder
  patientId       String                    @db.Uuid
  gtin            String                    @db.Char(14)    /// GTIN-14 GS1
  lote            String                    @db.VarChar(80)
  serie           String?                   @db.VarChar(80) /// número de serie; null si ítem sin serie
  status          PharmacyReservationStatus @default(RESERVED)
  expiresAt       DateTime                  @db.Timestamptz() /// now() + 4h al crear
  cancelMotivo    String?                   @db.Text
  createdAt       DateTime                  @default(now()) @db.Timestamptz()
  updatedAt       DateTime                  @updatedAt @db.Timestamptz()

  organization  Organization   @relation("OrgPharmacyReservations", fields: [organizationId], references: [id], onDelete: Restrict)
  pharmacyOrder PharmacyOrder  @relation(fields: [pharmacyOrderId], references: [id], onDelete: Restrict)
  patient       Patient        @relation("PatPharmacyReservations", fields: [patientId], references: [id], onDelete: Restrict)

  @@index([organizationId, patientId])
  @@index([pharmacyOrderId])
  @@index([expiresAt])
  @@schema("public")
}

enum PharmacyReservationStatus {
  RESERVED
  CONFIRMED
  DISPATCHED
  CANCELLED
  EXPIRED

  @@schema("public")
}

/// TDR §15.3 — dispensación (registro por farmacéutico).
model MedicationDispense {
  id                 String    @id @default(uuid()) @db.Uuid
  prescriptionItemId String    @db.Uuid
  dispensedAt        DateTime  @default(now()) @db.Timestamptz()
  dispensedById      String    @db.Uuid /// User (farmacéutico).
  quantity           Decimal   @db.Decimal(12, 4)
  batchNumber        String?   @db.VarChar(80)
  expiryDate         DateTime? @db.Date
  notes              String?   @db.Text

  item PrescriptionItem @relation(fields: [prescriptionItemId], references: [id], onDelete: Restrict)
  cartItems PharmacyCartItem[]

  @@index([prescriptionItemId])
  @@index([dispensedAt])
  @@schema("public")
}

// =============================================================================
// §17 LIS — Lab Information System (Sprint 4 / Phase 4 entry)
// LOINC codes via ClinicalConcept existentes (no nuevos modelos para códigos).
// =============================================================================

enum SpecimenType {
  BLOOD
  URINE
  STOOL
  CSF
  SWAB
  TISSUE
  SALIVA
  OTHER

  @@schema("public")
}

enum LabPriority {
  ROUTINE
  URGENT
  STAT

  @@schema("public")
}

enum LabOrderStatus {
  DRAFT
  ORDERED
  COLLECTED
  IN_PROCESS
  RESULTED
  VALIDATED
  CANCELLED

  @@schema("public")
}

enum SpecimenCondition {
  ACCEPTABLE
  REJECTED
  HEMOLYZED
  CLOTTED
  INSUFFICIENT

  @@schema("public")
}

enum ResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL_LOW
  CRITICAL_HIGH
  ABNORMAL

  @@schema("public")
}

/// TDR §17.1 — panel de lab (agrupa tests; ej. hemograma).
model LabPanel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid /// null = catálogo global.
  code           String   @db.VarChar(20) /// LOINC.
  name           String   @db.VarChar(200)
  description    String?  @db.Text
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  tests LabTest[]

  @@index([code])
  @@schema("public")
}

/// TDR §17.1 — test individual de lab.
model LabTest {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @db.Uuid
  panelId        String?      @db.Uuid /// null = test independiente sin panel.
  code           String       @db.VarChar(20) /// LOINC.
  name           String       @db.VarChar(200)
  specimen       SpecimenType
  unit           String?      @db.VarChar(40)
  refRangeLow    Decimal?     @db.Decimal(18, 6)
  refRangeHigh   Decimal?     @db.Decimal(18, 6)
  refRangeText   String?      @db.VarChar(200) /// para resultados cualitativos.
  critical       Boolean      @default(false)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @db.Timestamptz()

  panel           LabPanel?           @relation(fields: [panelId], references: [id], onDelete: SetNull)
  orderItems      LabOrderItem[]
  referenceRanges LabReferenceRange[]
  triggersFor     LabReflexRule[]     @relation("LabReflexTrigger")
  reflexesFor     LabReflexRule[]     @relation("LabReflexReflex")

  @@index([code])
  @@index([panelId])
  @@schema("public")
}

/// TDR §17.2 — orden de lab. Cabecera con items.
model LabOrder {
  id                   String         @id @default(uuid()) @db.Uuid
  organizationId       String         @db.Uuid
  encounterId          String         @db.Uuid
  prescriberId         String         @db.Uuid /// User.
  patientId            String         @db.Uuid
  orderedAt            DateTime       @default(now()) @db.Timestamptz()
  priority             LabPriority    @default(ROUTINE)
  status               LabOrderStatus @default(DRAFT)
  clinicalIndication   String?        @db.Text
  externalLabRef       String?        @db.VarChar(120) /// si se externaliza a un lab externo.
  /// Centro de costo solicitante (productivo o intermedio que pidió el estudio).
  costCenterId         String?        @db.Uuid
  /// Centro intermedio ejecutor (normalmente 2-LAB-CLI; asignado por defecto en el router).
  ejecutorCostCenterId String?        @db.Uuid
  createdAt            DateTime       @default(now()) @db.Timestamptz()
  updatedAt            DateTime       @updatedAt @db.Timestamptz()

  items            LabOrderItem[]
  specimens        LabSpecimen[]
  costCenter       CostCenter?    @relation("LabOrderSolicitante", fields: [costCenterId], references: [id], onDelete: Restrict)
  ejecutorCostCenter CostCenter?  @relation("LabOrderEjecutor", fields: [ejecutorCostCenterId], references: [id], onDelete: Restrict)
  // HH-10 (audit Stream H): relaciones declaradas — las FK físicas ya existen.
  patient          Patient        @relation("PatLabOrders", fields: [patientId], references: [id], onDelete: Restrict)
  encounter        Encounter      @relation("EncLabOrders", fields: [encounterId], references: [id], onDelete: Restrict)

  @@index([organizationId, orderedAt])
  @@index([encounterId])
  @@index([patientId])
  @@index([costCenterId])
  @@index([ejecutorCostCenterId])
  @@schema("public")
}

/// TDR §17.2 — ítem de orden (un test por línea).
model LabOrderItem {
  id      String         @id @default(uuid()) @db.Uuid
  orderId String         @db.Uuid
  testId  String         @db.Uuid
  status  LabOrderStatus @default(ORDERED)
  notes   String?        @db.Text

  order   LabOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test    LabTest     @relation(fields: [testId], references: [id], onDelete: Restrict)
  results LabResult[]

  @@index([orderId])
  @@schema("public")
}

/// TDR §17.3 — espécimen físico (una orden puede tener N especímenes).
model LabSpecimen {
  id              String            @id @default(uuid()) @db.Uuid
  orderId         String            @db.Uuid
  type            SpecimenType
  collectedAt     DateTime?         @db.Timestamptz()
  collectedById   String?           @db.Uuid
  barcode         String            @unique @db.VarChar(80)
  condition       SpecimenCondition @default(ACCEPTABLE)
  rejectionReason String?           @db.VarChar(400)
  createdAt       DateTime          @default(now()) @db.Timestamptz()

  /// IPSG.1-H1: GSRN escaneado de la pulsera del paciente en bedside (AI 8018).
  /// Persiste evidencia de la verificación JCI; null en flujo lab sin pulsera.
  gsrnPacienteVerificado String?  @db.VarChar(20)
  /// IPSG.1-H1: tipo del segundo identificador usado (DUI/NOMBRE_COMPLETO/FECHA_NAC/MRN).
  identifier2Kind        String?  @db.VarChar(20)
  /// IPSG.1-H1: valor del segundo identificador verificado.
  identifier2Value       String?  @db.Text
  /// IPSG.1-H1: timestamp de la verificación 2-IDs. Null = flujo sin pulsera.
  verifiedAt             DateTime? @db.Timestamptz()
  /// IPSG.1-H1: usuario que realizó la verificación bedside.
  verifiedBy             String?  @db.Uuid

  order          LabOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  verifiedByUser User?       @relation("LabSpecimenVerifiedBy", fields: [verifiedBy], references: [id], onDelete: Restrict)
  results        LabResult[]

  @@index([orderId])
  @@index([verifiedAt])
  @@schema("public")
}

/// TDR §17.4 — resultado validado por lab tech (cuatro-ojos).
model LabResult {
  id            String     @id @default(uuid()) @db.Uuid
  orderItemId   String     @db.Uuid
  specimenId    String?    @db.Uuid
  resultedAt    DateTime   @default(now()) @db.Timestamptz()
  resultedById  String     @db.Uuid /// User que entró el resultado.
  valueNumeric  Decimal?   @db.Decimal(18, 6)
  valueText     String?    @db.VarChar(800)
  valueUnit     String?    @db.VarChar(40)
  flag          ResultFlag @default(NORMAL)
  notes         String?    @db.Text
  validatedAt   DateTime?  @db.Timestamptz()
  validatedById String?    @db.Uuid /// User distinto de resultedById (regla 4-eyes).
  confidential  Boolean    @default(false) /// K-16: requiere counseling previo (HIV, oncológico, salud mental). Bloquea visibilidad en portal aunque showInPortal=true.
  showInPortal  Boolean    @default(true)  /// K-16: visibilidad en portal del paciente. Default true preserva comportamiento legacy.
  createdAt     DateTime   @default(now()) @db.Timestamptz()
  updatedAt     DateTime   @updatedAt @db.Timestamptz()

  orderItem LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  specimen  LabSpecimen? @relation(fields: [specimenId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([validatedAt])
  @@schema("public")
}

/// TDR §17 — rangos de referencia estratificados por sexo/edad (Wave 2 stratification).
/// Creado vía SQL 27_lis_hardening_v2 (no por prisma migrate); RLS por tenant en SQL 41.
model LabReferenceRange {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?  @db.Uuid /// null = catálogo global.
  labTestId      String   @db.Uuid
  minValue       Decimal? @db.Decimal(18, 6)
  maxValue       Decimal? @db.Decimal(18, 6)
  ageMinYears    Int?
  ageMaxYears    Int?
  sex            String   @default("BOTH") @db.VarChar(10) /// CHECK enforced en DB: MALE | FEMALE | BOTH.
  criticalLow    Decimal? @db.Decimal(18, 6)
  criticalHigh   Decimal? @db.Decimal(18, 6)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @default(now()) @db.Timestamptz()

  labTest LabTest @relation(fields: [labTestId], references: [id], onDelete: Cascade)

  @@index([labTestId, sex, ageMinYears, ageMaxYears])
  @@index([organizationId])
  @@schema("public")
}

/// TDR §17 — reglas de reflex testing automation.
/// Creado vía SQL 27_lis_hardening_v2 (no por prisma migrate); RLS por tenant en SQL 41.
model LabReflexRule {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String?  @db.Uuid /// null = catálogo global.
  triggerTestId    String   @db.Uuid
  reflexTestId     String   @db.Uuid
  triggerCondition String   @db.VarChar(20) /// CHECK enforced en DB: ABOVE | BELOW | POSITIVE | FLAGGED.
  triggerThreshold Decimal? @db.Decimal(18, 6)
  description      String?  @db.Text
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @db.Timestamptz()
  updatedAt        DateTime @default(now()) @db.Timestamptz()

  triggerTest LabTest @relation("LabReflexTrigger", fields: [triggerTestId], references: [id], onDelete: Cascade)
  reflexTest  LabTest @relation("LabReflexReflex", fields: [reflexTestId], references: [id], onDelete: Restrict)

  @@index([triggerTestId])
  @@index([organizationId])
  @@schema("public")
}

// =============================================================================
// §14 EHR Clinical Notes (Sprint 4 / Phase 4 entry)
// Notas SOAP firmadas + diagnoses (CIE-10 via ClinicalConcept existente).
// =============================================================================

enum NoteType {
  PROGRESS
  ADMISSION
  DISCHARGE_SUMMARY
  CONSULTATION
  NURSING
  EMERGENCY

  @@schema("public")
}

enum DiagnosisType {
  PRINCIPAL
  SECONDARY
  RULE_OUT
  CHRONIC

  @@schema("public")
}

/// TDR §14.1 — nota clínica SOAP. Firmada = inmutable; addendum encadenado.
model ClinicalNote {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  encounterId    String    @db.Uuid
  authorId       String    @db.Uuid /// User.
  authoredAt     DateTime  @default(now()) @db.Timestamptz()
  noteType       NoteType
  specialtyId    String?   @db.Uuid /// MedicalSpecialty.
  subjective     String?   @db.Text
  objective      String?   @db.Text
  assessment     String?   @db.Text
  plan           String?   @db.Text
  addendumOfId   String?   @db.Uuid /// FK self-ref para chain de addenda.
  signedAt       DateTime? @db.Timestamptz()
  signatureHash  String?   @db.VarChar(120)
  /// Historial de cambios pre-firma. Array [{at, by, action, diff}]. Max 50 entries (oldest dropped).
  editHistory    Json?
  /// K-05 audit Stream K: gate explícita de visibilidad al Portal Paciente.
  /// Default false — el clínico debe marcar la nota como publicable.
  /// Filtra notas psiquiátricas, trabajo social, sospecha de abuso, addenda internos
  /// que no deben llegar al portal sin counseling previo (LGPDP Art. 9 / TDR §5.2).
  isPortalVisible Boolean  @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  addendumOf  ClinicalNote?            @relation("NoteAddendum", fields: [addendumOfId], references: [id], onDelete: Restrict)
  addenda     ClinicalNote[]           @relation("NoteAddendum")
  attachments ClinicalNoteAttachment[]

  @@index([organizationId, encounterId])
  @@index([authorId])
  @@index([authoredAt])
  @@schema("public")
}

/// TDR §14.1.b — adjuntos en Supabase Storage.
model ClinicalNoteAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  noteId       String   @db.Uuid
  fileName     String   @db.VarChar(200)
  mimeType     String   @db.VarChar(100)
  sizeBytes    Int
  storageKey   String   @db.VarChar(400) /// path en bucket clinical-attachments.
  uploadedAt   DateTime @default(now()) @db.Timestamptz()
  uploadedById String   @db.Uuid

  note ClinicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@schema("public")
}

/// TDR §14.2 — diagnoses asociados al encuentro (CIE-10 via ClinicalConcept).
model EncounterDiagnosis {
  id            String        @id @default(uuid()) @db.Uuid
  encounterId   String        @db.Uuid
  conceptId     String        @db.Uuid /// FK a ClinicalConcept (CIE-10).
  type          DiagnosisType
  diagnosedAt   DateTime      @default(now()) @db.Timestamptz()
  diagnosedById String        @db.Uuid
  notes         String?       @db.Text
  resolvedAt    DateTime?     @db.Timestamptz()
  createdAt     DateTime      @default(now()) @db.Timestamptz()
  updatedAt     DateTime      @updatedAt @db.Timestamptz()

  encounter Encounter @relation("EncDiagnoses", fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@index([conceptId])
  @@schema("public")
}

// =============================================================================
// §11 Inpatient — Hospitalización (Wave 7 / Phase 2 entry)
// =============================================================================

/// ISSS MNP-S-138 — los 3 hitos del ciclo hospitalario.
/// Spec: docs/36_admision_vs_ingreso_isss.md
enum InpatientStatus {
  ADMISSION_DECIDED   /// Hito 1: médico indicó ingreso, sin cama
  BED_ASSIGNED        /// Hito 2: cama reservada, sin recibir paciente
  ACTIVE              /// Hito 3: paciente físicamente en sala (inicia día-cama)
  DISCHARGE_PENDING   /// alta firmada, esperando salida administrativa
  ON_LEAVE            /// permiso pase domiciliario
  CANCELLED           /// admisión revertida pre-recepción física
  DISCHARGED          /// alta efectiva (terminal)
  TRANSFERRED_OUT     /// transferido a otra org (terminal)

  @@schema("public")
}

enum CarePlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("public")
}

/// TDR §11.1 — admisión hospitalaria (encuentro INPATIENT). 1:1 con Encounter.
model InpatientAdmission {
  id              String          @id @default(uuid()) @db.Uuid
  organizationId  String          @db.Uuid
  establishmentId String          @db.Uuid
  encounterId     String          @unique @db.Uuid /// Encounter INPATIENT.
  patientId       String          @db.Uuid
  attendingId     String          @db.Uuid /// User (médico tratante).
  admittedAt      DateTime        @default(now()) @db.Timestamptz()
  expectedLos     Int? /// estancia esperada en días.
  reason          String          @db.VarChar(400)
  status          InpatientStatus @default(ACTIVE)
  dischargedAt    DateTime?       @db.Timestamptz()
  notes           String?         @db.Text
  // Wave 10 — imputación a centro de costo productivo (migration cost_center_id_clinical_modules_2026_05_25)
  costCenterId    String?         @db.Uuid
  // ISSS MNP-S-138 — los 3 hitos del ciclo hospitalario (migration 136_admision_vs_ingreso_isss.sql)
  // Hito 1: decisión clínica
  admissionDecidedAt    DateTime? @db.Timestamptz()
  admissionDecidedById  String?   @db.Uuid
  // Hito 2: asignación operativa de cama
  bedAssignedAt         DateTime? @db.Timestamptz()
  bedAssignedById       String?   @db.Uuid
  bedId                 String?   @db.Uuid
  // Hito 3: recepción física (INICIA DÍA-CAMA, Norma General 6)
  physicalAdmittedAt    DateTime? @db.Timestamptz()
  physicalAdmittedById  String?   @db.Uuid
  wristbandPlacedAt     DateTime? @db.Timestamptz()
  admissionFormNumber   String?   @db.VarChar(40) /// SAFISSS 130201132
  createdAt       DateTime        @default(now()) @db.Timestamptz()
  createdBy       String?         @db.Uuid
  updatedAt       DateTime        @updatedAt @db.Timestamptz()
  updatedBy       String?         @db.Uuid
  deletedAt       DateTime?       @db.Timestamptz()

  organization  Organization  @relation("OrgInpatientAdmissions", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment @relation("EstInpatientAdmissions", fields: [establishmentId], references: [id], onDelete: Restrict)
  encounter     Encounter     @relation("EncInpatientAdmission", fields: [encounterId], references: [id], onDelete: Cascade)
  patient       Patient       @relation("PatInpatientAdmissions", fields: [patientId], references: [id], onDelete: Restrict)
  attending     User          @relation("InpatientAttending", fields: [attendingId], references: [id], onDelete: Restrict)
  costCenter    CostCenter?   @relation("InpatientAdmissionCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)

  vitalsLog InpatientVitals[]
  kardexLog InpatientKardex[]
  carePlans InpatientCarePlan[]

  @@index([organizationId, admittedAt])
  @@index([patientId])
  @@index([attendingId])
  @@index([status])
  @@index([establishmentId])
  @@schema("public")
}

/// TDR §11.2 — signos vitales registrados por enfermería durante la hospitalización.
model InpatientVitals {
  id              String   @id @default(uuid()) @db.Uuid
  admissionId     String   @db.Uuid
  recordedAt      DateTime @default(now()) @db.Timestamptz()
  recordedById    String   @db.Uuid /// User (enfermero/a).
  temperatureC    Decimal? @db.Decimal(4, 1)
  heartRate       Int?
  respiratoryRate Int?
  systolicBp      Int?
  diastolicBp     Int?
  spo2            Int?
  painScale       Int? /// 0-10 escala visual.
  notes           String?  @db.Text

  admission InpatientAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@index([recordedById])
  @@schema("public")
}

/// TDR §11.3 — kardex de enfermería: indicaciones y eventos por turno.
model InpatientKardex {
  id           String   @id @default(uuid()) @db.Uuid
  admissionId  String   @db.Uuid
  recordedAt   DateTime @default(now()) @db.Timestamptz()
  recordedById String   @db.Uuid
  category     String   @db.VarChar(40) /// "DIET", "ACTIVITY", "OBSERVATION", "PROCEDURE"
  entry        String   @db.Text
  shift        String?  @db.VarChar(20) /// "MORNING", "AFTERNOON", "NIGHT".

  admission InpatientAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@index([recordedById])
  @@schema("public")
}

/// TDR §11.4 — plan de cuidados de enfermería (NANDA / NIC / NOC simplificado).
model InpatientCarePlan {
  id            String         @id @default(uuid()) @db.Uuid
  admissionId   String         @db.Uuid
  title         String         @db.VarChar(200)
  goal          String?        @db.Text
  interventions String?        @db.Text
  status        CarePlanStatus @default(DRAFT)
  startedAt     DateTime       @default(now()) @db.Timestamptz()
  completedAt   DateTime?      @db.Timestamptz()
  createdById   String         @db.Uuid
  createdAt     DateTime       @default(now()) @db.Timestamptz()
  updatedAt     DateTime       @updatedAt @db.Timestamptz()

  admission InpatientAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId])
  @@index([createdById])
  @@index([status])
  @@schema("public")
}

// =============================================================================
// §12 Emergency — Urgencias (Wave 7 / Phase 2 entry)
// =============================================================================

enum EmergencyDisposition {
  PENDING
  DISCHARGED
  ADMITTED
  TRANSFERRED
  LWBS /// Left Without Being Seen.
  AMA /// Against Medical Advice.
  DECEASED

  @@schema("public")
}

enum EmergencyArrivalMode {
  WALK_IN
  AMBULANCE
  POLICE
  REFERRAL
  PRIVATE_VEHICLE
  OTHER

  @@schema("public")
}

/// TDR §12.1 — visita de urgencias. Vinculado a Encounter EMERGENCY 1:1.
model EmergencyVisit {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @db.Uuid
  establishmentId      String               @db.Uuid
  encounterId          String               @unique @db.Uuid
  patientId            String               @db.Uuid
  treatingId           String?              @db.Uuid /// User (médico de urgencias).
  /// TDR §12.4 — referencia al triage Manchester que habilita la admisión. Nullable para compatibilidad con registros anteriores.
  triageEvaluationId   String?              @db.Uuid
  arrivedAt            DateTime             @default(now()) @db.Timestamptz()
  arrivalMode          EmergencyArrivalMode @default(WALK_IN)
  chiefComplaint       String               @db.VarChar(400)
  disposition          EmergencyDisposition @default(PENDING)
  dispositionAt        DateTime?            @db.Timestamptz()
  observationStartedAt DateTime?            @db.Timestamptz()
  observationEndedAt   DateTime?            @db.Timestamptz()
  notes                String?              @db.Text
  createdAt            DateTime             @default(now()) @db.Timestamptz()
  createdBy            String?              @db.Uuid
  updatedAt            DateTime             @updatedAt @db.Timestamptz()
  updatedBy            String?              @db.Uuid
  deletedAt            DateTime?            @db.Timestamptz()

  organization      Organization      @relation("OrgEmergencyVisits", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment     Establishment     @relation("EstEmergencyVisits", fields: [establishmentId], references: [id], onDelete: Restrict)
  encounter         Encounter         @relation("EncEmergencyVisit", fields: [encounterId], references: [id], onDelete: Cascade)
  patient           Patient           @relation("PatEmergencyVisits", fields: [patientId], references: [id], onDelete: Restrict)
  treating          User?             @relation("EmergencyTreating", fields: [treatingId], references: [id], onDelete: SetNull)
  triageEvaluation  TriageEvaluation? @relation("EmergencyTriageEval", fields: [triageEvaluationId], references: [id], onDelete: SetNull)

  notesLog EmergencyNote[]

  @@index([organizationId, arrivedAt])
  @@index([patientId])
  @@index([treatingId])
  @@index([triageEvaluationId])
  @@index([disposition])
  @@index([establishmentId])
  @@schema("public")
}

/// TDR §12.2 — notas de evolución durante la visita de urgencias.
model EmergencyNote {
  id           String   @id @default(uuid()) @db.Uuid
  visitId      String   @db.Uuid
  recordedAt   DateTime @default(now()) @db.Timestamptz()
  recordedById String   @db.Uuid
  category     String   @db.VarChar(40) /// "OBSERVATION", "TREATMENT", "REASSESSMENT".
  body         String   @db.Text

  visit EmergencyVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId, recordedAt])
  @@index([recordedById])
  @@schema("public")
}

// =============================================================================
// §13 Surgery — Quirófano (Wave 7 / Phase 2 entry)
// =============================================================================

enum SurgeryCaseStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  POST_OP
  COMPLETED
  CANCELLED
  POSTPONED

  @@schema("public")
}

/// WHO Surgical Safety Checklist — anesthesia type for SurgeryCase.
enum AnesthesiaType {
  GENERAL
  REGIONAL
  LOCAL
  SEDATION
  NONE

  @@schema("public")
}

enum AsaClass {
  ASA_I
  ASA_II
  ASA_III
  ASA_IV
  ASA_V
  ASA_VI

  @@schema("public")
}

/// TDR §13.1 — quirófano físico (Operating Room).
model OperatingRoom {
  id              String   @id @default(uuid()) @db.Uuid
  establishmentId String   @db.Uuid
  /// Nivel B — sql/61. FK opcional al ServiceUnit (típicamente QX).
  /// Permite filtrar SurgeryCase por el servicio operativo del OR.
  serviceUnitId   String?  @db.Uuid
  code            String   @db.VarChar(40)
  name            String   @db.VarChar(120)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  serviceUnit   ServiceUnit?  @relation(fields: [serviceUnitId], references: [id], onDelete: SetNull)
  cases         SurgeryCase[]

  @@unique([establishmentId, code])
  @@index([establishmentId])
  @@index([serviceUnitId])
  @@schema("public")
}

/// TDR §13.2 — caso quirúrgico programado/intervenido.
model SurgeryCase {
  id                   String            @id @default(uuid()) @db.Uuid
  organizationId       String            @db.Uuid
  establishmentId      String            @db.Uuid
  encounterId          String            @db.Uuid
  patientId            String            @db.Uuid
  operatingRoomId      String?           @db.Uuid
  primarySurgeonId     String            @db.Uuid /// User.
  scheduledStart       DateTime          @db.Timestamptz()
  scheduledEnd         DateTime          @db.Timestamptz()
  actualStart          DateTime?         @db.Timestamptz()
  actualEnd            DateTime?         @db.Timestamptz()
  procedureDescription String            @db.VarChar(400)
  procedureCode        String?           @db.VarChar(40) /// CIE-9-CM / CPT.
  asaClass             AsaClass?
  /// WHO Surgical Safety Checklist — Sign In (paciente identificado + consentimiento).
  signInAt             DateTime?         @db.Timestamptz()
  signInById           String?           @db.Uuid
  timeOutAt            DateTime?         @db.Timestamptz()
  timeOutById          String?           @db.Uuid
  /// WHO Surgical Safety Checklist — Sign Out (count instrumentos, especímenes).
  signOutAt            DateTime?         @db.Timestamptz()
  signOutById          String?           @db.Uuid
  /// Anestesia: tipo + duración tracking.
  anesthesiaType       AnesthesiaType?
  anesthesiaStartAt    DateTime?         @db.Timestamptz()
  anesthesiaEndAt      DateTime?         @db.Timestamptz()
  status               SurgeryCaseStatus @default(SCHEDULED)
  preopNotes           String?           @db.Text
  intraopNotes         String?           @db.Text
  postopNotes          String?           @db.Text
  cancelReason         String?           @db.VarChar(400)
  /// Imputación financiera a centro de costo quirúrgico (132_cost_center_clinical_modules.sql).
  costCenterId         String?           @db.Uuid
  createdAt            DateTime          @default(now()) @db.Timestamptz()
  createdBy            String?           @db.Uuid
  updatedAt            DateTime          @updatedAt @db.Timestamptz()
  updatedBy            String?           @db.Uuid
  deletedAt            DateTime?         @db.Timestamptz()

  organization   Organization   @relation("OrgSurgeryCases", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment  Establishment  @relation("EstSurgeryCases", fields: [establishmentId], references: [id], onDelete: Restrict)
  encounter      Encounter      @relation("EncSurgeryCases", fields: [encounterId], references: [id], onDelete: Restrict)
  patient        Patient        @relation("PatSurgeryCases", fields: [patientId], references: [id], onDelete: Restrict)
  operatingRoom  OperatingRoom? @relation(fields: [operatingRoomId], references: [id], onDelete: SetNull)
  primarySurgeon User           @relation("SurgeryPrimarySurgeon", fields: [primarySurgeonId], references: [id], onDelete: Restrict)
  costCenter     CostCenter?    @relation("SurgeryCaseCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)

  @@index([organizationId, scheduledStart])
  @@index([patientId])
  @@index([primarySurgeonId])
  @@index([operatingRoomId])
  @@index([status])
  @@index([establishmentId])
  @@index([costCenterId])
  @@schema("public")
}

// =============================================================================
// §16 eMAR — Electronic Medication Administration Record (Wave 7 / Phase 2 entry)
// =============================================================================

enum MedAdminStatus {
  SCHEDULED
  ADMINISTERED
  GIVEN
  HELD
  REFUSED
  MISSED
  DOCUMENTED_LATE
  /// Cancelado por enfermería con motivo obligatorio.
  CANCELED

  @@schema("public")
}

/// TDR §16.1 — administración de medicamento.
/// Beta.8 hardening layer 1: BCMA (3 scans), doble-check alto riesgo,
/// timing-window ±N min, override con audit, qty acumulada en PrescriptionItem.
model MedicationAdministration {
  id                      String         @id @default(uuid()) @db.Uuid
  organizationId          String         @db.Uuid
  prescriptionItemId      String         @db.Uuid
  administeredAt          DateTime       @default(now()) @db.Timestamptz()
  administeredById        String         @db.Uuid /// User (enfermero/a).
  /// Doble-check requerido para alto riesgo (requiresControlledLog=true o RX_CONTROLLED).
  secondVerifierId        String?        @db.Uuid
  status                  MedAdminStatus @default(SCHEDULED)
  doseAmount              Decimal?       @db.Decimal(12, 4)
  doseUnit                String?        @db.VarChar(20)
  route                   AdminRoute?
  site                    String?        @db.VarChar(80)
  /// BCMA — los tres scans deben ser true para STATUS=ADMINISTERED.
  patientBarcodeScanned   Boolean        @default(false)
  drugBarcodeScanned      Boolean        @default(false)
  providerBadgeScanned    Boolean        @default(false)
  scannedAt               DateTime?      @db.Timestamptz()
  /// Campos legacy mantenidos por compatibilidad.
  barcodeScannedAt        DateTime?      @db.Timestamptz()
  patientWristbandScanned Boolean        @default(false)
  doubleCheckById         String?        @db.Uuid
  /// Timing-window enforcement.
  scheduledTime           DateTime?      @db.Timestamptz()
  timingWindowMinutes     Int            @default(30)
  /// Override de timing o qty con audit.
  overrideReason          String?        @db.VarChar(500)
  notes                   String?        @db.Text
  /// BCMA bedside GS1 — campos opcionales para compatibilidad con admin manual legacy.
  /// US.F2.6.30-33: bedsideValidationId FK opcional al evento de scan bedside (Stream 01/10).
  bedsideValidationId     String?        @map("bedside_validation_id") @db.Uuid
  gtinScanned             String?        @map("gtin_scanned") @db.VarChar(50)
  loteScanned             String?        @map("lote_scanned") @db.VarChar(50)
  serieScanned            String?        @map("serie_scanned") @db.VarChar(50)
  gsrnPaciente            String?        @map("gsrn_paciente") @db.VarChar(20)
  gsrnEnfermera           String?        @map("gsrn_enfermera") @db.VarChar(20)
  glnUbicacion            String?        @map("gln_ubicacion") @db.VarChar(15)
  /// Cancelación de enfermería con motivo obligatorio.
  cancelReason            String?        @map("cancel_reason") @db.VarChar(500)
  canceledAt              DateTime?      @map("canceled_at") @db.Timestamptz()
  canceledById            String?        @map("canceled_by_id") @db.Uuid
  /// JCI IPSG.3 ME 4 — verificación independiente de 2 enfermeras para high-alert meds.
  doubleCheckBy           String?        @db.Uuid
  doubleCheckAt           DateTime?      @db.Timestamptz()
  /// Hash argon2id del PIN de la verificadora. Nunca se almacena texto plano.
  doubleCheckPin          String?        @db.Text
  /// JCI IPSG.3-H1 (US-21-D4) — LASA acknowledgement bloqueante.
  /// Timestamp en que el profesional reconoció explícitamente el riesgo LASA.
  lasaAckAt               DateTime?      @map("lasa_ack_at") @db.Timestamptz()
  /// UUID del User que reconoció el par LASA (debe ser el mismo que administra).
  lasaAckBy               String?        @map("lasa_ack_by") @db.Uuid
  /// Razón clínica registrada en el acknowledgement LASA (audit trail JCI surveyor).
  lasaAckReason           String?        @map("lasa_ack_reason") @db.VarChar(500)
  createdAt               DateTime       @default(now()) @db.Timestamptz()
  updatedAt               DateTime       @updatedAt @db.Timestamptz()

  organization     Organization     @relation("OrgMedAdmins", fields: [organizationId], references: [id], onDelete: Restrict)
  prescriptionItem PrescriptionItem @relation("MedAdminItem", fields: [prescriptionItemId], references: [id], onDelete: Restrict)
  administeredBy   User             @relation("MedAdminAdministrator", fields: [administeredById], references: [id], onDelete: Restrict)
  secondVerifier   User?            @relation("MedAdminSecondVerifier", fields: [secondVerifierId], references: [id], onDelete: Restrict)
  canceledBy       User?            @relation("MedAdminCanceledBy", fields: [canceledById], references: [id], onDelete: Restrict)

  @@index([organizationId, administeredAt])
  @@index([prescriptionItemId])
  @@index([administeredById])
  @@index([status])
  @@index([scheduledTime])
  @@index([bedsideValidationId])
  @@schema("public")
}

// =============================================================================
// =============================================================================
// §18 RIS/PACS — Imaging Orders & Modalities (Wave 7 / Phase 2 entry)
// Beta.9 hardening layer 1: state machine, DICOM codes, urgency SLA, immutability
// =============================================================================

enum ImagingModalityType {
  CR /// Computed Radiography
  CT /// Computed Tomography
  MR /// Magnetic Resonance
  US /// Ultrasound
  XA /// X-ray Angiography
  MG /// Mammography
  NM /// Nuclear Medicine
  PT /// PET
  OTHER

  @@schema("public")
}

/// DICOM standard modality codes (IOD C.7.3.1.1.1) for dicomCode validation.
enum DicomModality {
  CT
  MR
  US
  XR
  MG
  NM
  PT
  DX
  RF

  @@schema("public")
}

/// State machine: ORDERED → SCHEDULED → IN_PROGRESS → COMPLETED → REPORTED → VALIDATED
/// Branch: any cancellable status (ORDERED/SCHEDULED/IN_PROGRESS) → CANCELLED.
enum ImagingOrderStatus {
  ORDERED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  REPORTED
  VALIDATED
  CANCELLED

  @@schema("public")
}

enum ImagingPriority {
  STAT /// Emergency: SLA 60 min
  URGENT /// Urgent: SLA 240 min
  ROUTINE /// Routine: SLA 1440 min

  @@schema("public")
}

/// TDR §18.1 — modalidad/equipo de imagen físico (RIS/DICOM).
model ImagingModality {
  id              String              @id @default(uuid()) @db.Uuid
  establishmentId String              @db.Uuid
  code            String              @db.VarChar(40)
  name            String              @db.VarChar(120)
  modalityType    ImagingModalityType
  /// DICOM standard modality code (2-4 chars, e.g. "CT", "MR"). Must match DicomModality enum.
  dicomCode       DicomModality?
  aeTitle         String?             @db.VarChar(40) /// DICOM AE Title.
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now()) @db.Timestamptz()
  updatedAt       DateTime            @updatedAt @db.Timestamptz()

  establishment Establishment  @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  orders        ImagingOrder[]

  @@unique([establishmentId, code])
  @@index([establishmentId])
  @@index([modalityType])
  @@schema("public")
}

/// TDR §18.2 — orden de estudio de imagen.
model ImagingOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  organizationId     String              @db.Uuid
  establishmentId    String              @db.Uuid
  encounterId        String              @db.Uuid
  patientId          String              @db.Uuid
  modalityId         String?             @db.Uuid
  orderingProviderId String              @db.Uuid /// User.
  modalityType       ImagingModalityType
  studyDescription   String              @db.VarChar(400)
  bodySite           String?             @db.VarChar(120)
  clinicalIndication String              @db.Text
  priority           ImagingPriority     @default(ROUTINE)
  status             ImagingOrderStatus  @default(ORDERED)
  orderedAt          DateTime            @default(now()) @db.Timestamptz() /// Base timestamp for SLA calculation.
  scheduledAt        DateTime?           @db.Timestamptz()
  completedAt        DateTime?           @db.Timestamptz() /// Set on COMPLETED transition.
  accessionNumber    String?             @db.VarChar(80) /// DICOM accession.
  /// Radiation dose — DAP in cGy·cm². Only for CT/XA/MG modalities.
  radiationDoseDap   Decimal?            @db.Decimal(10, 4)
  /// Radiation dose — CTDIvol in mGy. Only for CT/XA/MG modalities.
  radiationDoseCtdi  Decimal?            @db.Decimal(10, 4)
  notes              String?             @db.Text
  /// Centro solicitante (productivo o intermedio). FK RESTRICT.
  costCenterId          String?             @db.Uuid
  /// Centro intermedio ejecutor (depende de modalidad). FK RESTRICT.
  ejecutorCostCenterId  String?             @db.Uuid
  createdAt          DateTime            @default(now()) @db.Timestamptz()
  createdBy          String?             @db.Uuid
  updatedAt          DateTime            @updatedAt @db.Timestamptz()
  updatedBy          String?             @db.Uuid
  deletedAt          DateTime?           @db.Timestamptz()

  organization          Organization     @relation("OrgImagingOrders", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment         Establishment    @relation("EstImagingOrders", fields: [establishmentId], references: [id], onDelete: Restrict)
  encounter             Encounter        @relation("EncImagingOrders", fields: [encounterId], references: [id], onDelete: Restrict)
  patient               Patient          @relation("PatImagingOrders", fields: [patientId], references: [id], onDelete: Restrict)
  modality              ImagingModality? @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  orderingProvider      User             @relation("ImagingOrderingProvider", fields: [orderingProviderId], references: [id], onDelete: Restrict)
  costCenter            CostCenter?      @relation("ImagingOrderCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)
  ejecutorCostCenter    CostCenter?      @relation("ImagingOrderEjecutorCostCenter", fields: [ejecutorCostCenterId], references: [id], onDelete: Restrict)

  report ImagingReport?

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@index([orderingProviderId])
  @@index([modalityId])
  @@index([modalityType])
  @@index([establishmentId])
  @@index([orderedAt]) /// SLA/overdue queries.
  @@index([costCenterId])
  @@index([ejecutorCostCenterId])
  @@schema("public")
}

/// TDR §18.3 — reporte radiológico de una orden de imagen.
/// Immutability: DB trigger blocks UPDATE/DELETE when validatedAt IS NOT NULL.
model ImagingReport {
  id             String    @id @default(uuid()) @db.Uuid
  orderId        String    @unique @db.Uuid
  radiologistId  String    @db.Uuid /// User.
  findings       String    @db.Text
  impression     String    @db.Text
  recommendation String?   @db.Text
  reportedAt     DateTime  @default(now()) @db.Timestamptz()
  signedAt       DateTime? @db.Timestamptz()
  validatedAt    DateTime? @db.Timestamptz() /// When set, report is immutable (enforced by DB trigger).
  amendedAt      DateTime? @db.Timestamptz()
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  order       ImagingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  radiologist User         @relation("ImagingRadiologist", fields: [radiologistId], references: [id], onDelete: Restrict)

  @@index([radiologistId])
  @@schema("public")
}

// =============================================================================
// §25 Insurer Agreements — Convenios de aseguradoras (Wave 8 / Phase 2 entry)
// =============================================================================

enum InsurerKind {
  PUBLIC /// ISSS, Bienestar Magisterial, Fosalud.
  PRIVATE /// SISA, Pan-American Life, etc.
  SELF_INSURED /// auto-asegurado / empresa.

  @@schema("public")
}

enum AuthorizationStatus {
  PENDING /// b14: canonical start state for new records.
  REQUESTED /// legacy treated as PENDING in state machine; kept for backward compat.
  APPROVED
  PARTIAL
  DENIED
  EXPIRED
  CANCELLED

  @@schema("public")
}

/// TDR §25.1 — aseguradora (carrier). Catálogo global (organizationId null)
/// o tenant-específico para convenios cerrados.
model Insurer {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String?     @db.Uuid /// null = catálogo global.
  code           String      @db.VarChar(40)
  name           String      @db.VarChar(200)
  taxId          String?     @db.VarChar(40)
  kind           InsurerKind @default(PRIVATE)
  contactPhone   String?     @db.VarChar(40)
  contactEmail   String?     @db.VarChar(200)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now()) @db.Timestamptz()
  createdBy      String?     @db.Uuid
  updatedAt      DateTime    @updatedAt @db.Timestamptz()
  updatedBy      String?     @db.Uuid

  organization    Organization?   @relation("OrgInsurers", fields: [organizationId], references: [id], onDelete: Restrict)
  plans           InsurancePlan[]
  // Finance — sql/127
  invoices        Invoice[]       @relation("InvoiceInsurer")
  insuranceClaims InsuranceClaim[] @relation("ClaimInsurer")

  @@unique([organizationId, code])
  @@index([active])
  @@schema("public")
}

/// TDR §25.2 — plan/producto comercial de una aseguradora.
model InsurancePlan {
  id                String   @id @default(uuid()) @db.Uuid
  insurerId         String   @db.Uuid
  code              String   @db.VarChar(40)
  name              String   @db.VarChar(200)
  description       String?  @db.VarChar(400)
  copayPct          Decimal? @db.Decimal(5, 2) /// % a cargo del paciente.
  coveredProcedures Json? /// b14: JSONB [{"code": "MRI", "maxCoverage": 1500.00}] estructura.
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz()
  updatedAt         DateTime @updatedAt @db.Timestamptz()

  insurer   Insurer           @relation(fields: [insurerId], references: [id], onDelete: Restrict)
  coverages PatientCoverage[]

  @@unique([insurerId, code])
  @@index([insurerId])
  @@schema("public")
}

/// TDR §25.3 — vinculación paciente↔plan (póliza vigente).
model PatientCoverage {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  patientId      String    @db.Uuid
  planId         String    @db.Uuid
  policyNumber   String    @db.VarChar(80)
  validFrom      DateTime  @db.Timestamptz()
  validTo        DateTime? @db.Timestamptz()
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  createdBy      String?   @db.Uuid
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  updatedBy      String?   @db.Uuid

  organization   Organization           @relation("OrgPatientCoverages", fields: [organizationId], references: [id], onDelete: Restrict)
  patient        Patient                @relation("PatCoverages", fields: [patientId], references: [id], onDelete: Restrict)
  plan           InsurancePlan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  authorizations AuthorizationRequest[]

  @@unique([organizationId, patientId, policyNumber])
  @@index([organizationId, patientId])
  @@index([planId])
  @@index([active])
  @@schema("public")
}

/// TDR §25.4 — solicitud de autorización de servicio ante la aseguradora.
model AuthorizationRequest {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  coverageId     String              @db.Uuid
  encounterId    String?             @db.Uuid
  serviceCode    String              @db.VarChar(40)
  serviceDesc    String              @db.VarChar(400)
  requestedAt    DateTime            @default(now()) @db.Timestamptz()
  requestedById  String?             @db.Uuid /// User.
  status         AuthorizationStatus @default(REQUESTED)
  externalRef    String?             @db.VarChar(80) /// número de la aseguradora.
  approvedAmount Decimal?            @db.Decimal(18, 2)
  denialReason   String?             @db.VarChar(400)
  validFrom      DateTime?           @db.Timestamptz()
  validTo        DateTime?           @db.Timestamptz()
  createdAt      DateTime            @default(now()) @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @db.Timestamptz()

  organization Organization    @relation("OrgAuthRequests", fields: [organizationId], references: [id], onDelete: Restrict)
  coverage     PatientCoverage @relation(fields: [coverageId], references: [id], onDelete: Restrict)
  encounter    Encounter?      @relation("EncAuthRequests", fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([coverageId])
  @@index([encounterId])
  @@index([requestedAt])
  @@schema("public")
}

// =============================================================================
// §19 Inventory — Stock multi-bodega con lotes FEFO (Wave 8 / Phase 2 entry)
// =============================================================================

enum StockMovementType {
  IN /// ingreso (compra, donación, devolución a bodega).
  OUT /// salida (consumo, despacho).
  TRANSFER /// traslado entre bodegas.
  ADJUST /// ajuste de inventario (conteo físico).

  @@schema("public")
}

/// TDR §19.1 — item inventariable. Catálogo global (organizationId null) o tenant.
model StockItem {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid /// null = catálogo global.
  sku            String   @db.VarChar(60)
  name           String   @db.VarChar(200)
  description    String?  @db.VarChar(400)
  unitOfMeasure  String   @db.VarChar(20) /// UN, ML, MG, BOX, etc.
  category       String?  @db.VarChar(80) /// "MEDICAMENTO", "INSUMO", "REACTIVO", etc.
  trackLots      Boolean  @default(true) /// si requiere control de lote+expiry.
  reorderLevel   Decimal? @db.Decimal(18, 4)
  /// GTIN-14 del artículo (FK a ece.gs1_gtin.codigo, SQL 170). Enlace Nivel 3→Nivel 2 GS1.
  gtin           String?  @db.Char(14)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdBy      String?  @db.Uuid
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedBy      String?  @db.Uuid

  organization Organization?   @relation("OrgStockItems", fields: [organizationId], references: [id], onDelete: Restrict)
  lots         StockLot[]
  movements    StockMovement[]

  @@unique([organizationId, sku])
  @@index([active])
  @@schema("public")
}

/// TDR §19.2 — lote de un item (control FEFO: First Expired First Out).
model StockLot {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  establishmentId String    @db.Uuid /// bodega física.
  itemId          String    @db.Uuid
  lotNumber       String    @db.VarChar(80)
  /// GTIN-14 físico escaneado del empaque (AI 01). Captura cruda GS1 DataMatrix, SQL 170.
  gtinFisico      String?   @map("gtin_fisico") @db.Char(14)
  expiryDate      DateTime? @db.Date
  /// Estado de calidad logístico-clínico (guía GS1 El Salvador Nivel 3), SQL 171.
  /// AVAILABLE | QUARANTINE | RECALL | EXPIRED — bloquea salida si <> AVAILABLE.
  qualityStatus   String    @default("AVAILABLE") @map("quality_status")
  quantityOnHand  Decimal   @default(0) @db.Decimal(18, 4)
  reservedQty     Decimal   @default(0) @db.Decimal(18, 4) /// cantidad reservada (no disponible para OUT).
  costPerUnit     Decimal?  @db.Decimal(18, 4)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdBy       String?   @db.Uuid
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  organization  Organization    @relation("OrgStockLots", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment   @relation("EstStockLots", fields: [establishmentId], references: [id], onDelete: Restrict)
  item          StockItem       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  movements     StockMovement[]

  @@unique([organizationId, establishmentId, itemId, lotNumber])
  @@index([organizationId, expiryDate])
  @@index([itemId])
  @@index([establishmentId])
  @@schema("public")
}

/// TDR §19.3 — movimiento de inventario (auditoría inmutable).
model StockMovement {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @db.Uuid
  establishmentId String            @db.Uuid
  itemId          String            @db.Uuid
  lotId           String?           @db.Uuid
  type            StockMovementType
  quantity        Decimal           @db.Decimal(18, 4) /// positivo siempre; el signo lo da `type`.
  reason          String?           @db.VarChar(200)
  referenceCode   String?           @db.VarChar(80) /// nro factura, dispense, ajuste, etc.
  /// GTIN-14 físico escaneado en el movimiento (AI 01), SQL 170.
  gtinFisico      String?           @map("gtin_fisico") @db.Char(14)
  transferGroupId String?           @db.Uuid /// par OUT+IN del mismo TRANSFER (atomicidad).
  performedAt     DateTime          @default(now()) @db.Timestamptz()
  performedById   String?           @db.Uuid
  createdAt       DateTime          @default(now()) @db.Timestamptz()

  organization  Organization  @relation("OrgStockMovements", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment @relation("EstStockMovements", fields: [establishmentId], references: [id], onDelete: Restrict)
  item          StockItem     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot           StockLot?     @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([organizationId, performedAt])
  @@index([itemId])
  @@index([lotId])
  @@index([transferGroupId])
  @@index([type])
  @@schema("public")
}

// =============================================================================
// §20 Services & Equipment — Equipos biomédicos + PM + calibración (Wave 8)
// =============================================================================

enum EquipmentStatus {
  OPERATIONAL
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
  BROKEN

  @@schema("public")
}

enum CriticalityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("public")
}

enum PmScheduleStatus {
  PLANNED
  COMPLETED
  OVERDUE
  CANCELLED

  @@schema("public")
}

/// TDR §20.1 — equipo biomédico inventariado (activo fijo trazable).
model BiomedicalEquipment {
  id                     String           @id @default(uuid()) @db.Uuid
  organizationId         String           @db.Uuid
  establishmentId        String           @db.Uuid
  assetTag               String           @db.VarChar(60) /// código interno (etiqueta).
  name                   String           @db.VarChar(200)
  manufacturer           String?          @db.VarChar(120)
  model                  String?          @db.VarChar(120)
  serialNumber           String?          @db.VarChar(120)
  category               String?          @db.VarChar(80) /// "VENTILADOR", "MONITOR", etc.
  location               String?          @db.VarChar(120) /// sala/área dentro del establecimiento.
  installDate            DateTime?        @db.Date
  status                 EquipmentStatus  @default(OPERATIONAL)
  criticality            CriticalityLevel @default(MEDIUM)
  certificationExpiresAt DateTime?        @db.Timestamptz() /// vencimiento de certificación regulatoria.
  maintenanceReason      String?          @db.VarChar(500) /// obligatorio cuando criticality=CRITICAL y status=UNDER_MAINTENANCE.
  active                 Boolean          @default(true)
  createdAt              DateTime         @default(now()) @db.Timestamptz()
  createdBy              String?          @db.Uuid
  updatedAt              DateTime         @updatedAt @db.Timestamptz()

  organization    Organization     @relation("OrgEquipment", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment   Establishment    @relation("EstEquipment", fields: [establishmentId], references: [id], onDelete: Restrict)
  pmSchedules     PmSchedule[]
  calibrationLogs CalibrationLog[]

  @@unique([organizationId, assetTag])
  @@index([organizationId, status])
  @@index([establishmentId])
  @@index([organizationId, certificationExpiresAt])
  @@schema("public")
}

/// TDR §20.2 — calendario de mantenimiento preventivo por equipo.
model PmSchedule {
  id          String           @id @default(uuid()) @db.Uuid
  equipmentId String           @db.Uuid
  scheduledAt DateTime         @db.Timestamptz()
  performedAt DateTime?        @db.Timestamptz()
  performedBy String?          @db.Uuid /// User.
  status      PmScheduleStatus @default(PLANNED)
  taskNotes   String?          @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @db.Timestamptz()

  equipment BiomedicalEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, scheduledAt])
  @@index([status])
  @@schema("public")
}

/// TDR §20.3 — bitácora de calibración (cumplimiento metrológico).
model CalibrationLog {
  id             String    @id @default(uuid()) @db.Uuid
  equipmentId    String    @db.Uuid
  calibratedAt   DateTime  @db.Timestamptz()
  calibratedBy   String?   @db.Uuid /// User (o externo si null).
  externalAgency String?   @db.VarChar(200)
  certificateRef String?   @db.VarChar(80)
  result         String    @db.VarChar(40) /// "PASS", "FAIL", "CONDITIONAL".
  nextDueAt      DateTime? @db.Timestamptz()
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @db.Timestamptz()

  equipment BiomedicalEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, calibratedAt])
  @@schema("public")
}

// =============================================================================
// §21 Respiratory — Órdenes respiratorias + ventilador + gases (Wave 8)
// =============================================================================

enum RespiratoryOrderType {
  OXYGEN_THERAPY
  MECHANICAL_VENT
  NEBULIZATION
  AEROSOL
  CPAP_BIPAP
  CHEST_PHYSIO

  @@schema("public")
}

enum RespiratoryOrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD

  @@schema("public")
}

enum VentilatorMode {
  AC /// Assist-Control.
  SIMV /// Synchronized Intermittent Mandatory Ventilation.
  PSV /// Pressure Support.
  CPAP
  BIPAP
  PRVC /// Pressure-Regulated Volume Control.
  OTHER

  @@schema("public")
}

enum MedicalGasType {
  O2 /// oxígeno.
  AIR
  N2O /// óxido nitroso.
  CO2
  HELIOX

  @@schema("public")
}

/// Beta.12 §21 — state machine de destete del ventilador mecánico.
/// Transiciones válidas:
///   ACTIVE  → WEANING → EXTUBATED
///   WEANING → ESCALATED → ACTIVE  (deterioro; retorna a ventilación completa)
///   WEANING → FAILED_EXTUBATION   (intento de extubación fallido)
enum VentilatorSessionStatus {
  ACTIVE
  WEANING
  EXTUBATED
  ESCALATED
  FAILED_EXTUBATION

  @@schema("public")
}

/// TDR §21.1 — orden respiratoria emitida por médico.
/// Beta.12: expiresAt = startedAt + 24 h por defecto; renewedAt registra última renovación.
model RespiratoryOrder {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @db.Uuid
  encounterId    String                 @db.Uuid
  patientId      String                 @db.Uuid
  prescriberId   String                 @db.Uuid
  type           RespiratoryOrderType
  status         RespiratoryOrderStatus @default(ACTIVE)
  flowRate       Decimal?               @db.Decimal(8, 2) /// L/min para O2.
  fio2           Decimal?               @db.Decimal(5, 2) /// fracción inspirada de O2 0–100.
  notes          String?                @db.Text
  startedAt      DateTime               @default(now()) @db.Timestamptz()
  expiresAt      DateTime?              @db.Timestamptz() /// Beta.12: expiración (startedAt+24h); NULL = sin límite explícito.
  endedAt        DateTime?              @db.Timestamptz()
  renewedAt      DateTime?              @db.Timestamptz() /// Beta.12: timestamp de la última renovación; NULL = nunca renovada.
  createdAt      DateTime               @default(now()) @db.Timestamptz()
  createdBy      String?                @db.Uuid
  updatedAt      DateTime               @updatedAt @db.Timestamptz()
  updatedBy      String?                @db.Uuid

  organization       Organization        @relation("OrgRespiratoryOrders", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter          Encounter           @relation("EncRespiratoryOrders", fields: [encounterId], references: [id], onDelete: Restrict)
  patient            Patient             @relation("PatRespiratoryOrders", fields: [patientId], references: [id], onDelete: Restrict)
  prescriber         User                @relation("RespiratoryPrescriber", fields: [prescriberId], references: [id], onDelete: Restrict)
  ventilatorSessions VentilatorSession[]
  gasUsages          MedicalGasUsage[]

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@index([expiresAt]) /// Beta.12: soporte para getExpiredOrders.
  @@schema("public")
}

/// TDR §21.2 — sesión de ventilación mecánica vinculada a una orden.
/// Beta.12: statusSM (state machine destete), patientWeightKg (Vt/kg), outOfRangeSince, alertFiredAt.
model VentilatorSession {
  id              String                  @id @default(uuid()) @db.Uuid
  orderId         String                  @db.Uuid
  mode            VentilatorMode
  statusSM        VentilatorSessionStatus @default(ACTIVE) /// Beta.12: estado en la state machine de destete.
  startedAt       DateTime                @default(now()) @db.Timestamptz()
  endedAt         DateTime?               @db.Timestamptz()
  tidalVolume     Decimal?                @db.Decimal(8, 2) /// mL; rango seguro 4–12 mL/kg.
  rrSet           Int? /// resp/min programadas; rango seguro 8–30.
  peep            Decimal?                @db.Decimal(6, 2) /// cmH2O; rango seguro 5–20.
  fio2            Decimal?                @db.Decimal(4, 3) /// fracción 0.21–1.0.
  patientWeightKg Decimal?                @db.Decimal(6, 2) /// Beta.12: peso para derivar Vt/kg.
  outOfRangeSince DateTime?               @db.Timestamptz() /// Beta.12: inicio del intervalo con parámetros fuera de rango.
  alertFiredAt    DateTime?               @db.Timestamptz() /// Beta.12: momento en que se disparó la alerta crítica (>5 min fuera de rango).
  notes           String?                 @db.Text
  createdAt       DateTime                @default(now()) @db.Timestamptz()
  updatedAt       DateTime                @updatedAt @db.Timestamptz()

  order RespiratoryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, startedAt])
  @@index([statusSM]) /// Beta.12: queries de destete por estado.
  @@schema("public")
}

/// TDR §21.3 — consumo de gas médico (auditoría + costo).
model MedicalGasUsage {
  id           String         @id @default(uuid()) @db.Uuid
  orderId      String         @db.Uuid
  gasType      MedicalGasType
  volumeLiters Decimal        @db.Decimal(12, 2)
  measuredAt   DateTime       @default(now()) @db.Timestamptz()
  recordedById String?        @db.Uuid
  notes        String?        @db.VarChar(400)
  createdAt    DateTime       @default(now()) @db.Timestamptz()

  order RespiratoryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, measuredAt])
  @@index([gasType])
  @@schema("public")
}

// =============================================================================
// §22 Nutrition — Dietas + valoración + ordenes enteral/parenteral (Wave 8)
// =============================================================================

enum DietType {
  REGULAR
  SOFT
  LIQUID_CLEAR
  LIQUID_FULL
  DIABETIC
  LOW_SODIUM
  RENAL
  HYPOPROTEIC
  HYPERPROTEIC
  HYPOCALORIC
  HIPERCALORIC
  ENTERAL_ONLY
  NPO /// nada por boca.
  OTHER

  @@schema("public")
}

enum DietPlanStatus {
  ACTIVE
  DISCONTINUED
  COMPLETED

  @@schema("public")
}

enum NutritionOrderRoute {
  ENTERAL
  PARENTERAL

  @@schema("public")
}

enum NutritionOrderStatus {
  /// Orden recibida, pendiente de inicio.
  ORDERED
  ACTIVE
  COMPLETED
  /// Suspendida temporalmente, puede reactivarse.
  HELD
  CANCELLED

  @@schema("public")
}

/// TDR §22.1 — plan dietético asignado durante un encuentro.
model DietPlan {
  id                      String         @id @default(uuid()) @db.Uuid
  organizationId          String         @db.Uuid
  encounterId             String         @db.Uuid
  patientId               String         @db.Uuid
  dietType                DietType
  status                  DietPlanStatus @default(ACTIVE)
  caloriesTarget          Int? /// kcal/día.
  proteinTarget           Decimal?       @db.Decimal(8, 2) /// g/día.
  /// Lista de códigos de diagnóstico (CIE-10/SNOMED) compatibles con este plan.
  /// Usado por validateDietCompatibility() para validar NutritionOrder.dietPlanId.
  compatibleWithDiagnoses String[]       @default([])
  /// Alergenos declarados en el plan (e.g. ["NUTS", "DAIRY", "GLUTEN"]).
  /// Comparados contra PatientAllergy.substanceText (uppercase) en order.create. UAT-BUG-02.
  allergens               String[]       @default([])
  notes                   String?        @db.Text
  startedAt               DateTime       @default(now()) @db.Timestamptz()
  endedAt                 DateTime?      @db.Timestamptz()
  createdAt               DateTime       @default(now()) @db.Timestamptz()
  createdBy               String?        @db.Uuid
  updatedAt               DateTime       @updatedAt @db.Timestamptz()

  organization    Organization     @relation("OrgDietPlans", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter       Encounter        @relation("EncDietPlans", fields: [encounterId], references: [id], onDelete: Restrict)
  patient         Patient          @relation("PatDietPlans", fields: [patientId], references: [id], onDelete: Restrict)
  nutritionOrders NutritionOrder[]

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@schema("public")
}

/// TDR §22.2 — valoración nutricional (Mini Nutritional Assessment u otra).
/// Append-only post-firma (signedAt NOT NULL): trigger fn_nutrition_assessment_immutability
/// impide UPDATE/DELETE una vez firmada.
model NutritionAssessment {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid
  encounterId      String    @db.Uuid
  patientId        String    @db.Uuid
  assessedAt       DateTime  @default(now()) @db.Timestamptz()
  assessedById     String    @db.Uuid /// User (nutricionista/médico).
  weightKg         Decimal?  @db.Decimal(6, 2)
  heightCm         Decimal?  @db.Decimal(6, 2)
  bmi              Decimal?  @db.Decimal(5, 2)
  malnutritionRisk String?   @db.VarChar(40) /// "LOW", "MODERATE", "HIGH".
  /// Objetivo calórico diario expresado en kcal/día (600–4000 médicamente plausible).
  targetCalories   Int?
  notes            String?   @db.Text
  /// Timestamp de firma clínica. Una vez establecido, el registro es inmutable.
  signedAt         DateTime? @db.Timestamptz()
  createdAt        DateTime  @default(now()) @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @db.Timestamptz()

  organization Organization @relation("OrgNutritionAssessments", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter    Encounter    @relation("EncNutritionAssessments", fields: [encounterId], references: [id], onDelete: Restrict)
  patient      Patient      @relation("PatNutritionAssessments", fields: [patientId], references: [id], onDelete: Restrict)

  @@index([organizationId, assessedAt])
  @@index([encounterId])
  @@index([patientId])
  @@schema("public")
}

/// TDR §22.3 — orden de nutrición enteral o parenteral.
/// State machine: ORDERED → ACTIVE → COMPLETED | HELD (reversible a ACTIVE) | CANCELLED.
/// Exclusividad: un encuentro activo no puede tener simultáneamente ENTERAL y PARENTERAL ORDERED/ACTIVE.
model NutritionOrder {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  encounterId    String               @db.Uuid
  patientId      String               @db.Uuid
  prescriberId   String               @db.Uuid
  route          NutritionOrderRoute
  /// Estado inicial al crear: ORDERED. Transitions: ORDERED→ACTIVE, ACTIVE→COMPLETED|HELD|CANCELLED, HELD→ACTIVE|CANCELLED.
  status         NutritionOrderStatus @default(ORDERED)
  formula        String?              @db.VarChar(200) /// nombre comercial / composición.
  ratePerHour    Decimal?             @db.Decimal(8, 2) /// mL/h.
  totalVolume    Decimal?             @db.Decimal(10, 2) /// mL/día.
  caloriesPerDay Int?
  /// Plan dietético asociado. Si especificado, se valida compatibilidad de diagnósticos.
  dietPlanId     String?              @db.Uuid
  notes          String?              @db.Text
  startedAt      DateTime             @default(now()) @db.Timestamptz()
  endedAt        DateTime?            @db.Timestamptz()
  createdAt      DateTime             @default(now()) @db.Timestamptz()
  createdBy      String?              @db.Uuid
  updatedAt      DateTime             @updatedAt @db.Timestamptz()

  organization Organization @relation("OrgNutritionOrders", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter    Encounter    @relation("EncNutritionOrders", fields: [encounterId], references: [id], onDelete: Restrict)
  patient      Patient      @relation("PatNutritionOrders", fields: [patientId], references: [id], onDelete: Restrict)
  prescriber   User         @relation("NutritionPrescriber", fields: [prescriberId], references: [id], onDelete: Restrict)
  dietPlan     DietPlan?    @relation(fields: [dietPlanId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@index([route])
  @@schema("public")
}

// =============================================================================
// Beta.15 — Alerts & Notifications (Outbox + Notification Engine)
// Diseño: docs/blueprints/beta15_notifications.md + docs/adr/0008.
// DBA review: docs/blueprints/beta15_notifications_dba_review.md (aplicado abajo).
// SRE: docs/blueprints/beta15_notifications_sre_review.md (extensiones pg_cron/pg_net
// + cron.schedule() y Resend account pendientes — los habilita @SRE post-merge).
// =============================================================================

/// Canal por el cual se entrega una notificación. Beta.15 cubre INBOX + EMAIL.
/// SMS (Beta.16+) y WHATSAPP (Beta.17+) se añadirán después.
enum NotificationChannel {
  INBOX
  EMAIL

  @@schema("public")
}

/// Severidad clínica/operativa de la notificación. Drives routing + email-vs-inbox-only.
enum NotificationSeverity {
  CRITICAL
  WARNING
  INFO

  @@schema("public")
}

/// Status forward-only: PENDING → SENT → DELIVERED → READ, ó PENDING → FAILED (terminal).
enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED

  @@schema("public")
}

/// Outbox pattern — eventos de dominio emitidos dentro de transacción del router.
/// eventType es VARCHAR (no enum PG) para evolución sin ALTER TYPE; ver ADR 0008.
/// Validado por Zod en `emitDomainEvent` antes del INSERT (catálogo en
/// `@his/contracts/events/catalog.ts`). RLS: tenant-scoped por organizationId.
/// Audit triggers + hash chain aplicados via SQL 43.
model DomainEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @db.Uuid
  eventType      String    @db.VarChar(80)
  aggregateType  String    @db.VarChar(60)
  aggregateId    String    @db.Uuid
  payload        Json
  /// SHA-256 hex; opcional Beta.15. Beta.16 puede enforcear UNIQUE para dedup defensivo.
  payloadHash    String?   @db.VarChar(64)
  occurredAt     DateTime  @default(now()) @db.Timestamptz()
  publishedAt    DateTime? @db.Timestamptz()
  attempts       Int       @default(0)
  /// Bounded a 2000 chars; mensajes largos se truncan en el dispatcher.
  lastError      String?   @db.VarChar(2000)
  /// Beta.15 (SQL 44 poller) — timestamp del último intento de procesamiento.
  /// Usado por el poller para calcular backoff exponencial.
  lastAttemptAt  DateTime? @db.Timestamptz()
  /// Beta.15 (SQL 44 poller) — request_id devuelto por net.http_post (pg_net)
  /// del último intento. Permite trazabilidad fin-a-fin pg_net → Edge Function.
  lastNetRequestId BigInt?
  emittedById    String?   @db.Uuid

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  emittedBy     User?          @relation("DomainEventEmitter", fields: [emittedById], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([organizationId, eventType])
  @@index([occurredAt])
  /// Soporte queries forenses "qué eventos generó la admisión X".
  @@index([aggregateType, aggregateId])
  @@schema("public")
}

/// Envelope persistente de notificaciones — 1 row por (eventId, recipient, channel).
/// UNIQUE garantiza idempotencia del dispatcher (ON CONFLICT DO NOTHING).
/// Retención: 90 días en status=READ (purge vía pg_cron diario; SQL 42).
/// AuditLog permanente para compliance (hash chain SKIP — write amplification @DBA §S8).
model Notification {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String               @db.Uuid
  eventId           String               @db.Uuid
  recipientUserId   String               @db.Uuid
  channel           NotificationChannel
  severity          NotificationSeverity
  subject           String               @db.VarChar(200)
  body              String               @db.VarChar(5000)
  status            NotificationStatus   @default(PENDING)
  sentAt            DateTime?            @db.Timestamptz()
  deliveredAt       DateTime?            @db.Timestamptz()
  readAt            DateTime?            @db.Timestamptz()
  failedAt          DateTime?            @db.Timestamptz()
  failureReason     String?              @db.VarChar(2000)
  /// Resend message ID típicamente ULID ~26 chars; 120 da margen para otros providers.
  providerMessageId String?              @db.VarChar(120)
  metadata          Json?
  attempts          Int                  @default(0)
  createdAt         DateTime             @default(now()) @db.Timestamptz()
  updatedAt         DateTime             @updatedAt @db.Timestamptz()

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event         DomainEvent  @relation(fields: [eventId], references: [id], onDelete: Restrict)
  recipientUser User         @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)

  @@unique([eventId, recipientUserId, channel])
  @@index([recipientUserId, status, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@schema("public")
}

/// Preferencias por usuario × severity × channel. UPSERT-friendly.
/// CRITICAL+INBOX nunca se deshabilita (validado en dispatcher, no en BD).
/// Si no hay row para una combinación → fallback a RoleNotificationDefault del rol.
model UserNotificationPreference {
  userId    String               @db.Uuid
  severity  NotificationSeverity
  channel   NotificationChannel
  enabled   Boolean              @default(true)
  updatedAt DateTime             @updatedAt @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, severity, channel])
  @@schema("public")
}

/// Defaults por rol × severity × channel. Read-mostly, cambios via seed/migration.
/// Seed inicial cubre Doctor/Nurse/Pharmacist/Admin Org (4 × 3 × 2 = 24 rows).
model RoleNotificationDefault {
  roleId   String               @db.Uuid
  severity NotificationSeverity
  channel  NotificationChannel
  enabled  Boolean

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, severity, channel])
  @@schema("public")
}

// §15 Banco de Sangre / Hemoterapia — Beta.16
// TDR §15: gestión de unidades, compatibilidad, transfusiones, reacciones.
// =============================================================================

/// Grupo sanguíneo ABO.
enum BloodType {
  A
  B
  AB
  O

  @@schema("public")
}

/// Factor Rh.
enum RhFactor {
  POSITIVE
  NEGATIVE

  @@schema("public")
}

/// Componentes hemáticos disponibles.
/// WB=Sangre total, RBC=Glóbulos rojos, PLT=Plaquetas, FFP=PFC, CRYO=Crioprecipitado.
enum BloodComponent {
  WB
  RBC
  PLT
  FFP
  CRYO

  @@schema("public")
}

/// Estado de la unidad en el ciclo de vida.
enum BloodUnitStatus {
  AVAILABLE
  RESERVED
  IN_USE
  TRANSFUSED
  DISCARDED
  EXPIRED

  @@schema("public")
}

/// Urgencia de la solicitud de transfusión.
enum TransfusionUrgency {
  ROUTINE
  URGENT
  EMERGENCY

  @@schema("public")
}

/// Estado de la solicitud de transfusión.
enum TransfusionRequestStatus {
  REQUESTED
  CROSSMATCHING
  APPROVED
  CANCELLED
  FULFILLED

  @@schema("public")
}

/// Resultado de la prueba cruzada.
enum CrossMatchResult {
  COMPATIBLE
  INCOMPATIBLE
  INCONCLUSIVE

  @@schema("public")
}

/// Vía de administración de la transfusión.
enum TransfusionRoute {
  IV_PERIPHERAL
  IV_CENTRAL
  IO

  @@schema("public")
}

/// Estado de la administración de la transfusión.
enum TransfusionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  ABORTED

  @@schema("public")
}

/// Banco de sangre asociado a un establecimiento.
/// Un establecimiento puede operar sin banco (null en FK); si opera con él, solo uno.
model BloodBank {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @db.Uuid
  establishmentId String   @unique @db.Uuid
  name            String   @db.VarChar(200)
  licenseNumber   String?  @db.VarChar(80)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  units         BloodUnit[]

  @@index([organizationId])
  @@schema("public")
}

/// Unidad de sangre / componente hemático en inventario.
/// antigens: JSON tipado {"kell": bool, "duffy_a": bool, "duffy_b": bool, ...}.
/// donorCode: anonimizado — nunca expone PII del donante.
model BloodUnit {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @db.Uuid
  bloodBankId    String          @db.Uuid
  bloodType      BloodType
  rhFactor       RhFactor
  component      BloodComponent
  status         BloodUnitStatus @default(AVAILABLE)
  /// Antígenos extendidos (Kell, Duffy, Kidd…). Conservador: JSONB tipado en TS.
  antigens       Json?
  donorCode      String?         @db.VarChar(40)
  collectionDate DateTime        @db.Date
  expirationDate DateTime        @db.Timestamptz()
  volume         Int?            /// ml
  notes          String?         @db.VarChar(1000)
  discardedAt    DateTime?       @db.Timestamptz()
  discardReason  String?         @db.VarChar(500)
  createdAt      DateTime        @default(now()) @db.Timestamptz()
  updatedAt      DateTime        @updatedAt @db.Timestamptz()

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  bloodBank      BloodBank             @relation(fields: [bloodBankId], references: [id], onDelete: Restrict)
  crossMatches   CrossMatch[]
  transfusions   Transfusion[]

  @@index([organizationId, status])
  @@index([bloodBankId, status])
  @@index([bloodType, rhFactor, status])
  @@schema("public")
}

/// Solicitud médica de transfusión para un paciente/encuentro.
model TransfusionRequest {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String                   @db.Uuid
  encounterId      String                   @db.Uuid
  patientId        String                   @db.Uuid
  requestedById    String                   @db.Uuid
  urgency          TransfusionUrgency       @default(ROUTINE)
  component        BloodComponent
  bloodType        BloodType?
  rhFactor         RhFactor?
  unitsRequested   Int                      @default(1)
  clinicalIndication String                 @db.VarChar(2000)
  status           TransfusionRequestStatus @default(REQUESTED)
  requestedAt      DateTime                 @default(now()) @db.Timestamptz()
  cancelledAt      DateTime?                @db.Timestamptz()
  cancelReason     String?                  @db.VarChar(500)
  createdAt        DateTime                 @default(now()) @db.Timestamptz()
  updatedAt        DateTime                 @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  encounter    Encounter    @relation(fields: [encounterId], references: [id], onDelete: Restrict)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  requestedBy  User         @relation("TransfusionRequestor", fields: [requestedById], references: [id], onDelete: Restrict)
  crossMatches CrossMatch[]
  transfusions Transfusion[]

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@schema("public")
}

/// Prueba cruzada (crossmatch) entre una unidad y una solicitud.
/// método: mayor (plasma paciente + RBC donante), menor, coombs indirecto.
model CrossMatch {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @db.Uuid
  requestId   String           @db.Uuid
  unitId      String           @db.Uuid
  technicianId String          @db.Uuid
  result      CrossMatchResult
  method      String           @db.VarChar(60)
  notes       String?          @db.VarChar(1000)
  performedAt DateTime         @default(now()) @db.Timestamptz()
  createdAt   DateTime         @default(now()) @db.Timestamptz()

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  request      TransfusionRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  unit         BloodUnit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  technician   User               @relation("CrossMatchTechnician", fields: [technicianId], references: [id], onDelete: Restrict)
  transfusion  Transfusion?

  @@index([organizationId])
  @@index([requestId])
  @@index([unitId])
  @@schema("public")
}

/// Administración de la transfusión.
/// adverseReactions: JSON tipado {"type": "...", "severity": "...", "management": "..."}.
/// vitalSigns: JSON tipado {"pre": {...}, "intra": {...}, "post": {...}}.
model Transfusion {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String           @db.Uuid
  requestId        String           @db.Uuid
  unitId           String           @db.Uuid
  encounterId      String           @db.Uuid
  crossMatchId     String           @unique @db.Uuid
  nurseId          String           @db.Uuid
  supervisorId     String           @db.Uuid
  route            TransfusionRoute
  status           TransfusionStatus @default(STARTED)
  startedAt        DateTime          @default(now()) @db.Timestamptz()
  completedAt      DateTime?         @db.Timestamptz()
  vitalSigns       Json?
  adverseReactions Json?
  abortReason      String?           @db.VarChar(500)
  createdAt        DateTime          @default(now()) @db.Timestamptz()
  updatedAt        DateTime          @updatedAt @db.Timestamptz()

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  request      TransfusionRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  unit         BloodUnit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  encounter    Encounter          @relation("TransfusionEncounter", fields: [encounterId], references: [id], onDelete: Restrict)
  crossMatch   CrossMatch         @relation(fields: [crossMatchId], references: [id], onDelete: Restrict)
  nurse        User               @relation("TransfusionNurse", fields: [nurseId], references: [id], onDelete: Restrict)
  supervisor   User               @relation("TransfusionSupervisor", fields: [supervisorId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([requestId])
  @@index([encounterId])
  @@index([unitId])
  @@schema("public")
}

// =============================================================================
// Beta.17 — Patología / Anatomía Patológica (TDR §16)
// State machines:
//   PathologyOrder:   REQUESTED → COLLECTING → IN_PROCESS → REPORTED | CANCELLED
//   PathologySpecimen: RECEIVED → GROSSING → PROCESSED → REPORTED | ARCHIVED | DISCARDED
//   PathologyReport:  DRAFT → PRELIMINARY → FINAL (immutable post-sign) | AMENDED
// ADR 0004: PathologyReport con status=FINAL es inmutable; AMENDED crea nueva fila.
// Hash chain aplicado a PathologyReport (ver SQL 46_pathology_hardening.sql).
// =============================================================================

/// Tipo de estudio anatomopatológico solicitado.
enum PathologyStudyType {
  HISTOPATHOLOGY
  CYTOLOGY
  BIOPSY
  IMMUNOHISTOCHEMISTRY
  AUTOPSY

  @@schema("public")
}

/// Estado de la solicitud de patología.
enum PathologyOrderStatus {
  REQUESTED
  COLLECTING
  IN_PROCESS
  REPORTED
  CANCELLED

  @@schema("public")
}

/// Estado del espécimen recibido en el laboratorio de patología.
enum SpecimenStatus {
  RECEIVED
  GROSSING
  PROCESSED
  REPORTED
  ARCHIVED
  DISCARDED

  @@schema("public")
}

/// Estado del reporte de patología.
/// FINAL → inmutable post-firma (ADR 0004). AMENDED → nueva fila, no update.
enum ReportStatus {
  DRAFT
  PRELIMINARY
  FINAL
  AMENDED

  @@schema("public")
}

/// TDR §16 — Solicitud médica de estudio de patología/anatomía patológica.
/// State machine: REQUESTED → COLLECTING → IN_PROCESS → REPORTED | CANCELLED.
model PathologyOrder {
  id                    String               @id @default(uuid()) @db.Uuid
  organizationId        String               @db.Uuid
  encounterId           String               @db.Uuid
  patientId             String               @db.Uuid
  requestingPhysicianId String               @db.Uuid
  studyType             PathologyStudyType
  clinicalIndication    String?              @db.Text
  suspectedDiagnosis    String?              @db.VarChar(500)
  priority              String               @default("ROUTINE") @db.VarChar(20) /// ROUTINE | URGENT | STAT
  status                PathologyOrderStatus @default(REQUESTED)
  requestedAt           DateTime             @default(now()) @db.Timestamptz()
  createdAt             DateTime             @default(now()) @db.Timestamptz()
  updatedAt             DateTime             @updatedAt @db.Timestamptz()

  organization       Organization        @relation("OrgPathologyOrders", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter          Encounter           @relation("EncPathologyOrders", fields: [encounterId], references: [id], onDelete: Restrict)
  patient            Patient             @relation("PatPathologyOrders", fields: [patientId], references: [id], onDelete: Restrict)
  requestingPhysician User               @relation("PathologyOrderPhysician", fields: [requestingPhysicianId], references: [id], onDelete: Restrict)
  specimens          PathologySpecimen[]
  report             PathologyReport[]

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@index([requestingPhysicianId])
  @@schema("public")
}

/// TDR §16 — Muestra recibida en el laboratorio de patología.
/// Condición de conservación al recibir: formalina, fresco, congelado, otro.
model PathologySpecimen {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @db.Uuid
  anatomicSite      String        @db.VarChar(300) /// Descripción libre del sitio anatómico.
  snomedCode        String?       @db.VarChar(20)  /// Código SNOMED CT opcional.
  collectionMethod  String?       @db.VarChar(100) /// biopsia forceps, escisión, aspirado, etc.
  fixative          String        @default("FORMALIN") @db.VarChar(40) /// FORMALIN | FRESH | FROZEN | OTHER
  blockCount        Int           @default(0)
  slideCount        Int           @default(0)
  receivedAt        DateTime      @default(now()) @db.Timestamptz()
  receivedById      String        @db.Uuid
  status            SpecimenStatus @default(RECEIVED)
  createdAt         DateTime      @default(now()) @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @db.Timestamptz()

  order            PathologyOrder              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  receivedBy       User                        @relation("PathologySpecimenReceiver", fields: [receivedById], references: [id], onDelete: Restrict)
  macroDescription PathologyMacroDescription[]
  microDescription PathologyMicroDescription[]

  @@index([orderId])
  @@schema("public")
}

/// TDR §16 — Descripción macroscópica del espécimen.
model PathologyMacroDescription {
  id           String   @id @default(uuid()) @db.Uuid
  specimenId   String   @db.Uuid
  pathologistId String  @db.Uuid
  description  String   @db.Text
  dimensions   String?  @db.VarChar(100) /// Ej. "3.5 x 2.0 x 1.5 cm"
  weightGrams  Decimal? @db.Decimal(8, 2)
  color        String?  @db.VarChar(100)
  photoUrls    String[] /// Array de URLs a storage de fotos/anexos.
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  specimen    PathologySpecimen @relation(fields: [specimenId], references: [id], onDelete: Restrict)
  pathologist User              @relation("PathologyMacroPathologist", fields: [pathologistId], references: [id], onDelete: Restrict)

  @@index([specimenId])
  @@schema("public")
}

/// TDR §16 — Descripción microscópica del espécimen.
/// stains: array de tinciones usadas (HE, PAS, TRICROMICO, IHQ específicas, etc.).
model PathologyMicroDescription {
  id            String   @id @default(uuid()) @db.Uuid
  specimenId    String   @db.Uuid
  pathologistId String   @db.Uuid
  description   String   @db.Text
  stains        String[] /// ["HE","PAS","IHQ-ER","IHQ-PR"] etc.
  createdAt     DateTime @default(now()) @db.Timestamptz()
  updatedAt     DateTime @updatedAt @db.Timestamptz()

  specimen    PathologySpecimen @relation(fields: [specimenId], references: [id], onDelete: Restrict)
  pathologist User              @relation("PathologyMicroPathologist", fields: [pathologistId], references: [id], onDelete: Restrict)

  @@index([specimenId])
  @@schema("public")
}

/// TDR §16 — Reporte final de patología firmado digitalmente.
/// status=FINAL → inmutable (ADR 0004): NO se hacen UPDATE salvo triggers.
/// AMENDED → nueva fila hija que referencia amendedFromId para trazabilidad.
/// Hash chain: prevHash + signatureHash para inmutabilidad criptográfica (SQL 46).
/// criticalFinding=true dispara evento pathology.criticalFinding al médico solicitante.
model PathologyReport {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  orderId          String       @db.Uuid
  pathologistId    String       @db.Uuid  /// Firmante del reporte.
  primaryDiagnosis String       @db.Text
  secondaryDiagnoses String[]            /// Diagnósticos secundarios en texto libre.
  diagnosisCodes   String[]             /// CIE-O / SNOMED si aplica.
  tnmStaging       String?      @db.VarChar(50)  /// Ej. "pT2N1M0".
  tumorGrade       String?      @db.VarChar(20)  /// G1/G2/G3/GX etc.
  criticalFinding  Boolean      @default(false)  /// Si true → evento pathology.criticalFinding.
  status           ReportStatus @default(DRAFT)
  signedAt         DateTime?    @db.Timestamptz()  /// Seteado al pasar a FINAL.
  amendmentReason  String?      @db.Text           /// Obligatorio en status=AMENDED.
  amendedFromId    String?      @db.Uuid           /// FK al reporte original que se enmendó.
  /// Hash chain (SQL 46) — calculado por trigger BEFORE INSERT.
  prevHash         String?      @db.VarChar(64)
  signatureHash    String?      @db.VarChar(64)
  createdAt        DateTime     @default(now()) @db.Timestamptz()
  updatedAt        DateTime     @updatedAt @db.Timestamptz()

  organization  Organization     @relation("OrgPathologyReports", fields: [organizationId], references: [id], onDelete: Restrict)
  order         PathologyOrder   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  pathologist   User             @relation("PathologyReportPathologist", fields: [pathologistId], references: [id], onDelete: Restrict)
  amendedFrom   PathologyReport? @relation("PathologyAmendment", fields: [amendedFromId], references: [id])
  amendments    PathologyReport[] @relation("PathologyAmendment")

  @@index([organizationId, status])
  @@index([orderId])
  @@schema("public")
}
// =============================================================================
// 23. CONTABILIDAD MULTI-LIBRO  (TDR §23, Wave Beta.18)
//
// Modelo append-only conforme ADR 0007. Sin DTE Hacienda (ADR 0006).
// Ledger ya existe arriba. Aqui se anaden las entidades transaccionales.
// =============================================================================

/// Tipo de cuenta contable. ADR 0007 D3.
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  /// Solo para libro STATISTICAL.
  STATISTICAL

  @@schema("public")
}

/// Estado del periodo fiscal. ADR 0007 D6.
enum PeriodStatus {
  OPEN
  PENDING_CLOSE
  CLOSED
  REOPENED

  @@schema("public")
}

/// Estado del asiento contable. ADR 0007 D2.
enum JournalStatus {
  DRAFT
  POSTED
  REVERSED

  @@schema("public")
}

/// Origen del asiento.
enum JournalOrigin {
  MANUAL
  SISTEMA_FACTURACION
  SISTEMA_NOMINA
  AJUSTE
  CIERRE

  @@schema("public")
}

/// TDR §23 — plan de cuentas jerarquico por libro (ADR 0007 D3).
/// Solo cuentas hoja (isLeaf=true) aceptan JournalLine.
model Account {
  id              String      @id @default(uuid()) @db.Uuid
  organizationId  String      @db.Uuid
  ledgerId        String      @db.Uuid
  code            String      @db.VarChar(40)
  name            String      @db.VarChar(200)
  accountType     AccountType
  isLeaf          Boolean     @default(true)
  allowPosting    Boolean     @default(true)
  parentAccountId String?     @db.Uuid
  level           Int         @default(1)
  currencyId      String      @db.Uuid
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now()) @db.Timestamptz()
  updatedAt       DateTime    @updatedAt @db.Timestamptz()

  organization Organization @relation("AccountOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  ledger       Ledger       @relation("LedgerAccounts", fields: [ledgerId], references: [id], onDelete: Restrict)
  currency     Currency     @relation("AccountCurrency", fields: [currencyId], references: [id], onDelete: Restrict)
  parent       Account?     @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  children     Account[]    @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([ledgerId, code])
  @@index([organizationId, accountType])
  @@index([ledgerId, parentAccountId])
  @@index([organizationId, active])
  @@schema("public")
}

/// TDR §23 — periodo fiscal por libro (ADR 0007 D6).
/// Solo periodos OPEN o REOPENED aceptan nuevos JournalEntry.
model AccountingPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  ledgerId       String       @db.Uuid
  periodYear     Int
  periodMonth    Int
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  status         PeriodStatus @default(OPEN)
  closingNote    String?      @db.VarChar(500)
  closedAt       DateTime?    @db.Timestamptz()
  closedById     String?      @db.Uuid
  createdAt      DateTime     @default(now()) @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @db.Timestamptz()

  organization   Organization   @relation("PeriodOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  ledger         Ledger         @relation("LedgerPeriods", fields: [ledgerId], references: [id], onDelete: Restrict)
  closedBy       User?          @relation("PeriodClosedBy", fields: [closedById], references: [id])
  journalEntries JournalEntry[]

  @@unique([organizationId, ledgerId, periodYear, periodMonth])
  @@index([organizationId, ledgerId, status])
  @@schema("public")
}

/// TDR §23 — cabecera de asiento contable, append-only (ADR 0007 D2).
/// POSTED es immutable. Correccion via contraasiento (reversalOfId).
model JournalEntry {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @db.Uuid
  ledgerId          String        @db.Uuid
  periodId          String        @db.Uuid
  entryDate         DateTime      @db.Date
  numeroCorrelativo Int
  referencia        String?       @db.VarChar(120)
  descripcion       String        @db.VarChar(500)
  origen            JournalOrigin @default(MANUAL)
  status            JournalStatus @default(DRAFT)
  currencyId        String        @db.Uuid
  fxRate            Decimal?      @db.Decimal(18, 8)
  fxRateDate        DateTime?     @db.Date
  documentRef       String?       @db.VarChar(120)
  documentType      String?       @db.VarChar(60)
  postedAt          DateTime?     @db.Timestamptz()
  postedById        String?       @db.Uuid
  createdById       String        @db.Uuid
  reversalOfId      String?       @db.Uuid
  createdAt         DateTime      @default(now()) @db.Timestamptz()
  updatedAt         DateTime      @updatedAt @db.Timestamptz()

  organization Organization     @relation("JournalOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  ledger       Ledger           @relation("LedgerJournals", fields: [ledgerId], references: [id], onDelete: Restrict)
  period       AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  currency     Currency         @relation("JournalCurrency", fields: [currencyId], references: [id], onDelete: Restrict)
  createdBy    User             @relation("JournalCreatedBy", fields: [createdById], references: [id])
  postedBy     User?            @relation("JournalPostedBy", fields: [postedById], references: [id])
  reversalOf   JournalEntry?    @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversedBy   JournalEntry[]   @relation("JournalReversal")
  lines        JournalLine[]

  @@unique([organizationId, ledgerId, periodId, numeroCorrelativo])
  @@index([organizationId, ledgerId, entryDate])
  @@index([organizationId, periodId, status])
  @@index([documentType, documentRef])
  @@schema("public")
}

/// TDR §23 — linea de asiento contable (partida doble).
/// Invariante SQL: debit>=0, credit>=0, NOT(debit>0 AND credit>0).
/// SUM(debit)==SUM(credit) por entry: trigger en 47_accounting_hardening.sql.
model JournalLine {
  id             String    @id @default(uuid()) @db.Uuid
  journalEntryId String    @db.Uuid
  lineNumber     Int
  accountId      String    @db.Uuid
  debit          Decimal   @db.Decimal(18, 2)
  credit         Decimal   @db.Decimal(18, 2)
  descripcion    String?   @db.VarChar(300)
  costCenterId   String?   @db.Uuid
  thirdPartyType String?   @db.VarChar(30)
  thirdPartyId   String?   @db.Uuid
  createdAt      DateTime  @default(now()) @db.Timestamptz()

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])

  @@unique([journalEntryId, lineNumber])
  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
  @@schema("public")
}

/// TDR §23 — centro de costos por organizacion (jerarquico).
/// Extendido en sql/131_cost_centers_spec_v2_41.sql: tipo, permite_imputacion,
/// responsableId, baseDistribucion, centroResponsableMinsal, cuentas default.
/// code cambió a varchar(11) formato T-AAA-SSS (CHECK regex BD).
model CostCenter {
  id                      String                @id @default(uuid()) @db.Uuid
  organizationId          String                @db.Uuid
  code                    String                @db.VarChar(11)
  name                    String                @db.VarChar(120)
  parentId                String?               @db.Uuid
  active                  Boolean               @default(true)
  // sql/131 — extensión spec v2.41
  tipo                    CostCenterType?
  permiteImputacion       Boolean               @default(true) @map("permite_imputacion")
  responsableId           String?               @db.Uuid
  baseDistribucion        CostDistributionBase?
  centroResponsableMinsal String?               @db.VarChar(40)
  cuentaIngresoDefaultId  String?               @db.Uuid
  cuentaGastoDefaultId    String?               @db.Uuid
  createdAt               DateTime              @default(now()) @db.Timestamptz()
  updatedAt               DateTime              @updatedAt @db.Timestamptz()

  organization Organization                    @relation("CostCenterOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  parent       CostCenter?                     @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children     CostCenter[]                    @relation("CostCenterHierarchy")
  responsable  User?                           @relation("CostCenterResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  journalLines JournalLine[]
  // Finance — sql/127 + sql/128
  invoices     Invoice[]                       @relation("InvoiceCostCenter")
  invoiceItems InvoiceItem[]                   @relation("InvoiceItemCostCenter")
  // Wave 10 — módulos clínicos
  encounters          Encounter[]          @relation("EncounterCostCenter")
  inpatientAdmissions InpatientAdmission[] @relation("InpatientAdmissionCostCenter")
  // Prorrateo — sql/131
  allocationRulesAsSource  CostCenterAllocationRule[]   @relation("AllocationRuleSource")
  allocationRulesAsTarget  CostCenterAllocationTarget[] @relation("AllocationRuleTarget")
  // Imaging — Wave 10
  imagingOrdersSolicitante ImagingOrder[]               @relation("ImagingOrderCostCenter")
  imagingOrdersEjecutor    ImagingOrder[]               @relation("ImagingOrderEjecutorCostCenter")
  // LIS — back-relations para LabOrder.costCenterId / LabOrder.ejecutorCostCenterId
  labOrdersSolicitante     LabOrder[]                   @relation("LabOrderSolicitante")
  labOrdersEjecutor        LabOrder[]                   @relation("LabOrderEjecutor")
  // Surgery — Wave 10 (132_cost_center_clinical_modules.sql)
  surgeryCases             SurgeryCase[]                @relation("SurgeryCaseCostCenter")

  @@unique([organizationId, code])
  @@index([organizationId, active])
  @@index([tipo])
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// Beta.20 — Portal del Paciente (E.B20.1)
// RLS en `52_portal_hardening.sql` usa GUC `app.current_portal_account`.
// ─────────────────────────────────────────────────────────────────────────────

enum PortalAccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED

  @@schema("public")
}

enum MagicLinkPurpose {
  LOGIN
  REGISTER
  RECOVERY

  @@schema("public")
}

enum GuardianRelationshipType {
  PARENT
  LEGAL_GUARDIAN
  TUTOR
  OTHER

  @@schema("public")
}

enum GuardianRelationshipStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@schema("public")
}

/// Cuenta del paciente en el Portal del Paciente. 1:1 con Patient.
/// Auth es passwordless vía magic link + TOTP opcional.
/// mfaSecret: cifrado AES-256-GCM (app-layer, legado). Nuevas escrituras usan Vault (SQL 161).
/// mfaSecretVaultId: referencia al secret en vault.secrets (pgsodium XChaCha20).
/// Exactamente uno de los dos debe ser no-null cuando mfaEnabled=true (CHECK en BD).
model PortalAccount {
  id                   String              @id @default(uuid()) @db.Uuid
  patientId            String              @unique @db.Uuid
  email                String              @unique @db.VarChar(254)
  emailVerifiedAt      DateTime?           @db.Timestamptz()
  status               PortalAccountStatus @default(PENDING_VERIFICATION)
  mfaEnabled           Boolean             @default(false)
  /// AES-256-GCM encrypted TOTP secret (legado app-layer). NULL cuando Vault está activo.
  mfaSecret            String?             @db.VarChar(512)
  /// UUID del secret en vault.secrets (pgsodium). NULL cuando app-layer está activo.
  mfaSecretVaultId     String?             @db.Uuid
  lastLoginAt          DateTime?           @db.Timestamptz()
  lastLoginIp          String?             @db.VarChar(45)
  failedLoginAttempts  Int                 @default(0)
  lockedUntil          DateTime?           @db.Timestamptz()
  createdAt            DateTime            @default(now()) @db.Timestamptz()
  updatedAt            DateTime            @updatedAt @db.Timestamptz()

  patient       Patient               @relation(fields: [patientId], references: [id], onDelete: Restrict)
  sessions      PortalSession[]
  magicLinks    PortalMagicLink[]
  guardianships GuardianRelationship[] @relation("GuardianAccount")

  @@schema("public")
}

/// Sesión activa del portal (token = SHA-256 del token real enviado al cliente).
model PortalSession {
  id         String    @id @default(uuid()) @db.Uuid
  accountId  String    @db.Uuid
  /// SHA-256 del bearer token. El token real solo vive en el cliente (httpOnly cookie).
  token      String    @db.Char(64)
  expiresAt  DateTime  @db.Timestamptz()
  ip         String?   @db.VarChar(45)
  userAgent  String?   @db.VarChar(512)
  revokedAt  DateTime? @db.Timestamptz()
  createdAt  DateTime  @default(now()) @db.Timestamptz()

  account PortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([accountId, expiresAt])
  @@schema("public")
}

/// Magic link de un solo uso para login passwordless y verificación de email.
/// Token es SHA-256 del token real enviado al correo.
model PortalMagicLink {
  id         String           @id @default(uuid()) @db.Uuid
  accountId  String           @db.Uuid
  /// SHA-256 del token enviado al correo.
  token      String           @db.Char(64)
  purpose    MagicLinkPurpose
  expiresAt  DateTime         @db.Timestamptz()
  consumedAt DateTime?        @db.Timestamptz()
  createdAt  DateTime         @default(now()) @db.Timestamptz()

  account PortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([accountId, purpose, expiresAt])
  @@schema("public")
}

/// Relación tutor/guardián → paciente menor o dependiente.
/// Permite a un adulto gestionar citas y ver HCE de un paciente dependiente.
model GuardianRelationship {
  id                 String                     @id @default(uuid()) @db.Uuid
  guardianAccountId  String                     @db.Uuid
  wardPatientId      String                     @db.Uuid
  relationship       GuardianRelationshipType
  documentType       String?                    @db.VarChar(20)
  documentNumber     String?                    @db.VarChar(40)
  validFrom          DateTime                   @db.Date
  validUntil         DateTime?                  @db.Date
  status             GuardianRelationshipStatus @default(ACTIVE)
  createdAt          DateTime                   @default(now()) @db.Timestamptz()
  updatedAt          DateTime                   @updatedAt @db.Timestamptz()

  guardianAccount PortalAccount @relation("GuardianAccount", fields: [guardianAccountId], references: [id], onDelete: Restrict)
  wardPatient     Patient       @relation("GuardianWard", fields: [wardPatientId], references: [id], onDelete: Restrict)

  @@unique([guardianAccountId, wardPatientId])
  @@index([guardianAccountId, status])
  @@schema("public")
}

// =============================================================================
// ECE — Expediente Clínico Electrónico (Fase 2)
// Schema: ece (multi-schema preview)
// Normativa: NTEC Acuerdo n.° 1616 MINSAL 2024
// Convención: @@schema("ece") en todos los modelos
// =============================================================================

// -----------------------------------------------------------------------------
// ECE — Catálogos maestros
// -----------------------------------------------------------------------------

/// Instituciones del SNIS (MINSAL, ISSS, ISRI, privado, etc.)
model EceInstitucion {
  id       String  @id @default(uuid()) @db.Uuid
  codigo   String  @unique @db.VarChar(30)
  nombre   String  @db.VarChar(200)
  tipo     String  @db.VarChar(20)
  activo   Boolean @default(true)
  creadoEn DateTime @default(now()) @map("creado_en") @db.Timestamptz()

  establecimientos EceEstablecimiento[]

  @@map("institucion")
  @@schema("ece")
}

/// Establecimiento prestador de servicios de salud con código MINSAL
model EceEstablecimiento {
  id                   String  @id @default(uuid()) @db.Uuid
  institucionId        String  @map("institucion_id") @db.Uuid
  codigo               String  @unique @db.VarChar(30)
  nombre               String  @db.VarChar(200)
  nivelAtencion        String  @map("nivel_atencion") @db.VarChar(20)
  patronNumExpediente  String? @map("patron_num_expediente") @db.VarChar(100)
  activo               Boolean @default(true)
  creadoEn             DateTime @default(now()) @map("creado_en") @db.Timestamptz()

  institucion    EceInstitucion       @relation(fields: [institucionId], references: [id])
  servicios      EceServicio[]
  personalSalud  EcePersonalSalud[]
  pacientes      EcePaciente[]
  episodios      EceEpisodioAtencion[]
  salasQx        EceSalaQx[]
  ordenesIngreso EceOrdenIngreso[]    @relation("OIEstablecimiento")

  @@map("establecimiento")
  @@schema("ece")
}

/// Unidades funcionales del establecimiento (Medicina, Cirugía, UCI, etc.)
model EceServicio {
  id               String  @id @default(uuid()) @db.Uuid
  establecimientoId String  @map("establecimiento_id") @db.Uuid
  codigo           String  @db.VarChar(30)
  nombre           String  @db.VarChar(200)
  categoria        String  @db.VarChar(40)
  activo           Boolean @default(true)

  establecimiento  EceEstablecimiento  @relation(fields: [establecimientoId], references: [id])
  camas            EceCama[]
  asignacionesRol  EceAsignacionRol[]
  episodios        EceEpisodioAtencion[]
  episodiosHosp    EceEpisodioHospitalario[]
  ordenesIngreso   EceOrdenIngreso[]
  hojasIngreso     EceHojaIngreso[]

  @@unique([establecimientoId, codigo])
  @@map("servicio")
  @@schema("ece")
}

/// Recurso físico cama
model EceCama {
  id         String  @id @default(uuid()) @db.Uuid
  servicioId String  @map("servicio_id") @db.Uuid
  codigo     String  @db.VarChar(20)
  estado     String  @default("disponible") @db.VarChar(20)

  servicio         EceServicio        @relation(fields: [servicioId], references: [id])
  asignaciones     EceAsignacionCama[]
  hojasIngreso     EceHojaIngreso[]

  @@unique([servicioId, codigo])
  @@map("cama")
  @@schema("ece")
}

/// Roles funcionales del ECE (ADM, ENF, MC, ESP, DIR...)
model EceRol {
  id          String  @id @default(uuid()) @db.Uuid
  codigo      String  @unique @db.VarChar(20)
  nombre      String  @db.VarChar(100)
  descripcion String?

  asignaciones         EceAsignacionRol[]
  transicionesAutoriza EceFlujoTransicion[]             @relation("RolAutoriza")
  documentoRoles       EceDocumentoRol[]
  historialEjecutor    EceDocumentoInstanciaHistorial[] @relation("RolEjecutor")
  perfilesAcceso       EcePerfilAcceso[]

  @@map("rol")
  @@schema("ece")
}

/// Enumeraciones configurables por institución
model EceCatalogoValor {
  id       String  @id @default(uuid()) @db.Uuid
  dominio  String  @db.VarChar(60)
  codigo   String  @db.VarChar(60)
  etiqueta String  @db.VarChar(200)
  activo   Boolean @default(true)

  @@unique([dominio, codigo])
  @@map("catalogo_valor")
  @@schema("ece")
}

// -----------------------------------------------------------------------------
// ECE — Seguridad y personal
// -----------------------------------------------------------------------------

/// Profesionales de salud vinculados a Supabase Auth (Art. 23 NTEC)
model EcePersonalSalud {
  id                String    @id @default(uuid()) @db.Uuid
  authUserId        String?   @unique @map("auth_user_id") @db.Uuid
  institucionId     String    @map("institucion_id") @db.Uuid
  establecimientoId String    @map("establecimiento_id") @db.Uuid
  documentoIdentidad String   @map("documento_identidad") @db.VarChar(40)
  nombreCompleto    String    @map("nombre_completo") @db.VarChar(200)
  jvpmOJvp          String?   @map("jvpm_o_jvp") @db.VarChar(40)
  profesion         String?   @db.VarChar(100)
  activo            Boolean   @default(true)
  fechaBaja         DateTime? @map("fecha_baja") @db.Timestamptz()
  creadoEn          DateTime  @default(now()) @map("creado_en") @db.Timestamptz()

  establecimiento             EceEstablecimiento             @relation(fields: [establecimientoId], references: [id])
  asignaciones                EceAsignacionRol[]
  firmaElectronica            EceFirmaElectronica?
  documentosCreados           EceDocumentoInstancia[]        @relation("CreadoPor")
  historialEjecutado          EceDocumentoInstanciaHistorial[] @relation("EjecutadoPor")
  bitacoraAccesos             EceBitacoraAcceso[]
  bitacoraAuditorias          EceBitacoraAuditoria[]
  rectificaciones             EceRectificacion[]             @relation("EjecutadaPor")
  supresiones                 EceSupresion[]                 @relation("AutorizadaPor")
  historiasClinicas           EceHistoriaClinica[]           @relation("HCRegistradoPor")
  signosVitales               EceSignosVitales[]             @relation("SVRegistradoPor")
  triajes                     EceTriaje[]                    @relation("TRRegistradoPor")
  atencionesEmergencia        EceAtencionEmergencia[]        @relation("AERegistradoPor")
  indicacionesMedPrescriptor  EceIndicacionesMedicas[]       @relation("IMPrescriptor")
  indicacionesMedTranscriptor EceIndicacionesMedicas[]       @relation("IMTranscriptor")
  registrosEnfermeria         EceRegistroEnfermeria[]        @relation("RERegistradoPor")
  administracionesMed         EceAdministracionMedicamento[] @relation("AMResponsable")
  evolucionesMedicas          EceEvolucionMedica[]           @relation("EMRegistradoPor")
  consentimientosMedico       EceConsentimientoInformado[]   @relation("CIMedicoInforma")
  referenciasRriSolicitado    EceReferenciaRri[]             @relation("RRISolicitadoPor")
  referenciasRriRespondido    EceReferenciaRri[]             @relation("RRIRespondidoPor")
  ordenesIngreso              EceOrdenIngreso[]              @relation("OIMedicoOrdena")
  hojasIngreso                EceHojaIngreso[]               @relation("HIResponsableAdmision")
  actosQuirurgicos            EceActoQuiruurgico[]           @relation("AQCirujano")
  actosQuirAnestesiologo      EceActoQuiruurgico[]           @relation("AQAnestesiologo")
  documentosObstetricos       EceDocumentoObstetrico[]       @relation("DORegistradoPor")
  epicrisesEgreso             EceEpicrisisEgreso[]           @relation("EEMedicoTratante")
  epicrisesVistoJefe          EceEpicrisisEgreso[]           @relation("EEVistoJefe")
  certificadosDefuncion       EceCertificadoDefuncion[]      @relation("CDMedicoCertificante")
  certificadosIncapacidad     EceCertificadoIncapacidad[]    @relation("CIMedicoAutorizado")
  solicitudesEstudio          EceSolicitudEstudio[]          @relation("SEMedicoSolicitante")
  resultadosEstudio           EceResultadoEstudio[]          @relation("RESResponsable")
  pacientesResponsableDatos   EcePaciente[]                  @relation("PacienteResponsableTomaDatos")

  @@index([establecimientoId])
  @@map("personal_salud")
  @@schema("ece")
}

/// N:M personal x rol x servicio
model EceAsignacionRol {
  id         String   @id @default(uuid()) @db.Uuid
  personalId String   @map("personal_id") @db.Uuid
  rolId      String   @map("rol_id") @db.Uuid
  servicioId String?  @map("servicio_id") @db.Uuid
  vigente    Boolean  @default(true)
  asignadoEn DateTime @default(now()) @map("asignado_en") @db.Timestamptz()

  personal EcePersonalSalud @relation(fields: [personalId], references: [id])
  rol      EceRol           @relation(fields: [rolId], references: [id])
  servicio EceServicio?     @relation(fields: [servicioId], references: [id])

  @@unique([personalId, rolId, servicioId])
  @@map("asignacion_rol")
  @@schema("ece")
}

/// Firma electrónica simple — hash de credencial 1:1 con personal (Art. 4.17 NTEC)
model EceFirmaElectronica {
  id             String    @id @default(uuid()) @db.Uuid
  personalId     String    @unique @map("personal_id") @db.Uuid
  // Hash PHC completo argon2id ($argon2id$v=19$m=65536,t=3,p=4$<salt>$<hash>).
  // Nunca PIN plano ni bcrypt — solo argon2id vía capa aplicación.
  pinHash        String    @map("pin_hash")
  // Salt explícito para auditoría de rotación (también embebido en pin_hash PHC).
  saltExtra      String    @map("salt_extra")
  lastRotatedAt  DateTime  @default(now()) @map("last_rotated_at") @db.Timestamptz()
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz()

  personal      EcePersonalSalud                @relation(fields: [personalId], references: [id])
  historial     EceDocumentoInstanciaHistorial[]
  eliminacion1  EceEliminacionSupervisada[]     @relation("EliminacionFirma1")
  eliminacion2  EceEliminacionSupervisada[]     @relation("EliminacionFirma2")

  @@map("firma_electronica")
  @@schema("ece")
}

/// RBAC recurso x permiso x rol (Art. 45, 52 NTEC)
model EcePerfilAcceso {
  id      String @id @default(uuid()) @db.Uuid
  rolId   String @map("rol_id") @db.Uuid
  recurso String @db.VarChar(80)
  permiso String @db.VarChar(20)

  rol EceRol @relation(fields: [rolId], references: [id])

  @@unique([rolId, recurso, permiso])
  @@map("perfil_acceso")
  @@schema("ece")
}

// -----------------------------------------------------------------------------
// ECE — Paciente maestro
// -----------------------------------------------------------------------------

/// Ficha de Identificación (Art. 15 NTEC) — registro MAESTRO del expediente
model EcePaciente {
  id                    String    @id @default(uuid()) @db.Uuid
  establecimientoId     String    @map("establecimiento_id") @db.Uuid
  numeroExpediente      String    @map("numero_expediente") @db.VarChar(50)
  nui                   String?   @db.VarChar(20)
  cun                   String?   @db.VarChar(20)
  dui                   String?   @db.VarChar(10)
  carnetMinoridad       String?   @map("carnet_minoridad") @db.VarChar(20)
  pasaporte             String?   @db.VarChar(30)
  documentoNoPresentado Boolean   @default(false) @map("documento_no_presentado")
  origenIdentidad       String    @default("verificado") @map("origen_identidad") @db.VarChar(30)
  primerNombre          String?   @map("primer_nombre") @db.VarChar(60)
  segundoNombre         String?   @map("segundo_nombre") @db.VarChar(60)
  primerApellido        String?   @map("primer_apellido") @db.VarChar(60)
  segundoApellido       String?   @map("segundo_apellido") @db.VarChar(60)
  fechaNacimiento       DateTime? @map("fecha_nacimiento") @db.Date
  sexo                  String?   @db.VarChar(1)
  estadoFamiliar        String?   @map("estado_familiar") @db.VarChar(30)
  nacionalidad          String?   @db.VarChar(60)
  direccion             String?   @db.VarChar(300)
  telefono              String?   @db.VarChar(20)
  ocupacion             String?   @db.VarChar(100)
  observaciones         String?
  estadoExpediente      String    @default("activo") @map("estado_expediente") @db.VarChar(20)
  fallecido             Boolean   @default(false)
  responsableTomaDatosId String?  @map("responsable_toma_datos") @db.Uuid
  creadoEn              DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  estadoRegistro        String    @default("vigente") @map("estado_registro") @db.VarChar(20)
  expedienteMaestroId   String?   @map("expediente_maestro_id") @db.Uuid

  establecimiento       EceEstablecimiento        @relation(fields: [establecimientoId], references: [id])
  expedienteMaestro     EcePaciente?              @relation("UnificadoCon", fields: [expedienteMaestroId], references: [id])
  expedientesUnificados EcePaciente[]             @relation("UnificadoCon")
  responsableTomaDatos  EcePersonalSalud?         @relation("PacienteResponsableTomaDatos", fields: [responsableTomaDatosId], references: [id])
  identificadores       EceIdentificadorPaciente[]
  responsables          EceResponsablePaciente[]
  afiliacionIsss        EceAfiliacionIsss?
  episodios             EceEpisodioAtencion[]
  documentosInstancia   EceDocumentoInstancia[]
  consentimientos       EceConsentimientoInformado[]
  referenciasRri        EceReferenciaRri[]
  ordenesIngreso        EceOrdenIngreso[]
  documentosObstetricosRN EceDocumentoObstetrico[] @relation("DORecienNacido")
  certificadosIncapacidad EceCertificadoIncapacidad[]

  @@unique([establecimientoId, numeroExpediente])
  @@index([nui])
  @@index([dui])
  @@map("paciente")
  @@schema("ece")
}

/// Identificadores adicionales/históricos del paciente
model EceIdentificadorPaciente {
  id           String   @id @default(uuid()) @db.Uuid
  pacienteId   String   @map("paciente_id") @db.Uuid
  tipo         String   @db.VarChar(20)
  valor        String   @db.VarChar(50)
  vigente      Boolean  @default(true)
  registradoEn DateTime @default(now()) @map("registrado_en") @db.Timestamptz()

  paciente EcePaciente @relation(fields: [pacienteId], references: [id])

  @@map("identificador_paciente")
  @@schema("ece")
}

/// Responsable/familiar del paciente (Art. 15 lit. c NTEC)
model EceResponsablePaciente {
  id         String  @id @default(uuid()) @db.Uuid
  pacienteId String  @map("paciente_id") @db.Uuid
  nombre     String  @db.VarChar(200)
  parentesco String? @db.VarChar(50)
  documento  String? @db.VarChar(40)
  telefono   String? @db.VarChar(20)
  vigente    Boolean @default(true)

  paciente EcePaciente @relation(fields: [pacienteId], references: [id])

  @@map("responsable_paciente")
  @@schema("ece")
}

/// Derechohabiencia ISSS
model EceAfiliacionIsss {
  id                  String    @id @default(uuid()) @db.Uuid
  pacienteId          String    @unique @map("paciente_id") @db.Uuid
  numeroAfiliado      String    @map("numero_afiliado") @db.VarChar(30)
  tipoDerechohabiente String    @map("tipo_derechohabiente") @db.VarChar(20)
  numeroPatronal      String?   @map("numero_patronal") @db.VarChar(20)
  vigente             Boolean   @default(true)
  verificadoEn        DateTime? @map("verificado_en") @db.Timestamptz()

  paciente EcePaciente @relation(fields: [pacienteId], references: [id])

  @@map("afiliacion_isss")
  @@schema("ece")
}

// -----------------------------------------------------------------------------
// ECE — Episodio de atención
