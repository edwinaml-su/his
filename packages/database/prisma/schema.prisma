// =============================================================================
// F2-S7 — GS1 Bedside (Proceso D + E)
// Sprint F2-S7 | GS1 GSRN / GTIN / GLN bedside verification + dispensación.
// Reusa EpcisEvent (definido en schema GS1 logística F2-S6) para trazabilidad.
// TDR §15 (Farmacia) + GS1 EPCIS 2.0 + MINSAL SIGSA reqs.
// =============================================================================

/// Estado de una orden de dispensación farmacéutica.
enum PharmacyOrderStatus {
  PENDING
  DISPENSING
  DISPENSED
  CANCELLED

  @@schema("public")
}

/// Estado del identificador GSRN del personal.
enum StaffGsrnStatus {
  ACTIVE
  REVOKED

  @@schema("public")
}

/// GS1 F2-S7 — Orden de dispensación farmacéutica generada desde una orden médica.
/// Agrega GLN origen/destino para trazabilidad entre puntos de servicio GS1.
/// State machine: PENDING → DISPENSING → DISPENSED | CANCELLED.
/// RLS: organizationId. Audit trigger en 87_pharmacy_substitution.sql.
model PharmacyOrder {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid /// tenant RLS.
  encounterId    String               @db.Uuid
  medicalOrderId String?              @db.Uuid /// PrescriptionItem.id de referencia.
  patientId      String               @db.Uuid
  status         PharmacyOrderStatus  @default(PENDING)
  /// GLN (13 dígitos) del punto de servicio que origina la solicitud (ej. sala).
  glnOrigen      String               @db.VarChar(13)
  /// GLN del punto de servicio que entrega (ej. farmacia central).
  glnDestino     String               @db.VarChar(13)
  dispensedAt    DateTime?            @db.Timestamptz()
  dispensedById  String?              @db.Uuid /// User.id del farmacéutico.
  createdAt      DateTime             @default(now()) @db.Timestamptz()
  createdBy      String?              @db.Uuid
  updatedAt      DateTime             @updatedAt @db.Timestamptz()

  organization  Organization          @relation("OrgPharmacyOrders", fields: [organizationId], references: [id], onDelete: Restrict)
  encounter     Encounter             @relation("EncPharmacyOrders", fields: [encounterId], references: [id], onDelete: Restrict)
  patient       Patient               @relation("PatPharmacyOrders", fields: [patientId], references: [id], onDelete: Restrict)
  dispensedBy   User?                 @relation("PharmacyOrderDispenser", fields: [dispensedById], references: [id], onDelete: SetNull)
  reservations  PharmacyReservation[]
  substitutions PharmacySubstitution[]

  @@index([organizationId, status])
  @@index([encounterId])
  @@index([patientId])
  @@index([glnOrigen])
  @@index([glnDestino])
  @@map("PharmacyOrder")
  @@schema("public")
}

/// GS1 F2-S7 — Sustitución de GTIN autorizada por farmacéutico/médico.
/// Registra la trazabilidad de intercambio terapéutico (bioequivalente) con
/// el GTIN original vs el sustituto y quién autorizó.
/// Audit trigger en 87_pharmacy_substitution.sql (hash chain completo).
model PharmacySubstitution {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  pharmacyOrderId String   @db.Uuid
  /// GTIN-14 del medicamento originalmente prescrito.
  gtinOriginal    String   @db.VarChar(14)
  /// GTIN-14 del medicamento entregado como sustituto.
  gtinSustituto   String   @db.VarChar(14)
  autorizadoPorId String   @db.Uuid /// User.id (farmacéutico o médico).
  autorizadoEn    DateTime @db.Timestamptz()
  /// Razón clínica/administrativa de la sustitución (libre, max 500 chars).
  motivo          String   @db.VarChar(500)
  createdAt       DateTime @default(now()) @db.Timestamptz()

  organization  Organization  @relation("OrgPharmacySubstitutions", fields: [organizationId], references: [id], onDelete: Restrict)
  pharmacyOrder PharmacyOrder @relation(fields: [pharmacyOrderId], references: [id], onDelete: Restrict)
  autorizadoPor User          @relation("PharmacySubstitutionAuthorizer", fields: [autorizadoPorId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([pharmacyOrderId])
  @@index([autorizadoPorId])
  @@map("PharmacySubstitution")
  @@schema("public")
}

/// GS1 F2-S7 — GSRN (18 dígitos) asignado al personal clínico para identificación
/// bedside mediante DataMatrix en credencial física.
/// Unicidad: un GSRN por usuario (relación 1:1 activa; puede haber histórico revocado).
/// RLS: organizationId. Audit trigger en 88_staff_gsrn.sql.
model StaffGsrn {
  id            String        @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId        String        @unique @db.Uuid /// User.id — un GSRN activo por usuario.
  /// GSRN GS1: 18 dígitos numéricos. Único globalmente.
  gsrn          String        @unique @db.VarChar(18)
  /// Contenido del DataMatrix impreso en credencial (base64 o texto estructurado GS1).
  badgeDataMatrix String?     @db.VarChar(500)
  status        StaffGsrnStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @db.Timestamptz()
  revokedAt     DateTime?     @db.Timestamptz()

  organization Organization @relation("OrgStaffGsrn", fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation("UserStaffGsrn", fields: [userId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([gsrn])
  @@map("StaffGsrn")
  @@schema("public")
}

/// GS1 F2-S7 — Catálogo GTIN con metadatos extendidos para alertas bedside.
/// Extiende el catálogo de drogas/medicamentos con campos GS1 de rastreabilidad.
/// GTIN-14 como clave natural única. Reusable desde Drug via gtinRef.
/// NOTA: el catálogo comercial Nivel 2 canónico (guía GS1 El Salvador) es
/// ece.gs1_gtin (EceGs1Gtin). Esta tabla es un caché tenant-scoped para bedside;
/// consolidar ambos en ece.gs1_gtin queda como follow-up.
model MedicationGtin {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @db.Uuid
  /// GTIN-14 (padded con ceros a la izquierda si es GTIN-8/12/13).
  gtin                String   @unique @db.VarChar(14)
  /// Nombre comercial del producto.
  brandName           String   @db.VarChar(200)
  /// Concentración/forma farmacéutica (ej. "500mg comprimido").
  strengthForm        String?  @db.VarChar(200)
  /// Principios activos GS1/RxNorm (array para combinados).
  activeIngredients   String[] @default([])
  /// Excipientes potencialmente alergénicos (GS1 Healthcare alertas).
  excipientesAlergenos String[] @default([])
  /// Estado de recall GS1: NONE | VOLUNTARY | MANDATORY | MARKET_WITHDRAWAL.
  recallStatus        String?  @default("NONE") @db.VarChar(40)
  /// Referencia opcional al Drug.id del HIS para bidi join.
  drugId              String?  @db.Uuid
  createdAt           DateTime @default(now()) @db.Timestamptz()
  updatedAt           DateTime @updatedAt @db.Timestamptz()

  organization Organization @relation("OrgMedicationGtin", fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([gtin])
  @@index([recallStatus]) /// queries de recall activos.
  @@map("MedicationGtin")
  @@schema("public")
}

// =============================================================================
// §GS1 Carrito Unidosis — US.F2.6.12-16
// Farmacéutico arma carrito virtual por turno+paciente y despacha a GLN destino.
// =============================================================================

/// Estado del carrito: avance unidireccional (ARMANDO → LISTO → DESPACHADO → RECIBIDO).
enum PharmacyCartStatus {
  ARMANDO
  LISTO
  DESPACHADO
  RECIBIDO

  @@schema("public")
}

/// Carrito unidosis — agrupa ítems de dispensación por turno y paciente.
model PharmacyCart {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  turno          String              @db.VarChar(20) /// "MAÑANA", "TARDE", "NOCHE"
  patientId      String              @db.Uuid
  glnDestino     String              @db.VarChar(13) /// GLN destino (servicio hospitalización)
  status         PharmacyCartStatus  @default(ARMANDO)
  dispatchedAt   DateTime?           @db.Timestamptz()
  dispatchedById String?             @db.Uuid
  receivedAt     DateTime?           @db.Timestamptz()
  receivedById   String?             @db.Uuid
  signature      String?             @db.VarChar(2000) /// firma electrónica simple recepción
  createdAt      DateTime            @default(now()) @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @db.Timestamptz()

  organization Organization       @relation("OrgPharmacyCarts", fields: [organizationId], references: [id], onDelete: Restrict)
  patient      Patient            @relation("PatientPharmacyCarts", fields: [patientId], references: [id], onDelete: Restrict)
  dispatchedBy User?              @relation("CartDispatchedBy", fields: [dispatchedById], references: [id], onDelete: SetNull)
  receivedBy   User?              @relation("CartReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  items        PharmacyCartItem[]

  @@unique([organizationId, turno, patientId], name: "one_cart_per_turno_patient")
  @@index([organizationId, status])
  @@index([patientId])
  @@schema("public")
}

// =============================================================================
// ECE Staff Schedule — turnos de enfermería (F2-S7 Wave 2)
// Tabla en Supabase: ece.staff_schedule (ya creada vía SQL).
// @@schema("public") porque Prisma multi-schema solo soporta schemas
// declarados en datasource; el schema "ece" está declarado en la config.
// =============================================================================

/// Turno de trabajo del personal de enfermería.
/// Usado por bedside.shiftQueue para filtrar indicaciones del turno activo.
model EceStaffSchedule {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  turno          EceTurno
  fechaInicio    DateTime @db.Timestamptz()
  fechaFin       DateTime @db.Timestamptz()
  servicioId     String?  @db.Uuid
  glnDestino     String?  @map("gln_destino") @db.VarChar(15)
  createdAt      DateTime @default(now()) @db.Timestamptz()

  organization Organization @relation("OrgEceStaffSchedule", fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation("UserEceStaffSchedule", fields: [userId], references: [id], onDelete: Restrict)

  @@index([organizationId, userId, fechaInicio])
  @@index([userId, fechaFin])
  @@map("staff_schedule")
  @@schema("ece")
}

enum EceTurno {
  MANANA
  TARDE
  NOCHE
  GUARDIA_24H

  @@schema("ece")
}

/// Ítem del carrito — enlaza un despacho (MedicationDispense) con el carrito.
model PharmacyCartItem {
  id                 String   @id @default(uuid()) @db.Uuid
  cartId             String   @db.Uuid
  medicationDispenseId String? @db.Uuid /// FK opcional: ítem puede ser manual (scan GTIN)
  gtin               String   @db.VarChar(14)
  lote               String?  @db.VarChar(80)
  serie              String?  @db.VarChar(80)
  posicionCarrito    Int      @default(0) /// orden visual en el carrito
  createdAt          DateTime @default(now()) @db.Timestamptz()

  cart              PharmacyCart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  medicationDispense MedicationDispense? @relation(fields: [medicationDispenseId], references: [id], onDelete: SetNull)

  @@index([cartId])
  @@schema("public")
}

// =============================================================================
// F2-S15 Stream A — Cumplimiento operacional
// §6 Contingencia operativa (US.F2.7.26-28)
// §7 Conservación diferenciada y retención (US.F2.7.29-32)
// =============================================================================

/// Estado de conservación del episodio de atención (US.F2.7.29).
/// ACTIVO: expediente vigente con atenciones recientes.
/// PASIVO: sin atenciones en 5+ años; pasa a cola de evaluación.
/// POR_ELIMINAR: solicitud de eliminación supervisada iniciada.
enum EstadoConservacion {
  ACTIVO
  PASIVO
  POR_ELIMINAR

  @@schema("ece")
}

/// Estado de la solicitud de eliminación supervisada (US.F2.7.31).
enum EstadoEliminacion {
  SOLICITADA
  APROBADA
  RECHAZADA
  EJECUTADA

  @@schema("ece")
}

/// §6 — Registro de períodos de contingencia operativa (US.F2.7.26).
/// Cada fila representa un período en que el sistema estuvo inoperativo
/// y se usaron formularios en papel. Desactivado_en NULL = aún activo.
/// RLS: organizationId. Roles: ADM, DIR (activar/desactivar).
model EceContingenciaEvento {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  motivo            String
  esperadoHasta     DateTime? @map("esperado_hasta") @db.Timestamptz()
  activadoEn        DateTime  @default(now()) @map("activado_en") @db.Timestamptz()
  activadoPorId     String    @map("activado_por_id") @db.Uuid
  desactivadoEn     DateTime? @map("desactivado_en") @db.Timestamptz()
  desactivadoPorId  String?   @map("desactivado_por_id") @db.Uuid

  organization   Organization @relation("OrgContingenciaEventos", fields: [organizationId], references: [id], onDelete: Restrict)
  activadoPor    User         @relation("ContingenciaActivadoPor", fields: [activadoPorId], references: [id], onDelete: Restrict)
  desactivadoPor User?        @relation("ContingenciaDesactivadoPor", fields: [desactivadoPorId], references: [id], onDelete: SetNull)

  @@index([organizationId, desactivadoEn])
  @@map("contingencia_evento")
  @@schema("ece")
}

/// §7 — Catálogo de reglas de retención por patrón CIE-10 (US.F2.7.30).
/// cie10Pattern NULL = regla por defecto.
/// aniosRetencion = 10 para forenses (X*, V*), 5 para base general.
/// RLS: organizationId. Roles: DIR (gestión).
model EceReglaRetencion {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  /// Patrón LIKE sobre código CIE-10 (ej. 'X%', 'V%'). NULL = default.
  cie10Pattern     String?   @map("cie10_pattern") @db.VarChar(20)
  aniosRetencion   Int       @map("anios_retencion")
  motivoLegal      String    @map("motivo_legal")
  vigenteDesde     DateTime  @default(now()) @map("vigente_desde") @db.Date
  vigenteHasta     DateTime? @map("vigente_hasta") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  createdById      String?   @map("created_by_id") @db.Uuid

  organization Organization @relation("OrgReglasRetencion", fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("ReglaRetencionCreador", fields: [createdById], references: [id], onDelete: SetNull)
  eliminaciones EceEliminacionSupervisada[]

  @@index([organizationId, cie10Pattern])
  @@map("regla_retencion")
  @@schema("ece")
}

/// §7 — Solicitud de eliminación supervisada con doble firma (US.F2.7.31).
/// Workflow: SOLICITADA → APROBADA → EJECUTADA | RECHAZADA.
/// NO es borrado físico: marca el episodio como eliminado y preserva metadata.
/// Requiere 2 firmas electrónicas distintas (firma_dir1 + firma_dir2).
/// RLS: organizationId. Roles: DIR (firma), DIR_MEDICO (firma).
model EceEliminacionSupervisada {
  id                       String             @id @default(uuid()) @db.Uuid
  organizationId           String             @map("organization_id") @db.Uuid
  episodioId               String             @map("episodio_id") @db.Uuid
  solicitadoPorId          String             @map("solicitado_por_id") @db.Uuid
  motivoBaja               String             @map("motivo_baja")
  estado                   EstadoEliminacion  @default(SOLICITADA)
  firmaDir1Id              String?            @map("firma_dir1_id") @db.Uuid
  firmaDir2Id              String?            @map("firma_dir2_id") @db.Uuid
  fechaAprobacion          DateTime?          @map("fecha_aprobacion") @db.Timestamptz()
  fechaRechazo             DateTime?          @map("fecha_rechazo") @db.Timestamptz()
  motivoRechazo            String?            @map("motivo_rechazo")
  fechaEjecucion           DateTime?          @map("fecha_ejecucion") @db.Timestamptz()
  /// Metadata preservada permanentemente (inmutable post-ejecución, audit §TDR 6.3).
  pacienteNombre           String?            @map("paciente_nombre") @db.VarChar(200)
  pacienteDui              String?            @map("paciente_dui") @db.VarChar(20)
  reglaRetencionId         String?            @map("regla_retencion_id") @db.Uuid
  fechaVencimientoRetencion DateTime?         @map("fecha_vencimiento_retencion") @db.Timestamptz()
  createdAt                DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  organization    Organization      @relation("OrgEliminaciones", fields: [organizationId], references: [id], onDelete: Restrict)
  episodio        EceEpisodioAtencion @relation("EpisodioEliminaciones", fields: [episodioId], references: [id], onDelete: Restrict)
  solicitadoPor   User              @relation("EliminacionSolicitante", fields: [solicitadoPorId], references: [id], onDelete: Restrict)
  firmaDir1       EceFirmaElectronica? @relation("EliminacionFirma1", fields: [firmaDir1Id], references: [id], onDelete: SetNull)
  firmaDir2       EceFirmaElectronica? @relation("EliminacionFirma2", fields: [firmaDir2Id], references: [id], onDelete: SetNull)
  reglaRetencion  EceReglaRetencion? @relation(fields: [reglaRetencionId], references: [id], onDelete: SetNull)

  @@index([estado])
  @@index([organizationId, estado])
  @@index([episodioId])
  @@map("eliminacion_supervisada")
  @@schema("ece")
}

/// Catálogo CIE-10 OMS en español (versión MINSAL SV 2019).
/// Búsqueda full-text via índice GIN trigramas (pg_trgm) en descripcion.
/// Tabla global (no tenant-scoped) — reutilizable por todos los módulos clínicos.
model Icd10Catalog {
  /// Código CIE-10: 3-7 caracteres (ej. "A00", "J06.9", "O00.0").
  codigo      String   @id @db.VarChar(7)
  descripcion String   @db.Text
  /// Capítulo romano romano (ej. "I", "II", "XIX").
  capitulo    String?  @db.VarChar(5)
  /// Rango de grupo (ej. "A00-A09").
  grupo       String?  @db.VarChar(10)
  /// Notas de exclusión como array de objetos {codigo, nota}.
  exclusiones Json?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  @@map("Icd10Catalog")
  @@schema("public")
}

/// Combinaciones de códigos CIE-10 que el sistema debe alertar como potencialmente inválidas.
/// Restringe por sexo_excluido (null = aplica a ambos) y rango etario.
/// US.F2.7.35 — NTEC Art. 16-17.
model Icd10CombinacinInvalida {
  id              String   @id @default(uuid()) @db.Uuid
  codigoA         String   @db.VarChar(7)
  codigoB         String   @db.VarChar(7)
  motivo          String   @db.Text
  /// null = aplica a ambos sexos. Valores: "masculino" | "femenino"
  sexoExcluido    String?  @db.VarChar(20)
  /// null = sin restricción de edad mínima (en años).
  edadMinExcluida Int?
  /// null = sin restricción de edad máxima (en años, inclusive).
  edadMaxExcluida Int?
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now()) @db.Timestamptz()

  @@unique([codigoA, codigoB], map: "icd10_comb_pair_unique")
  @@index([codigoA])
  @@index([codigoB])
  @@map("icd10_combinacion_invalida")
  @@schema("ece")
}

/// Minuta de reunión del Comité del Expediente Clínico.
/// Inmutable post-firma (trigger trg_comite_inmutable en BD).
/// Hash chain idéntico al patrón de audit_log: prev_hash → payload_hash → chain_hash.
/// US.F2.7.46 — NTEC Art. 32.
model ComiteMinuta {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @db.Uuid
  establecimientoId  String?   @db.Uuid
  fechaReunion       DateTime  @db.Date
  /// [{nombre: string, rol: string, personal_id?: string}]
  asistentes         Json      @default("[]")
  /// [{numero: number, tema: string, descripcion?: string}]
  temasAgenda        Json      @default("[]")
  /// [{numero: number, acuerdo: string, responsable?: string, fecha_limite?: string}]
  acuerdos           Json      @default("[]")
  proximaFecha       DateTime? @db.Date
  firmaPresidenteId  String?   @db.Uuid
  firmadaEn          DateTime? @db.Timestamptz()
  /// "borrador" | "firmada"
  estado             String    @default("borrador") @db.VarChar(20)
  /// SHA-256 del payload JSON (asistentes + temas + acuerdos).
  payloadHash        String?   @db.VarChar(64)
  /// chain_hash de la minuta previa (null si es la primera).
  prevHash           String?   @db.VarChar(64)
  /// SHA-256(prevHash || payloadHash).
  chainHash          String?   @db.VarChar(64)
  registradoPor      String?   @db.Uuid
  registradoEn       DateTime  @default(now()) @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @db.Timestamptz()

  organization Organization @relation("OrgComiteMinutas", fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([fechaReunion(sort: Desc)])
  @@map("comite_minuta")
  @@schema("ece")
}

