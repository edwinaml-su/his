  creadoEn       DateTime @default(now()) @db.Timestamptz()

  organization Organization @relation("OrgExpedienteFormat", fields: [organizationId], references: [id], onDelete: Restrict)
  creadoPor    User?        @relation("ExpedienteFormatCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)

  @@index([organizationId, vigenteDesde(sort: Desc)])
  @@map("ExpedienteFormatConfig")
  @@schema("public")
}

/// Merge de expedientes ECE con doble firma electrónica (US.F2.7.41).
/// Distinto del public.PatientMerge legacy (HIS base); éste documenta el flujo NTEC:
/// PENDIENTE → requiere firmaDir1Id + firmaDir2Id → EJECUTADO (irreversible).
model EcePatientMerge {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @db.Uuid
  canonicalPatientId   String   @db.Uuid /// paciente superviviente.
  mergedPatientId      String   @db.Uuid /// paciente absorbido → mergedIntoId = canonicalPatientId.
  solicitadoPorId      String?  @db.Uuid
  /// Hash PIN del DIR 1 (inmutable — no FK para no perder historia si usuario se elimina).
  firmaDir1Id          String?  @db.VarChar(200)
  /// Hash PIN del Director Médico.
  firmaDir2Id          String?  @db.VarChar(200)
  fechaEjecucion       DateTime? @db.Timestamptz()
  estado               String   @default("PENDIENTE") @db.VarChar(30)
  creadoEn             DateTime @default(now()) @db.Timestamptz()

  organization     Organization @relation("OrgEcePatientMerge", fields: [organizationId], references: [id], onDelete: Restrict)
  canonicalPatient Patient      @relation("EceMergeCanonical", fields: [canonicalPatientId], references: [id], onDelete: Restrict)
  mergedPatient    Patient      @relation("EceMergeMerged", fields: [mergedPatientId], references: [id], onDelete: Restrict)
  solicitadoPor    User?        @relation("EceMergeSolicitante", fields: [solicitadoPorId], references: [id], onDelete: SetNull)

  @@unique([canonicalPatientId, mergedPatientId], name: "uq_ece_merge_pair")
  @@index([organizationId, estado])
  @@index([canonicalPatientId])
  @@map("EcePatientMerge")
  @@schema("public")
}

/// Solicitud ARCO del paciente: Rectificación o Supresión (US.F2.7.44-45).
/// Ciclo: PENDIENTE → APROBADA | RECHAZADA → EJECUTADA.
/// Excepciones de supresión: datos forenses, epidemiológicos, orden judicial (director rechaza con motivo).
model SolicitudArco {
  id               String    @id @default(uuid()) @db.Uuid
  pacienteId       String    @map("paciente_id") @db.Uuid
  organizacionId   String    @map("organizacion_id") @db.Uuid
  tipo             String    @db.VarChar(20) /// RECTIFICACION | SUPRESION
  documentoTarget  String?   @map("documento_target") @db.VarChar(200)
  motivo           String    @db.Text
  estado           String    @default("PENDIENTE") @db.VarChar(20)
  revisadoPorId    String?   @map("revisado_por_id") @db.Uuid
  fechaRespuesta   DateTime? @map("fecha_respuesta") @db.Timestamptz()
  motivoRespuesta  String?   @map("motivo_respuesta") @db.Text
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @default(now()) @updatedAt @map("actualizado_en") @db.Timestamptz()

  paciente    Patient @relation("PatientSolicitudesArco", fields: [pacienteId], references: [id], onDelete: Restrict)
  organizacion Organization @relation("OrgSolicitudesArco", fields: [organizacionId], references: [id], onDelete: Restrict)
  revisadoPor User?   @relation("ArcoRevisor", fields: [revisadoPorId], references: [id], onDelete: SetNull)

  @@index([pacienteId, estado])
  @@index([organizacionId, estado, creadoEn(sort: Desc)])
  @@map("solicitud_arco")
  @@schema("ece")
}

