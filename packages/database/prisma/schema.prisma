/// Factura emitida por episodio o paciente. Soporta facturación electrónica MH (SV).
/// Trigger BD fn_invoice_recalc_payments actualiza paidAmount + status automáticamente.
model Invoice {
  id                          String                  @id @default(uuid()) @db.Uuid
  organizationId              String                  @db.Uuid
  establishmentId             String                  @db.Uuid
  encounterId                 String?                 @db.Uuid
  patientId                   String                  @db.Uuid
  insurerId                   String?                 @db.Uuid
  invoiceNumber               String                  @db.VarChar(40)
  issuedAt                    DateTime                @default(now()) @db.Timestamptz()
  dueAt                       DateTime?               @db.Timestamptz()
  currencyId                  String                  @db.Uuid
  exchangeRateToFunc          Decimal                 @default(1) @db.Decimal(18, 8)
  subtotal                    Decimal                 @default(0) @db.Decimal(14, 2)
  taxAmount                   Decimal                 @default(0) @db.Decimal(14, 2)
  totalAmount                 Decimal                 @default(0) @db.Decimal(14, 2)
  paidAmount                  Decimal                 @default(0) @db.Decimal(14, 2)
  status                      InvoiceStatus           @default(DRAFT)
  electronicInvoiceStatus     ElectronicInvoiceStatus @default(NOT_APPLICABLE)
  electronicInvoiceCode       String?                 @db.VarChar(64)
  electronicInvoiceIssuedAt   DateTime?               @db.Timestamptz()
  notes                       String?                 @db.Text
  costCenterId                String?                 @db.Uuid
  createdAt                   DateTime                @default(now()) @db.Timestamptz()
  createdBy                   String?                 @db.Uuid
  updatedAt                   DateTime                @updatedAt @db.Timestamptz()
  updatedBy                   String?                 @db.Uuid

  organization  Organization  @relation("InvoiceOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  establishment Establishment @relation("InvoiceEstablishment", fields: [establishmentId], references: [id], onDelete: Restrict)
  encounter     Encounter?    @relation("InvoiceEncounter", fields: [encounterId], references: [id], onDelete: SetNull)
  patient       Patient       @relation("InvoicePatient", fields: [patientId], references: [id], onDelete: Restrict)
  insurer       Insurer?      @relation("InvoiceInsurer", fields: [insurerId], references: [id], onDelete: SetNull)
  currency      Currency      @relation("InvoiceCurrency", fields: [currencyId], references: [id], onDelete: Restrict)
  costCenter    CostCenter?   @relation("InvoiceCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)
  items         InvoiceItem[]
  payments      InvoicePayment[]
  claims        InsuranceClaim[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, issuedAt(sort: Desc)])
  @@index([patientId])
  @@index([encounterId])
  @@index([organizationId, status])
  @@index([organizationId, electronicInvoiceStatus])
  @@index([costCenterId])
  @@schema("public")
}

/// Línea de factura. costCenterId obligatorio (RESTRICT) — sin CC no hay análisis presupuestario.
model InvoiceItem {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @db.Uuid
  description   String   @db.VarChar(300)
  quantity      Decimal  @db.Decimal(12, 3)
  unitPrice     Decimal  @db.Decimal(14, 2)
  totalPrice    Decimal  @db.Decimal(14, 2)
  serviceUnitId String?  @db.Uuid
  costCenterId  String   @db.Uuid
  estimatedCost Decimal? @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @db.Timestamptz()

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  serviceUnit ServiceUnit? @relation("InvoiceItemServiceUnit", fields: [serviceUnitId], references: [id], onDelete: SetNull)
  costCenter  CostCenter   @relation("InvoiceItemCostCenter", fields: [costCenterId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([serviceUnitId])
  @@index([costCenterId])
  @@schema("public")
}

/// Pago registrado contra una factura.
/// Trigger BD fn_invoice_recalc_payments actualiza Invoice.paidAmount + status — NO replicar lógica aquí.
model InvoicePayment {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceId       String        @db.Uuid
  paidAt          DateTime      @default(now()) @db.Timestamptz()
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod
  referenceNumber String?       @db.VarChar(80)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @db.Timestamptz()
  createdBy       String?       @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([paidAt(sort: Desc)])
  @@schema("public")
}

/// Reclamación ante aseguradora vinculada a una factura.
model InsuranceClaim {
  id               String      @id @default(uuid()) @db.Uuid
  invoiceId        String      @db.Uuid
  insurerId        String      @db.Uuid
  claimNumber      String      @db.VarChar(80)
  submittedAt      DateTime    @default(now()) @db.Timestamptz()
  respondedAt      DateTime?   @db.Timestamptz()
  status           ClaimStatus @default(SUBMITTED)
  submittedAmount  Decimal     @db.Decimal(14, 2)
  approvedAmount   Decimal     @db.Decimal(14, 2)
  rejectedAmount   Decimal     @db.Decimal(14, 2)
  rejectionReason  String?     @db.Text
  notes            String?     @db.Text
  createdAt        DateTime    @default(now()) @db.Timestamptz()
  createdBy        String?     @db.Uuid
  updatedAt        DateTime    @updatedAt @db.Timestamptz()
  updatedBy        String?     @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  insurer Insurer @relation("ClaimInsurer", fields: [insurerId], references: [id], onDelete: Restrict)

  @@unique([insurerId, claimNumber])
  @@index([invoiceId])
  @@index([insurerId, submittedAt(sort: Desc)])
  @@index([status, submittedAt(sort: Desc)])
  @@schema("public")
}

