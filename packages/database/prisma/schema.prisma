/// Contacto asistencial — raíz de los documentos del episodio (Art. 16, 17 NTEC)
model EceEpisodioAtencion {
  id                String    @id @default(uuid()) @db.Uuid
  pacienteId        String    @map("paciente_id") @db.Uuid
  establecimientoId String    @map("establecimiento_id") @db.Uuid
  modalidad         String    @db.VarChar(20)
  servicioCategoria String    @map("servicio_categoria") @db.VarChar(40)
  servicioId        String?   @map("servicio_id") @db.Uuid
  origenConsulta    String?   @map("origen_consulta") @db.VarChar(20)
  modalidadAtencion String?   @map("modalidad_atencion") @db.VarChar(20)
  motivo            String?
  fechaHoraInicio   DateTime  @default(now()) @map("fecha_hora_inicio") @db.Timestamptz()
  fechaHoraCierre   DateTime? @map("fecha_hora_cierre") @db.Timestamptz()
  estado            String    @default("abierto") @db.VarChar(20)
  disposicion       String?   @db.VarChar(30)
  creadoPor         String?   @map("creado_por") @db.Uuid
  creadoEn          DateTime  @default(now()) @map("creado_en") @db.Timestamptz()

  /// F2-S15 Stream A — conservación §7
  estadoConservacion         EstadoConservacion   @default(ACTIVO) @map("estado_conservacion")
  fechaVencimientoRetencion  DateTime?            @map("fecha_vencimiento_retencion") @db.Timestamptz()

  paciente                EcePaciente               @relation(fields: [pacienteId], references: [id])
  establecimiento         EceEstablecimiento        @relation(fields: [establecimientoId], references: [id])
  servicio                EceServicio?              @relation(fields: [servicioId], references: [id])
  episodioHosp            EceEpisodioHospitalario?
  documentosInstancia     EceDocumentoInstancia[]
  historiasClinicas       EceHistoriaClinica[]
  signosVitales           EceSignosVitales[]
  triajes                 EceTriaje[]
  atencionesEmergencia    EceAtencionEmergencia[]
  indicacionesMedicas     EceIndicacionesMedicas[]
  registrosEnfermeria     EceRegistroEnfermeria[]
  evolucionesMedicas      EceEvolucionMedica[]
  consentimientos         EceConsentimientoInformado[]
  referenciasRri          EceReferenciaRri[]
  ordenesIngreso          EceOrdenIngreso[]
  hojaIngreso             EceHojaIngreso?
  actosQuirurgicos        EceActoQuiruurgico[]
  documentosObstetricos   EceDocumentoObstetrico[]
  epicrisisEgreso         EceEpicrisisEgreso?
  certificadosDefuncion   EceCertificadoDefuncion[]
  certificadosIncapacidad EceCertificadoIncapacidad[]
  solicitudesEstudio      EceSolicitudEstudio[]
  estadoLogs              EceEpisodioEstadoLog[]
  eliminaciones           EceEliminacionSupervisada[] @relation("EpisodioEliminaciones")
  reservasSalaQx          EceReservaSalaQx[]

  @@index([pacienteId])
  @@index([estado])
  @@map("episodio_atencion")
  @@schema("ece")
}

/// Datos hospitalarios del episodio (Art. 17 lit. b NTEC)
model EceEpisodioHospitalario {
  episodioId            String    @id @map("episodio_id") @db.Uuid
  circunstanciaIngreso  String    @map("circunstancia_ingreso") @db.VarChar(40)
  procedenciaIngreso    String    @map("procedencia_ingreso") @db.VarChar(40)
  modalidadHospitalaria String    @map("modalidad_hospitalaria") @db.VarChar(30)
  fechaHoraOrdenIngreso DateTime  @map("fecha_hora_orden_ingreso") @db.Timestamptz()
  fechaHoraEgreso       DateTime? @map("fecha_hora_egreso") @db.Timestamptz()
  tipoEgreso            String?   @map("tipo_egreso") @db.VarChar(20)
  circunstanciaAlta     String?   @map("circunstancia_alta") @db.VarChar(30)
  servicioIngresoId     String?   @map("servicio_ingreso_id") @db.Uuid

  episodio        EceEpisodioAtencion @relation(fields: [episodioId], references: [id])
  servicioIngreso EceServicio?        @relation(fields: [servicioIngresoId], references: [id])
  asignacionesCama EceAsignacionCama[]

  @@map("episodio_hospitalario")
  @@schema("ece")
}

/// Histórico de ocupación de cama por episodio
model EceAsignacionCama {
  id           String    @id @default(uuid()) @db.Uuid
  episodioId   String    @map("episodio_id") @db.Uuid
  camaId       String    @map("cama_id") @db.Uuid
  desde        DateTime  @default(now()) @db.Timestamptz()
  hasta        DateTime? @db.Timestamptz()
  motivoCambio String?   @map("motivo_cambio")

  episodioHosp EceEpisodioHospitalario @relation(fields: [episodioId], references: [episodioId])
  cama         EceCama                 @relation(fields: [camaId], references: [id])

  @@index([episodioId])
  @@map("asignacion_cama")
  @@schema("ece")
}

// -----------------------------------------------------------------------------
// ECE — Motor de workflow (data-driven)
// -----------------------------------------------------------------------------

/// Define cada documento del ECE para su digitalización
model EceTipoDocumento {
  id           String   @id @default(uuid()) @db.Uuid
  codigo       String   @unique @db.VarChar(60)
  nombre       String   @db.VarChar(200)
  tablaDatos   String   @map("tabla_datos") @db.VarChar(80)
  tipoRegistro String   @map("tipo_registro") @db.VarChar(20)
  modalidad    String   @db.VarChar(20)
  dependeDe    String[] @map("depende_de")
  inmutable    Boolean  @default(false)
  activo       Boolean  @default(true)

  flujoEstados      EceFlujoEstado[]
  flujoTransiciones EceFlujoTransicion[]
  documentoRoles    EceDocumentoRol[]
  instancias        EceDocumentoInstancia[]

  @@map("tipo_documento")
  @@schema("ece")
}

/// Estados del flujo por tipo de documento
model EceFlujoEstado {
  id              String  @id @default(uuid()) @db.Uuid
  tipoDocumentoId String  @map("tipo_documento_id") @db.Uuid
  codigo          String  @db.VarChar(30)
  nombre          String  @db.VarChar(100)
  esInicial       Boolean @default(false) @map("es_inicial")
  esFinal         Boolean @default(false) @map("es_final")
  orden           Int     @default(0)

  tipoDocumento       EceTipoDocumento               @relation(fields: [tipoDocumentoId], references: [id])
  transicionesOrigen  EceFlujoTransicion[]           @relation("EstadoOrigen")
  transicionesDestino EceFlujoTransicion[]           @relation("EstadoDestino")
  instanciasActuales  EceDocumentoInstancia[]
  historialAnterior   EceDocumentoInstanciaHistorial[] @relation("EstadoAnterior")
  historialNuevo      EceDocumentoInstanciaHistorial[] @relation("EstadoNuevo")

  @@unique([tipoDocumentoId, codigo])
  @@map("flujo_estado")
  @@schema("ece")
}

/// Transiciones permitidas + rol que AUTORIZA la transición
model EceFlujoTransicion {
  id              String  @id @default(uuid()) @db.Uuid
  tipoDocumentoId String  @map("tipo_documento_id") @db.Uuid
  estadoOrigenId  String  @map("estado_origen_id") @db.Uuid
  estadoDestinoId String  @map("estado_destino_id") @db.Uuid
  accion          String  @db.VarChar(60)
  rolAutorizaId   String  @map("rol_autoriza_id") @db.Uuid
  requiereFirma   Boolean @default(true) @map("requiere_firma")

  tipoDocumento EceTipoDocumento @relation(fields: [tipoDocumentoId], references: [id])
  estadoOrigen  EceFlujoEstado   @relation("EstadoOrigen", fields: [estadoOrigenId], references: [id])
  estadoDestino EceFlujoEstado   @relation("EstadoDestino", fields: [estadoDestinoId], references: [id])
  rolAutoriza   EceRol           @relation("RolAutoriza", fields: [rolAutorizaId], references: [id])

  @@unique([tipoDocumentoId, estadoOrigenId, accion])
  @@map("flujo_transicion")
  @@schema("ece")
}

/// Matriz LLENA/RESPONSABLE/AUTORIZA/FIRMA por documento
model EceDocumentoRol {
  id              String  @id @default(uuid()) @db.Uuid
  tipoDocumentoId String  @map("tipo_documento_id") @db.Uuid
  rolId           String  @map("rol_id") @db.Uuid
  funcion         String  @db.VarChar(20)
  obligatorio     Boolean @default(true)

  tipoDocumento EceTipoDocumento @relation(fields: [tipoDocumentoId], references: [id])
  rol           EceRol           @relation(fields: [rolId], references: [id])

  @@unique([tipoDocumentoId, rolId, funcion])
  @@map("documento_rol")
  @@schema("ece")
}

/// Documento real del expediente — une tipo, episodio y fila de datos clínicos
model EceDocumentoInstancia {
  id              String   @id @default(uuid()) @db.Uuid
  tipoDocumentoId String   @map("tipo_documento_id") @db.Uuid
  episodioId      String?  @map("episodio_id") @db.Uuid
  pacienteId      String   @map("paciente_id") @db.Uuid
  registroId      String?  @map("registro_id") @db.Uuid
  estadoActualId  String   @map("estado_actual_id") @db.Uuid
  version         Int      @default(1)
  estadoRegistro  String   @default("vigente") @map("estado_registro") @db.VarChar(20)
  creadoPorId     String   @map("creado_por") @db.Uuid
  creadoEn        DateTime @default(now()) @map("creado_en") @db.Timestamptz()

  tipoDocumento      EceTipoDocumento               @relation(fields: [tipoDocumentoId], references: [id])
  episodio           EceEpisodioAtencion?           @relation(fields: [episodioId], references: [id])
  paciente           EcePaciente                    @relation(fields: [pacienteId], references: [id])
  estadoActual       EceFlujoEstado                 @relation(fields: [estadoActualId], references: [id])
  creadoPor          EcePersonalSalud               @relation("CreadoPor", fields: [creadoPorId], references: [id])
  historial          EceDocumentoInstanciaHistorial[]
  bitacorasAuditoria EceBitacoraAuditoria[]
  rectificaciones    EceRectificacion[]
  supresiones        EceSupresion[]

  @@index([episodioId])
  @@index([pacienteId])
  @@index([tipoDocumentoId])
  @@map("documento_instancia")
  @@schema("ece")
}

/// Bitácora de workflow — solo INSERT, marca temporal nivel segundo (Art. 55 NTEC)
model EceDocumentoInstanciaHistorial {
  id               String    @id @default(uuid()) @db.Uuid
  instanciaId      String    @map("instancia_id") @db.Uuid
  estadoAnteriorId String?   @map("estado_anterior_id") @db.Uuid
  estadoNuevoId    String    @map("estado_nuevo_id") @db.Uuid
  accion           String    @db.VarChar(60)
  ejecutadoPorId   String    @map("ejecutado_por") @db.Uuid
  rolEjecutorId    String    @map("rol_ejecutor_id") @db.Uuid
  firmaId          String?   @map("firma_id") @db.Uuid
  observacion      String?
  ejecutadoEn      DateTime  @default(now()) @map("ejecutado_en") @db.Timestamptz()

  instancia      EceDocumentoInstancia @relation(fields: [instanciaId], references: [id])
  estadoAnterior EceFlujoEstado?       @relation("EstadoAnterior", fields: [estadoAnteriorId], references: [id])
  estadoNuevo    EceFlujoEstado        @relation("EstadoNuevo", fields: [estadoNuevoId], references: [id])
  ejecutadoPor   EcePersonalSalud      @relation("EjecutadoPor", fields: [ejecutadoPorId], references: [id])
  rolEjecutor    EceRol                @relation("RolEjecutor", fields: [rolEjecutorId], references: [id])
  firma          EceFirmaElectronica?  @relation(fields: [firmaId], references: [id])

  @@index([instanciaId])
  @@map("documento_instancia_historial")
  @@schema("ece")
}

// -----------------------------------------------------------------------------
// ECE — Documentos clínicos (19 formularios)
// -----------------------------------------------------------------------------

/// 3.2 Historia Clínica — SOAP / anamnesis
model EceHistoriaClinica {
  id               String   @id @default(uuid()) @db.Uuid
  instanciaId      String?  @map("instancia_id") @db.Uuid
  episodioId       String   @map("episodio_id") @db.Uuid
  pacienteId       String?  @map("paciente_id") @db.Uuid
  tipoConsulta     String   @map("tipo_consulta") @db.VarChar(20)
  motivoConsulta   String?  @map("motivo_consulta")
  enfermedadActual String?  @map("enfermedad_actual")
  antecedentes     Json?
  examenFisico     Json?    @map("examen_fisico")
  diagnosticos     Json?
  planManejo       String?  @map("plan_manejo")
  disposicion      String?  @db.VarChar(30)
  data             Json?
  registradoPorId  String   @map("registrado_por") @db.Uuid
  registradoEn     DateTime @default(now()) @map("registrado_en") @db.Timestamptz()
  estadoRegistro   String   @default("vigente") @map("estado_registro") @db.VarChar(20)
  /// CC-0007 RF-05 — antecedentes estructurados por subsección {estado,items[]}
  /// Subsecciones: alergias | personales | familiares | ocupacion | habitos
  antecedentesEstructurados Json?  @map("antecedentes_estructurados")
  /// CC-0007 RF-12 — plan de manejo como grid de indicaciones [{orden,texto}]
  planItems         Json?  @map("plan_items")
  /// CC-0007 RF-09 — procedimientos CPT [{codigo,descripcion,complemento?}]
  procedimientosCpt Json?  @map("procedimientos_cpt")
  /// CC-0007 RF-10 — terapia respiratoria estructurada
  terapiaRespiratoria Json? @map("terapia_respiratoria")
  /// CC-0007 RF-10 — órdenes de exámenes lab/gabinete [{seccion,examen,cantidad}]
  ordenesExamenes   Json?  @map("ordenes_examenes")
  /// CC-0007 RF-10 — órdenes de inyecciones [{texto}]
  ordenesInyecciones Json? @map("ordenes_inyecciones")

  episodio      EceEpisodioAtencion @relation(fields: [episodioId], references: [id])
  registradoPor EcePersonalSalud    @relation("HCRegistradoPor", fields: [registradoPorId], references: [id])

  @@index([episodioId])
  @@map("historia_clinica")
  @@schema("ece")
}

/// 3.3 Signos Vitales — serie temporal por episodio
model EceSignosVitales {
  id                     String   @id @default(uuid()) @db.Uuid
  instanciaId            String?  @map("instancia_id") @db.Uuid
  episodioId             String   @map("episodio_id") @db.Uuid
  pacienteId             String?  @map("paciente_id") @db.Uuid
  fechaHoraToma          DateTime @default(now()) @map("fecha_hora_toma") @db.Timestamptz()
  presionSistolica       Int?     @map("presion_sistolica")
  presionDiastolica      Int?     @map("presion_diastolica")
  frecuenciaCardiaca     Int?     @map("frecuencia_cardiaca")
  frecuenciaRespiratoria Int?     @map("frecuencia_respiratoria")
  temperatura            Decimal? @db.Decimal(4, 1)
  saturacionO2           Int?     @map("saturacion_o2")
  peso                   Decimal? @db.Decimal(6, 2)
  talla                  Decimal? @db.Decimal(5, 2)
  imc                    Decimal? @db.Decimal(5, 2)
  perimetroCefalico      Decimal? @map("perimetro_cefalico") @db.Decimal(5, 2)
  escalaDolor            Int?     @map("escala_dolor")
  data                   Json?
  registradoPorId        String   @map("registrado_por") @db.Uuid
  registradoEn           DateTime @default(now()) @map("registrado_en") @db.Timestamptz()
  estadoRegistro         String   @default("vigente") @map("estado_registro") @db.VarChar(20)
  /// F2-S15 Stream A — contingencia §6
  digitadoRetroactivamente Boolean  @default(false) @map("digitado_retroactivamente")
  timestampRealPapel       DateTime? @map("timestamp_real_papel") @db.Timestamptz()
  contingenciaEventoId     String?  @map("contingencia_evento_id") @db.Uuid
  /// CC-0007 RF-06 — neurológico (Glasgow por componente). La glucometría usa
  /// la columna existente glucometria_mgdl (operada vía raw SQL en el router).
  glasgowOcular            Int?     @map("glasgow_ocular")
  glasgowVerbal            Int?     @map("glasgow_verbal")
  glasgowMotor             Int?     @map("glasgow_motor")
  glasgowTotal             Int?     @map("glasgow_total")
  /// CC-0007 RF-06 — FiO2 obligatorio junto con PA+cardiorrespiratorios
  fio2                     Decimal? @db.Decimal(5, 2)
  /// CC-0007 RF-06 — antropometría extendida (ICT, cintura, balance, diuresis)
  ict                      Decimal? @db.Decimal(5, 3)
  perimetroCintura         Decimal? @map("perimetro_cintura") @db.Decimal(5, 1)
  balanceHidrico           Decimal? @map("balance_hidrico") @db.Decimal(7, 1)
  diuresis                 Decimal? @db.Decimal(7, 1)
  /// CC-0007 RF-06 — gineco-obstétrico (solo paciente femenina en edad fértil)
  fur                      DateTime? @db.Date
  fpp                      DateTime? @db.Date

  episodio      EceEpisodioAtencion @relation(fields: [episodioId], references: [id])
  registradoPor EcePersonalSalud    @relation("SVRegistradoPor", fields: [registradoPorId], references: [id])
  triajes       EceTriaje[]

  @@index([episodioId, fechaHoraToma])
  @@map("signos_vitales")
  @@schema("ece")
}

