  organization Organization? @relation("HisOperatingCostOrganization", fields: [organizationId], references: [id], onDelete: Restrict)
  currency     Currency      @relation("HisOperatingCostCurrency", fields: [currencyId], references: [id], onDelete: Restrict)

  @@index([periodStart, periodEnd])
  @@index([organizationId])
  @@index([category])
  @@schema("public")
}

// =============================================================================
// Cost Centers — sql/131_cost_centers_spec_v2_41.sql
// =============================================================================

/// Regla de prorrateo de un centro de costo fuente hacia N centros destino.
/// Trigger BD valida suma porcentajes = 100% (DEFERRABLE) — NO replicar en Prisma.
model CostCenterAllocationRule {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid
  name              String               @db.VarChar(120)
  sourceCostCenterId String              @db.Uuid
  base              CostDistributionBase
  periodicity       String               @default("monthly") @db.VarChar(20)
  active            Boolean              @default(true)
  createdAt         DateTime             @default(now()) @db.Timestamptz()
  updatedAt         DateTime             @updatedAt @db.Timestamptz()

  organization     Organization @relation("AllocationRuleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  sourceCostCenter CostCenter   @relation("AllocationRuleSource", fields: [sourceCostCenterId], references: [id], onDelete: Cascade)
  targets          CostCenterAllocationTarget[]

  @@unique([sourceCostCenterId, active])
  @@index([organizationId])
  @@schema("public")
}

/// Destino de prorrateo: un centro de costo objetivo con su porcentaje.
model CostCenterAllocationTarget {
  id                  String  @id @default(uuid()) @db.Uuid
  ruleId              String  @db.Uuid
  targetCostCenterId  String  @db.Uuid
  percentage          Decimal @db.Decimal(5, 2)

  rule             CostCenterAllocationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  targetCostCenter CostCenter               @relation("AllocationRuleTarget", fields: [targetCostCenterId], references: [id], onDelete: Restrict)

  @@index([ruleId])
  @@schema("public")
}

// =============================================================================
// CC-0002 §7 — Cuentas y Servicios de Paciente
// =============================================================================

/// Cuenta administrativa del paciente (CTA00001…). Correlativo por expediente.
/// encounterId es opcional: se genera con o sin admisión (ambulatorio incluido).
model PatientAccount {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  patientId      String   @db.Uuid
  numeroCuenta   String   @db.VarChar(20) /// CTA00001 — correlativo por expediente (CC-0002 §7).
  encounterId    String?  @db.Uuid       /// opcional: cuenta con o sin admisión.
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdBy      String?  @db.Uuid

  organization Organization          @relation("PatientAccountOrg", fields: [organizationId], references: [id], onDelete: Restrict)
  patient      Patient               @relation("PatientAccounts", fields: [patientId], references: [id], onDelete: Restrict)
  encounter    Encounter?            @relation("EncounterAccounts", fields: [encounterId], references: [id], onDelete: SetNull)
  servicios    PatientAccountService[]

  @@unique([patientId, numeroCuenta])
  @@index([organizationId])
  @@index([patientId])
  @@index([encounterId])
  @@schema("public")
}

/// Servicio registrado dentro de una cuenta de paciente (HOSPITALARIO | NO_HOSPITALARIO).
model PatientAccountService {
  id          String       @id @default(uuid()) @db.Uuid
  accountId   String       @db.Uuid
  tipo        TipoServicio
  descripcion String?      @db.VarChar(300)
  encounterId String?      @db.Uuid
  createdAt   DateTime     @default(now()) @db.Timestamptz()
  createdBy   String?      @db.Uuid

  account   PatientAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  encounter Encounter?     @relation("EncounterAccountServices", fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([encounterId])
  @@schema("public")
}
