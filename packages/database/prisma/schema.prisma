// =============================================================================
// HIS Multi-país | Inversiones Avante | MVP fundacional
// Schema Prisma — Postgres 15+ (Supabase) — 4NF estricto
// Cubre TDR §5 (multi-entidad), §6 (seguridad), §7 (catálogos), §8 (MPI/ADT),
// §9 (Triage Manchester).
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, citext, uuid_ossp(map: "uuid-ossp"), pg_trgm]
  schemas    = ["public", "audit"]
}

// =============================================================================
// 0. ENUMS  (valores fijos del dominio; los catálogos evolutivos van como tablas)
// =============================================================================

/// TDR §5.4 — libros contables paralelos.
enum LedgerKind {
  FISCAL_LOCAL
  IFRS
  US_GAAP
  MANAGEMENT
  BUDGET
  STATISTICAL

  @@schema("public")
}

/// TDR §5.3 — tipo de tasa de cambio.
enum FxRateType {
  BUY
  SELL
  AVERAGE
  OFFICIAL
  FISCAL

  @@schema("public")
}

/// TDR §6.1 — tipo de credencial usada para autenticar al usuario.
enum AuthMethod {
  PASSWORD
  TOTP
  SMS_OTP
  EMAIL_OTP
  PUSH
  SAML
  OIDC
  LDAP
  ESIGN

  @@schema("public")
}

/// TDR §6.3 — acción auditada.
enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  PRINT
  EXPORT
  SIGN
  VOID
  LOGIN
  LOGOUT
  BREAK_GLASS

  @@schema("public")
}

/// TDR §8.3 — tipo de admisión.
enum AdmissionType {
  EMERGENCY
  SCHEDULED
  TRANSFER_IN
  BIRTH
  NEWBORN

  @@schema("public")
}

/// TDR §8.1 — clase de identificador del paciente en MPI.
enum PatientIdentifierKind {
  DUI
  NIT
  NIE
  PASSPORT
  BIRTH_CERT
  MINOR_ID
  RESIDENT_ID
  NUP
  OTHER

  @@schema("public")
}

/// TDR §8.5 — tipos de alta.
enum DischargeType {
  MEDICAL
  VOLUNTARY
  TRANSFER_OUT
  ABSCONDED
  DEATH
  AGAINST_MEDICAL_ADVICE

  @@schema("public")
}

/// TDR §8.6 — estados de cama.
enum BedStatus {
  FREE
  OCCUPIED
  DIRTY
  BLOCKED
  MAINTENANCE
  RESERVED

  @@schema("public")
}

/// TDR §9 — niveles Manchester (color es derivado del nivel pero también persistido para auditoría).
enum TriageColor {
  RED
  ORANGE
  YELLOW
  GREEN
  BLUE

  @@schema("public")
}

/// TDR §9.2 — estado de la evaluación de triage.
enum TriageStatus {
  IN_PROGRESS
  COMPLETED
  RE_TRIAGED
  CANCELLED

  @@schema("public")
}

/// TDR §6.2 — efecto del permiso.
enum PermissionEffect {
  ALLOW
  DENY

  @@schema("public")
}

// =============================================================================
// 1. MULTI-ENTIDAD  (TDR §5)
// =============================================================================

/// TDR §5.1 — País. Raíz del aislamiento geográfico-regulatorio.
model Country {
  id            String   @id @default(uuid()) @db.Uuid
  isoAlpha3     String   @unique @db.Char(3) /// ISO 3166-1 alfa-3 (SLV).
  isoNumeric    Int      @unique
  name          String   @db.VarChar(120)
  defaultLocale String   @db.VarChar(20) /// es-SV, es-GT, etc.
  defaultTzId   String   @db.VarChar(60) /// IANA: America/El_Salvador.
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz()
  updatedAt     DateTime @updatedAt @db.Timestamptz()

  organizations   Organization[]
  geoDivisions    GeoDivision[]
  currencies      CountryCurrency[]
  identifierTypes IdentifierType[]
  holidays        Holiday[]

  @@schema("public")
}

/// TDR §5.1 / §27.4 — división política jerárquica auto-referencial.
/// 4NF: cada nivel (depto, municipio, distrito, cantón) en una sola tabla evita MVD entre niveles.
model GeoDivision {
  id        String    @id @default(uuid()) @db.Uuid
  countryId String    @db.Uuid
  parentId  String?   @db.Uuid
  level     Int /// 1=departamento, 2=municipio, 3=distrito, 4=cantón.
  code      String    @db.VarChar(20)
  name      String    @db.VarChar(120)
  validFrom DateTime  @db.Date /// vigencia del registro (reforma 2024 SV).
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()

  country  Country       @relation(fields: [countryId], references: [id], onDelete: Restrict)
  parent   GeoDivision?  @relation("GeoTree", fields: [parentId], references: [id], onDelete: Restrict)
  children GeoDivision[] @relation("GeoTree")

  @@unique([countryId, code, level, validFrom])
  @@index([parentId])
  @@schema("public")
}

/// TDR §27.4 — feriados nacionales y locales.
model Holiday {
  id            String   @id @default(uuid()) @db.Uuid
  countryId     String   @db.Uuid
  geoDivisionId String?  @db.Uuid /// null => feriado nacional.
  date          DateTime @db.Date
  name          String   @db.VarChar(120)
  kind          String   @db.VarChar(40) /// nacional/local/religioso/institucional.
  recurring     Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamptz()

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, geoDivisionId, date, name])
  @@schema("public")
}

/// TDR §5.3 — moneda (catálogo global).
model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  isoCode   String   @unique @db.Char(3) /// USD, SVC, BTC, GTQ.
  name      String   @db.VarChar(80)
  decimals  Int      @default(2)
  symbol    String   @db.VarChar(8)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  countries        CountryCurrency[]
  orgsAsFunctional Organization[]    @relation("OrgFunctional")
  orgsAsReporting  Organization[]    @relation("OrgReporting")
  fxFromRates      ExchangeRate[]    @relation("FxFrom")
  fxToRates        ExchangeRate[]    @relation("FxTo")
  ledgers          Ledger[]          @relation("LedgerCurrency")
  encounters       Encounter[]       @relation("EncounterCurrency")

  @@schema("public")
}

/// TDR §5.1, §5.3 — relación país-moneda (n:m con atributo `isLegalTender`).
/// 4NF: aísla la dependencia multivaluada países↔monedas.
model CountryCurrency {
  countryId     String  @db.Uuid
  currencyId    String  @db.Uuid
  isLegalTender Boolean @default(false)
  isFunctional  Boolean @default(false) /// moneda funcional del país.

  country  Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Restrict)

  @@id([countryId, currencyId])
  @@schema("public")
}

/// TDR §5.3 — tipos de cambio históricos.
model ExchangeRate {
  id           String     @id @default(uuid()) @db.Uuid
  fromCurrency String     @db.Uuid
  toCurrency   String     @db.Uuid
  rateType     FxRateType
  rate         Decimal    @db.Decimal(18, 8)
  validFrom    DateTime   @db.Timestamptz()
  validTo      DateTime?  @db.Timestamptz()
  source       String?    @db.VarChar(80) /// BCR, manual, etc.
  createdAt    DateTime   @default(now()) @db.Timestamptz()

  from Currency @relation("FxFrom", fields: [fromCurrency], references: [id], onDelete: Restrict)
  to   Currency @relation("FxTo", fields: [toCurrency], references: [id], onDelete: Restrict)

  @@unique([fromCurrency, toCurrency, rateType, validFrom])
  @@index([validFrom])
  @@schema("public")
}

/// TDR §5.2 — organización (entidad jurídica con NIT). Holding/Empresa.
model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  countryId          String   @db.Uuid
  parentId           String?  @db.Uuid /// jerarquía Holding -> Empresa.
  legalName          String   @db.VarChar(200)
  tradeName          String?  @db.VarChar(200)
  taxId              String   @db.VarChar(40) /// NIT.
  functionalCurrency String   @db.Uuid
  reportingCurrency  String?  @db.Uuid
  active             Boolean  @default(true)
  /// Prefijo GS1 de la empresa (7–9 dígitos) para generación de GSRN (US.F2.6.1).
  gs1CompanyPrefix   String?  @db.VarChar(9)
  createdAt          DateTime @default(now()) @db.Timestamptz()
  createdBy          String?  @db.Uuid
  updatedAt          DateTime @updatedAt @db.Timestamptz()
  updatedBy          String?  @db.Uuid

  country        Country                @relation(fields: [countryId], references: [id], onDelete: Restrict)
  parent         Organization?          @relation("OrgTree", fields: [parentId], references: [id], onDelete: Restrict)
  children       Organization[]         @relation("OrgTree")
  functionalCurr Currency               @relation("OrgFunctional", fields: [functionalCurrency], references: [id], onDelete: Restrict)
  reportingCurr  Currency?              @relation("OrgReporting", fields: [reportingCurrency], references: [id], onDelete: Restrict)
  establishments Establishment[]
  ledgers        Ledger[]
  userRoles      UserOrganizationRole[]
  patients       Patient[]
  encounters     Encounter[]
  triages        TriageEvaluation[]
  beds           Bed[]
  services       ServiceUnit[]
  vaccinations   PatientVaccination[]
  soapNotes      SoapNote[]
  /// Wave 1 cont. — back-relations W1c.
  allergyIntolerances   AllergyIntolerance[]
  allergyReactions      AllergyReaction[]
  problemListItems      ProblemListItem[]
  problemChangeLogs     ProblemChangeLog[]
  soapNoteTemplates     SoapNoteTemplate[]
  medicalLeaveBlobs     MedicalLeaveSignedBlob[]
  signedDocAnchors      SignedDocumentAnchor[]
  apptStateTransitions  AppointmentStateTransitionLog[]

  @@unique([countryId, taxId])
  @@index([parentId])
  @@schema("public")
}

/// TDR §5.2 — establecimiento físico (sede). MINSAL exige código por establecimiento.
model Establishment {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  geoDivisionId  String?  @db.Uuid
  code           String   @db.VarChar(40) /// código MINSAL.
  name           String   @db.VarChar(200)
  addressLine    String?  @db.VarChar(300)
  phone          String?  @db.VarChar(40)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  createdBy      String?  @db.Uuid
  updatedAt      DateTime @updatedAt @db.Timestamptz()
  updatedBy      String?  @db.Uuid

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  serviceUnits ServiceUnit[]
  beds         Bed[]
  encounters   Encounter[]
  triages      TriageEvaluation[]

  @@unique([organizationId, code])
  @@schema("public")
}

/// TDR §5.4 — libro contable paralelo. Asientos se generan por libro activo.
model Ledger {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @db.Uuid
  code           String     @db.VarChar(40)
  name           String     @db.VarChar(120)
  kind           LedgerKind
  currencyId     String     @db.Uuid
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now()) @db.Timestamptz()
  updatedAt      DateTime   @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currency     Currency     @relation("LedgerCurrency", fields: [currencyId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@schema("public")
}

// =============================================================================
// 2. SEGURIDAD  (TDR §6)
// =============================================================================

/// TDR §6.1 — usuario humano del sistema. Las credenciales viven en tablas separadas (4NF).
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.Citext
  fullName        String    @db.VarChar(200)
  active          Boolean   @default(true)
  mfaEnabled      Boolean   @default(false)
  lastLoginAt     DateTime? @db.Timestamptz()
  /// US-2.1 - intentos fallidos consecutivos de login (se resetea al login OK).
  failedAttempts  Int       @default(0)
  /// US-2.1 - bloqueo temporal por intentos fallidos. NULL = no bloqueado.
  lockedUntil     DateTime? @db.Timestamptz()
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdBy       String?   @db.Uuid
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedBy       String?   @db.Uuid

  credentials            UserCredential[]
  externalIdentities     UserExternalIdentity[]
  roles                  UserOrganizationRole[]
  sessions               Session[]
  patientConsentsGranted PatientConsent[]       @relation("ConsentAuthor")

  @@schema("public")
}

/// TDR §6.1 — credenciales locales. 4NF: separa la MVD usuario↔(método auth, hash).
model UserCredential {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @db.Uuid
  method     AuthMethod
  secretHash String /// bcrypt/argon2 (PASSWORD), TOTP secret cifrado, etc.
  validFrom  DateTime   @default(now()) @db.Timestamptz()
  validTo    DateTime?  @db.Timestamptz()
  createdAt  DateTime   @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, method])
  @@schema("public")
}

/// TDR §6.1 — identidad federada (SAML/OIDC/LDAP). 4NF: independiente de credenciales locales.
model UserExternalIdentity {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  provider  AuthMethod /// SAML/OIDC/LDAP.
  issuer    String     @db.VarChar(200)
  subject   String     @db.VarChar(200)
  createdAt DateTime   @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, issuer, subject])
  @@schema("public")
}

/// TDR §6.1 — sesión activa (para revocación y auditoría).
model Session {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  organizationId String?   @db.Uuid /// tenant context activo.
  ip             String?   @db.Inet
  userAgent      String?   @db.VarChar(400)
  issuedAt       DateTime  @default(now()) @db.Timestamptz()
  expiresAt      DateTime  @db.Timestamptz()
  revokedAt      DateTime? @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@schema("public")
}

/// TDR §6.2 — rol parametrizable (RBAC). Por organización o global.
model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid /// null => rol global del sistema.
  code           String   @db.VarChar(60)
  name           String   @db.VarChar(120)
  description    String?  @db.Text
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  permissions RolePermission[]
  userRoles   UserOrganizationRole[]

  @@unique([organizationId, code])
  @@schema("public")
}

/// TDR §6.2 — permiso atómico (acción + recurso). Catálogo seed.
model Permission {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(120) /// p.ej. "patient.read", "rx.sign".
  resource  String   @db.VarChar(60)
  action    String   @db.VarChar(40)
  createdAt DateTime @default(now()) @db.Timestamptz()

  rolePermissions RolePermission[]

  @@schema("public")
}

/// TDR §6.2 — n:m role↔permission con efecto allow/deny.
model RolePermission {
  roleId       String           @db.Uuid
  permissionId String           @db.Uuid
  effect       PermissionEffect @default(ALLOW)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@schema("public")
}

/// TDR §6.2 — un usuario tiene roles distintos por organización (ABAC dim. tenant).
/// 4NF: descompone MVD usuario↔(organización, rol).
model UserOrganizationRole {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  organizationId String    @db.Uuid
  roleId         String    @db.Uuid
  validFrom      DateTime  @default(now()) @db.Timestamptz()
  validTo        DateTime? @db.Timestamptz()

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId, roleId])
  @@index([organizationId])
  @@schema("public")
}

/// TDR §6.3 — log de auditoría append-only. En schema "audit" para aislar privilegios.
model AuditLog {
  id              BigInt      @id @default(autoincrement())
  occurredAt      DateTime    @default(now()) @db.Timestamptz()
  userId          String?     @db.Uuid
  organizationId  String?     @db.Uuid
  establishmentId String?     @db.Uuid
  ip              String?     @db.Inet
  userAgent       String?     @db.VarChar(400)
  action          AuditAction
  entity          String      @db.VarChar(80)
  entityId        String?     @db.VarChar(80)
  beforeJson      Json?
  afterJson       Json?
  justification   String?     @db.Text /// break-the-glass, eliminación.
  /// US-2.8 - SHA-256 de (id|prevHash|action|entity|entityId|beforeJson|afterJson|userId|occurredAt).
  /// Permite verificar integridad de la cadena append-only.
  signatureHash   String?     @db.VarChar(120)
  /// US-2.8 - hash del registro previo en la cadena (anti-tamper). NULL = primer registro.
  prevHash        String?     @db.VarChar(120)

  @@index([entity, entityId])
  @@index([userId, occurredAt])
  @@index([organizationId, occurredAt])
  @@schema("audit")
}

// =============================================================================
// 3. CATÁLOGOS DE PERSONAS  (TDR §7.2)
// =============================================================================

/// TDR §7.2 / §27.3 — tipo de documento de identidad por país.
model IdentifierType {
  id          String    @id @default(uuid()) @db.Uuid
  countryId   String    @db.Uuid
  code        String    @db.VarChar(20) /// DUI, NIT, NIE...
  name        String    @db.VarChar(80)
  validatorFn String?   @db.VarChar(80) /// nombre función SQL: validate_dui, validate_nit.
  active      Boolean   @default(true)
  validFrom   DateTime  @default(now()) @db.Date
  validTo     DateTime? @db.Date
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()

  country     Country             @relation(fields: [countryId], references: [id], onDelete: Cascade)
  identifiers PatientIdentifier[]

  @@unique([countryId, code])
  @@schema("public")
}

/// TDR §7.2 — género (identidad de género). Catálogo separado del sexo biológico (4NF).
model Gender {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(20)
  name      String    @db.VarChar(80)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patients Patient[]

  @@schema("public")
}

/// TDR §7.2 — sexo biológico al nacer.
model BiologicalSex {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(20) /// M, F, I (intersex), U (unknown).
  name      String    @db.VarChar(80)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patients Patient[]

  @@schema("public")
}

/// TDR §7.2 — estado civil.
model MaritalStatus {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(20)
  name      String    @db.VarChar(80)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patients Patient[]

  @@schema("public")
}

/// TDR §7.2 — etnia (parametrizable por país).
model Ethnicity {
  id        String    @id @default(uuid()) @db.Uuid
  countryId String?   @db.Uuid /// null = global.
  code      String    @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patientLinks PatientEthnicity[]

  @@unique([countryId, code])
  @@schema("public")
}

/// TDR §7.2 — nivel educativo.
model EducationLevel {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  ordinal   Int /// orden creciente para reportería.
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patients Patient[]

  @@schema("public")
}

/// TDR §7.2 — ocupación CIUO.
model Occupation {
  id        String    @id @default(uuid()) @db.Uuid
  ciuoCode  String    @unique @db.VarChar(20)
  name      String    @db.VarChar(200)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patients Patient[]

  @@schema("public")
}

/// TDR §7.2 — religión / culto.
model Religion {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patientLinks PatientReligion[]

  @@schema("public")
}

/// TDR §7.2 — idioma.
model Language {
  id        String    @id @default(uuid()) @db.Uuid
  isoCode   String    @unique @db.VarChar(10) /// ISO 639-3.
  name      String    @db.VarChar(80)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  patientLinks PatientLanguage[]

  @@schema("public")
}

// =============================================================================
// 4. CATÁLOGOS CLÍNICOS  (TDR §7.3)
// =============================================================================

/// TDR §7.3.1 — tipo de paciente (ambulatorio, hospitalizado, emergencia...).
model PatientType {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  encounters Encounter[]

  @@schema("public")
}

/// TDR §7.3.1 — categoría de paciente (privado, ISSS, MINSAL, FOSALUD...).
model PatientCategory {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  encounters Encounter[]

  @@schema("public")
}

/// TDR §7.3.1 — clasificación etaria (neonato, lactante...).
model AgeBand {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique @db.VarChar(30)
  name      String    @db.VarChar(80)
  minDays   Int
  maxDays   Int? /// null = sin límite superior.
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  @@schema("public")
}

/// TDR §7.3.4 — especialidad médica.
model MedicalSpecialty {
  id        String    @id @default(uuid()) @db.Uuid
  parentId  String?   @db.Uuid /// sub-especialidad.
  code      String    @unique @db.VarChar(40)
  name      String    @db.VarChar(120)
  active    Boolean   @default(true)
  validFrom DateTime  @default(now()) @db.Date
  validTo   DateTime? @db.Date
  version   Int       @default(1)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  parent   MedicalSpecialty?  @relation("SpecialtyTree", fields: [parentId], references: [id], onDelete: Restrict)
  children MedicalSpecialty[] @relation("SpecialtyTree")
  services ServiceUnit[]
  /// Wave 1 cont. — bindings de plantillas SOAP por especialidad (ADR-0008).
  templateBindings TemplateSpecialtyBinding[]

  @@schema("public")
}

/// TDR §7.3.4 — servicio/unidad funcional (UCI, sala de partos, consulta externa).
model ServiceUnit {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  establishmentId String   @db.Uuid
  specialtyId     String?  @db.Uuid
  code            String   @db.VarChar(40)
  name            String   @db.VarChar(120)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  establishment Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  specialty     MedicalSpecialty?  @relation(fields: [specialtyId], references: [id], onDelete: SetNull)
  beds          Bed[]
  encounters    Encounter[]
  triages       TriageEvaluation[]

  @@unique([establishmentId, code])
  @@schema("public")
}

/// TDR §7.3.2 — sistema de codificación clínica (CIE-10, CIE-11, SNOMED CT, LOINC, CIAP-2).
model CodeSystem {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(40) /// ICD10, ICD11, SNOMED, LOINC, CIAP2, ATC.
  name      String   @db.VarChar(120)
  version   String   @db.VarChar(40)
  uri       String?  @db.VarChar(200)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  concepts ClinicalConcept[]

  @@schema("public")
}

/// TDR §7.3.2 — concepto clínico genérico (diagnóstico, procedimiento, observación, prueba).
/// 4NF: una sola tabla evita duplicar columnas por sistema. Mapeos cruzados en ClinicalConceptMap.
model ClinicalConcept {
  id           String    @id @default(uuid()) @db.Uuid
  codeSystemId String    @db.Uuid
  code         String    @db.VarChar(60)
  display      String    @db.VarChar(400)
  isAbstract   Boolean   @default(false)
  active       Boolean   @default(true)
  validFrom    DateTime  @default(now()) @db.Date
  validTo      DateTime? @db.Date
  version      Int       @default(1)
  createdAt    DateTime  @default(now()) @db.Timestamptz()

  codeSystem CodeSystem           @relation(fields: [codeSystemId], references: [id], onDelete: Restrict)
  mapsFrom   ClinicalConceptMap[] @relation("MapFrom")
  mapsTo     ClinicalConceptMap[] @relation("MapTo")

  @@unique([codeSystemId, code])
  @@index([codeSystemId])
  @@schema("public")
}

/// TDR §7.3.2 — mapeo cruzado entre sistemas de codificación.
model ClinicalConceptMap {
  id            String   @id @default(uuid()) @db.Uuid
  fromConceptId String   @db.Uuid
  toConceptId   String   @db.Uuid
  equivalence   String   @db.VarChar(40) /// equivalent, broader, narrower, related.
  createdAt     DateTime @default(now()) @db.Timestamptz()

  from ClinicalConcept @relation("MapFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  to   ClinicalConcept @relation("MapTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([fromConceptId, toConceptId, equivalence])
  @@schema("public")
}

// =============================================================================
// 5. MPI / PACIENTE  (TDR §8.1)
// =============================================================================

/// TDR §8.1 — paciente único en el MPI institucional.
/// Soft delete vía `deletedAt` (TDR §5.5 regla 7).
model Patient {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @db.Uuid /// organización propietaria del registro maestro.
  mrn                String    @db.VarChar(40) /// medical record number interno.
  firstName          String    @db.VarChar(120)
  middleName         String?   @db.VarChar(120)
  lastName           String    @db.VarChar(120)
  secondLastName     String?   @db.VarChar(120)
  preferredName      String?   @db.VarChar(120)
  birthDate          DateTime? @db.Date
  birthDateEstimated Boolean   @default(false)
  birthPlaceGeoId    String?   @db.Uuid
  biologicalSexId    String    @db.Uuid
  genderId           String?   @db.Uuid
  maritalStatusId    String?   @db.Uuid
  educationLevelId   String?   @db.Uuid
  occupationId       String?   @db.Uuid
  bloodTypeAbo       String?   @db.VarChar(3) /// A, B, AB, O.
  bloodRh            String?   @db.VarChar(3) /// +, -.
  isUnknown          Boolean   @default(false) /// NN.
  unknownLabel       String?   @db.VarChar(40) /// NN-AAAAMMDD-NNN.
  motherPatientId    String?   @db.Uuid /// vínculo neonato↔madre.
  active             Boolean   @default(true)
  /// AI(8018) GSRN — asignado automáticamente al confirmar admisión hospitalaria (US.F2.6.1).
  gsrn               String?   @unique @db.Char(18)
  deletedAt          DateTime? @db.Timestamptz()
  deletedBy          String?   @db.Uuid
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  createdBy          String?   @db.Uuid
  updatedAt          DateTime  @updatedAt @db.Timestamptz()
  updatedBy          String?   @db.Uuid

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  biologicalSex  BiologicalSex   @relation(fields: [biologicalSexId], references: [id], onDelete: Restrict)
  gender         Gender?         @relation(fields: [genderId], references: [id], onDelete: SetNull)
  maritalStatus  MaritalStatus?  @relation(fields: [maritalStatusId], references: [id], onDelete: SetNull)
  educationLevel EducationLevel? @relation(fields: [educationLevelId], references: [id], onDelete: SetNull)
  occupation     Occupation?     @relation(fields: [occupationId], references: [id], onDelete: SetNull)
  mother         Patient?        @relation("MotherChild", fields: [motherPatientId], references: [id], onDelete: SetNull)
  children       Patient[]       @relation("MotherChild")

  identifiers       PatientIdentifier[]
  addresses         PatientAddress[]
  phones            PatientPhone[]
  emails            PatientEmail[]
  emergencyContacts PatientEmergencyContact[]
  ethnicities       PatientEthnicity[]
  religions         PatientReligion[]
  languages         PatientLanguage[]
  allergies         PatientAllergy[]
  consents          PatientConsent[]
  mergeHistoryFrom  PatientMerge[]            @relation("MergeFrom")
  mergeHistoryTo    PatientMerge[]            @relation("MergeTo")
  encounters        Encounter[]
  triages           TriageEvaluation[]
  vaccinations      PatientVaccination[]
  deathCertificate  DeathCertificate?
  /// Wave 1 cont. — FHIR R4 v2.
  allergyIntolerances AllergyIntolerance[]
  problemListItems    ProblemListItem[]
  /// US.F2.6.37-40 — historial de pulseras GSRN.
  gsrnHistory GsrnHistory[]

  @@unique([organizationId, mrn])
  @@index([lastName, firstName])
  @@index([birthDate])
  @@schema("public")
}

/// US.F2.6.37-40 — historial inmutable de pulseras GSRN por paciente.
/// Registra cada emisión y revocación. Una sola fila ACTIVE por paciente/org.
model GsrnHistory {
  id               String    @id @default(uuid()) @db.Uuid
  patientId        String    @db.Uuid
  organizationId   String    @db.Uuid
  gsrn             String    @unique @db.Char(18)
  status           GsrnStatus @default(ACTIVE)
  assignedAt       DateTime  @default(now()) @db.Timestamptz()
  revokedAt        DateTime? @db.Timestamptz()
  assignedById     String?   @db.Uuid
  revokedById      String?   @db.Uuid
  motivoRevocacion String?   @db.Text
  createdAt        DateTime  @default(now()) @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([organizationId])
  @@index([gsrn])
  @@schema("public")
}

enum GsrnStatus {
  ACTIVE
  REVOKED

  @@schema("public")
}

/// TDR §14.5 - catalogo de vacunas (PAI SV + universal).
model Vaccine {
  id           String   @id @default(uuid()) @db.Uuid
  countryId    String?  @db.Uuid /// null = global
  code         String   @db.VarChar(40) /// BCG, HepB, DPT, etc.
  name         String   @db.VarChar(120)
  manufacturer String?  @db.VarChar(120)
  routeOfAdmin String?  @db.VarChar(40) /// IM, SC, oral, intradermal
  scheduleNote String?  @db.Text /// edades recomendadas
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  vaccinations PatientVaccination[]

  @@unique([countryId, code])
  @@schema("public")
}

/// TDR §14.5 - registro de vacunacion aplicada al paciente.
model PatientVaccination {
  id                String    @id @default(uuid()) @db.Uuid
  patientId         String    @db.Uuid
  vaccineId         String    @db.Uuid
  organizationId    String    @db.Uuid
  establishmentId   String?   @db.Uuid
  doseNumber        Int       @default(1)
  administeredAt    DateTime  @db.Timestamptz()
  lotNumber         String?   @db.VarChar(60)
  expirationDate    DateTime? @db.Date
  anatomicalSite    String?   @db.VarChar(40)
  administeredById  String?   @db.Uuid /// User id
  reactionsObserved String?   @db.Text
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  createdBy         String?   @db.Uuid

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  vaccine      Vaccine      @relation(fields: [vaccineId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([patientId])
  @@index([vaccineId])
  @@schema("public")
}

/// TDR §8.7 - certificado medico de defuncion digital.
/// 1:1 con Patient (un certificado por fallecimiento).
model DeathCertificate {
  id                        String    @id @default(uuid()) @db.Uuid
  patientId                 String    @unique @db.Uuid
  encounterId               String?   @db.Uuid /// encounter en el que se constato
  organizationId            String    @db.Uuid
  establishmentId           String    @db.Uuid
  occurredAt                DateTime  @db.Timestamptz() /// fecha y hora del fallecimiento
  certifiedById             String    @db.Uuid /// medico que certifica (User)
  certifiedAt               DateTime  @default(now()) @db.Timestamptz()
  /// Causas CIE-10 (codigo + descripcion libre porque puede no estar en ClinicalConcept aun).
  basicCauseCode            String    @db.VarChar(20) /// causa basica
  basicCauseDesc            String    @db.VarChar(300)
  intermediateCauseCode     String?   @db.VarChar(20)
  intermediateCauseDesc     String?   @db.VarChar(300)
  directCauseCode           String?   @db.VarChar(20)
  directCauseDesc           String?   @db.VarChar(300)
  contributingCauses        String?   @db.Text
  manner                    String?   @db.VarChar(40) /// natural, accident, suicide, homicide, undetermined
  notifiedToCivilRegistryAt DateTime? @db.Timestamptz()
  notes                     String?   @db.Text
  createdAt                 DateTime  @default(now()) @db.Timestamptz()
  updatedAt                 DateTime  @updatedAt @db.Timestamptz()

  patient   Patient    @relation(fields: [patientId], references: [id])
  encounter Encounter? @relation(fields: [encounterId], references: [id])

  @@index([organizationId, occurredAt])
  @@schema("public")
}

/// TDR §8.1 — identificador del paciente (DUI, NIT, pasaporte). 4NF: relación independiente.
/// Un paciente puede tener N identificadores; cada tipo puede repetirse históricamente.
model PatientIdentifier {
  id               String                @id @default(uuid()) @db.Uuid
  patientId        String                @db.Uuid
  identifierTypeId String                @db.Uuid
  kind             PatientIdentifierKind
  value            String                @db.VarChar(80)
  countryOfIssue   String?               @db.Uuid
  issuedAt         DateTime?             @db.Date
  expiresAt        DateTime?             @db.Date
  isPrimary        Boolean               @default(false)
  createdAt        DateTime              @default(now()) @db.Timestamptz()

  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  identifierType IdentifierType @relation(fields: [identifierTypeId], references: [id], onDelete: Restrict)

  @@unique([identifierTypeId, value])
  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — direcciones (multivalor). 4NF: tabla independiente vs teléfonos/emails.
model PatientAddress {
  id            String    @id @default(uuid()) @db.Uuid
  patientId     String    @db.Uuid
  geoDivisionId String?   @db.Uuid
  line1         String    @db.VarChar(300)
  line2         String?   @db.VarChar(300)
  postalCode    String?   @db.VarChar(20)
  isPrimary     Boolean   @default(false)
  validFrom     DateTime  @default(now()) @db.Date
  validTo       DateTime? @db.Date
  createdAt     DateTime  @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — teléfonos (multivalor independiente).
model PatientPhone {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  phone     String   @db.VarChar(40)
  kind      String   @db.VarChar(20) /// móvil, casa, trabajo.
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — correos (multivalor independiente).
model PatientEmail {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  email     String   @db.Citext
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §8.1 — contactos de emergencia.
model PatientEmergencyContact {
  id           String   @id @default(uuid()) @db.Uuid
  patientId    String   @db.Uuid
  fullName     String   @db.VarChar(200)
  relationship String   @db.VarChar(60)
  phone        String?  @db.VarChar(40)
  email        String?  @db.Citext
  priority     Int      @default(1)
  createdAt    DateTime @default(now()) @db.Timestamptz()

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔etnia (multivalor 4NF independiente de idiomas y religiones).
model PatientEthnicity {
  patientId   String   @db.Uuid
  ethnicityId String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz()

  patient   Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ethnicity Ethnicity @relation(fields: [ethnicityId], references: [id], onDelete: Restrict)

  @@id([patientId, ethnicityId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔religión (multivalor 4NF independiente).
model PatientReligion {
  patientId  String   @db.Uuid
  religionId String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz()

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  religion Religion @relation(fields: [religionId], references: [id], onDelete: Restrict)

  @@id([patientId, religionId])
  @@schema("public")
}

/// TDR §7.2 / §8.1 — paciente↔idioma (multivalor 4NF independiente).
model PatientLanguage {
  patientId   String   @db.Uuid
  languageId  String   @db.Uuid
  isPreferred Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Restrict)

  @@id([patientId, languageId])
  @@schema("public")
}

/// TDR §8.1 — alergia conocida del paciente. 4NF: independiente de idiomas, etnias, religiones.
model PatientAllergy {
  id                 String    @id @default(uuid()) @db.Uuid
  patientId          String    @db.Uuid
  substanceConceptId String?   @db.Uuid /// referencia a ClinicalConcept (RxNorm/ATC/SNOMED).
  substanceText      String    @db.VarChar(200) /// texto libre si no hay concepto.
  reaction           String?   @db.VarChar(400)
  severity           String    @db.VarChar(20) /// mild, moderate, severe, life-threatening.
  onsetDate          DateTime? @db.Date
  verified           Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now()) @db.Timestamptz()
  createdBy          String?   @db.Uuid
  updatedAt          DateTime  @updatedAt @db.Timestamptz()
  updatedBy          String?   @db.Uuid

  /// Wave 1 cont. · ADR-0007 — enlace opcional v1->v2 (allergy_intolerance).
  /// NULL hasta que el médico re-declara la alergia en la UI FHIR R4.
  allergyIntoleranceId String? @db.Uuid

  patient             Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergyIntolerance  AllergyIntolerance? @relation(fields: [allergyIntoleranceId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([allergyIntoleranceId])
  @@schema("public")
}

/// TDR §6.4 / §8.1 — consentimientos del paciente (datos, telemedicina, transfusión, MPI cross-org).
model PatientConsent {
  id         String    @id @default(uuid()) @db.Uuid
  patientId  String    @db.Uuid
  purpose    String    @db.VarChar(80) /// data_processing, mpi_cross_org, transfusion, ...
  granted    Boolean
  scope      Json? /// detalles parametrizables (organizaciones, finalidades).
  signedAt   DateTime  @default(now()) @db.Timestamptz()
  signedById String?   @db.Uuid /// usuario que registra el consentimiento.
  validFrom  DateTime  @db.Timestamptz()
  validTo    DateTime? @db.Timestamptz()
  revokedAt  DateTime? @db.Timestamptz()

  patient  Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  signedBy User?   @relation("ConsentAuthor", fields: [signedById], references: [id], onDelete: SetNull)

  @@index([patientId, purpose])
  @@schema("public")
}

/// TDR §8.1 — historial de fusiones MPI (cuando se identifica un NN o se descubre duplicado).
model PatientMerge {
  id            String   @id @default(uuid()) @db.Uuid
  fromPatientId String   @db.Uuid /// registro absorbido (lógicamente eliminado).
  toPatientId   String   @db.Uuid /// registro superviviente.
  reason        String   @db.VarChar(200)
  mergedAt      DateTime @default(now()) @db.Timestamptz()
  mergedBy      String?  @db.Uuid

  from Patient @relation("MergeFrom", fields: [fromPatientId], references: [id], onDelete: Restrict)
  to   Patient @relation("MergeTo", fields: [toPatientId], references: [id], onDelete: Restrict)

  @@index([toPatientId])
  @@schema("public")
}

// =============================================================================
// 6. ADT — ADMISIÓN, ALTAS, TRASLADOS  (TDR §8)
// =============================================================================

/// TDR §8.6 — cama (recurso físico).
model Bed {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  establishmentId String    @db.Uuid
  serviceUnitId   String    @db.Uuid
  code            String    @db.VarChar(40)
  room            String?   @db.VarChar(40)
  status          BedStatus @default(FREE)
  isolation       String?   @db.VarChar(40) /// contacto, gotitas, respiratorio, protector.
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  establishment Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  serviceUnit   ServiceUnit     @relation(fields: [serviceUnitId], references: [id], onDelete: Restrict)
  assignments   BedAssignment[]

  @@unique([establishmentId, code])
  @@index([status])
  @@schema("public")
}

/// TDR §8.3 — encuentro asistencial (admisión / consulta / emergencia / hospitalización).
/// Es la unidad transaccional que aglutina ADT en una visita.
model Encounter {
  id                 String         @id @default(uuid()) @db.Uuid
  countryId          String         @db.Uuid
  organizationId     String         @db.Uuid
  establishmentId    String         @db.Uuid
  serviceUnitId      String?        @db.Uuid
  patientId          String         @db.Uuid
  patientTypeId      String?        @db.Uuid
  patientCategoryId  String?        @db.Uuid
  admissionType      AdmissionType
  encounterNumber    String         @db.VarChar(40) /// identificador legible "ADM-2026-000123".
  admittedAt         DateTime       @db.Timestamptz()
  dischargedAt       DateTime?      @db.Timestamptz()
  dischargeType      DischargeType?
  primaryDiagnosisId String?        @db.Uuid /// ClinicalConcept (CIE-10/11).
  currencyId         String         @db.Uuid
  exchangeRateToFunc Decimal        @db.Decimal(18, 8)
  createdAt          DateTime       @default(now()) @db.Timestamptz()
  createdBy          String?        @db.Uuid
  updatedAt          DateTime       @updatedAt @db.Timestamptz()
  updatedBy          String?        @db.Uuid

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  establishment   Establishment    @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  serviceUnit     ServiceUnit?     @relation(fields: [serviceUnitId], references: [id], onDelete: SetNull)
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  patientType     PatientType?     @relation(fields: [patientTypeId], references: [id], onDelete: SetNull)
  patientCategory PatientCategory? @relation(fields: [patientCategoryId], references: [id], onDelete: SetNull)
  currency        Currency         @relation("EncounterCurrency", fields: [currencyId], references: [id], onDelete: Restrict)

  bedAssignments     BedAssignment[]
  transfers          EncounterTransfer[]
  triages            TriageEvaluation[]
  deathCertificates  DeathCertificate[]

  @@unique([organizationId, encounterNumber])
  @@index([patientId])
  @@index([organizationId, admittedAt])
  @@schema("public")
}

/// TDR §8.3 / §8.4 — asignación de cama (historiable). 4NF: separa la MVD encuentro↔cama.
model BedAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  encounterId String    @db.Uuid
  bedId       String    @db.Uuid
  assignedAt  DateTime  @default(now()) @db.Timestamptz()
  releasedAt  DateTime? @db.Timestamptz()
  reason      String?   @db.VarChar(200)
  createdBy   String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  bed       Bed       @relation(fields: [bedId], references: [id], onDelete: Restrict)

  @@index([encounterId])
  @@index([bedId, assignedAt])
  @@schema("public")
}

/// TDR §8.4 — traslado interno (cambio de servicio o nivel de cuidado).
model EncounterTransfer {
  id            String   @id @default(uuid()) @db.Uuid
  encounterId   String   @db.Uuid
  fromServiceId String?  @db.Uuid
  toServiceId   String   @db.Uuid
  fromBedId     String?  @db.Uuid
  toBedId       String?  @db.Uuid
  reason        String   @db.VarChar(200)
  occurredAt    DateTime @default(now()) @db.Timestamptz()
  createdBy     String?  @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz()

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@schema("public")
}

// =============================================================================
// 7. TRIAGE MANCHESTER  (TDR §9)
// =============================================================================

/// TDR §9.1 / §9.3 — nivel Manchester parametrizable por organización.
model TriageLevel {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  color          TriageColor
  priority       Int /// 1=rojo .. 5=azul.
  name           String      @db.VarChar(40)
  maxWaitMinutes Int
  uiColorHex     String?     @db.VarChar(9)
  active         Boolean     @default(true)
  validFrom      DateTime    @default(now()) @db.Date
  validTo        DateTime?   @db.Date
  version        Int         @default(1)
  createdAt      DateTime    @default(now()) @db.Timestamptz()
  updatedAt      DateTime    @updatedAt @db.Timestamptz()

  flowcharts     TriageFlowchart[]
  discriminators TriageDiscriminator[]
  evaluations    TriageEvaluation[]

  @@unique([organizationId, color])
  @@unique([organizationId, priority])
  @@schema("public")
}

/// TDR §9.2 / §9.3 — flujograma de presentación Manchester (52 estándar + locales).
model TriageFlowchart {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  code           String    @db.VarChar(60) /// chest_pain, dyspnea, ...
  name           String    @db.VarChar(200)
  isPediatric    Boolean   @default(false)
  defaultLevelId String?   @db.Uuid /// nivel por defecto si ningún discriminador.
  active         Boolean   @default(true)
  validFrom      DateTime  @default(now()) @db.Date
  validTo        DateTime? @db.Date
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()

  defaultLevel   TriageLevel?               @relation(fields: [defaultLevelId], references: [id], onDelete: SetNull)
  discriminators TriageDiscriminator[]
  vitalSigns     TriageFlowchartVitalSign[]
  evaluations    TriageEvaluation[]

  @@unique([organizationId, code])
  @@schema("public")
}

/// TDR §9.2 — discriminador clínico (vía aérea, shock, dolor severo...).
/// El primer discriminador positivo determina el nivel.
model TriageDiscriminator {
  id            String    @id @default(uuid()) @db.Uuid
  flowchartId   String    @db.Uuid
  resultLevelId String    @db.Uuid
  code          String    @db.VarChar(60)
  text          String    @db.VarChar(400)
  ordinal       Int /// orden de evaluación dentro del flujograma.
  active        Boolean   @default(true)
  validFrom     DateTime  @default(now()) @db.Date
  validTo       DateTime? @db.Date
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  flowchart   TriageFlowchart          @relation(fields: [flowchartId], references: [id], onDelete: Cascade)
  resultLevel TriageLevel              @relation(fields: [resultLevelId], references: [id], onDelete: Restrict)
  hits        TriageDiscriminatorHit[]

  @@unique([flowchartId, ordinal])
  @@index([flowchartId])
  @@schema("public")
}

/// TDR §9.3 — signos vitales obligatorios por flujograma. 4NF: independiente de discriminadores.
model TriageFlowchartVitalSign {
  flowchartId String  @db.Uuid
  vitalCode   String  @db.VarChar(40) /// SpO2, BP, ECG, GLUC, GCS, PAIN, TEMP, HR, RR.
  required    Boolean @default(true)

  flowchart TriageFlowchart @relation(fields: [flowchartId], references: [id], onDelete: Cascade)

  @@id([flowchartId, vitalCode])
  @@schema("public")
}

/// TDR §9.2 — evaluación de triage de un encuentro.
model TriageEvaluation {
  id                     String       @id @default(uuid()) @db.Uuid
  countryId              String       @db.Uuid
  organizationId         String       @db.Uuid
  establishmentId        String       @db.Uuid
  serviceUnitId          String?      @db.Uuid
  patientId              String       @db.Uuid
  encounterId            String?      @db.Uuid
  flowchartId            String       @db.Uuid
  assignedLevelId        String       @db.Uuid /// nivel resultante.
  systemSuggestedLevelId String?      @db.Uuid /// lo que el sistema sugirió.
  overrideJustification  String?      @db.Text
  status                 TriageStatus @default(IN_PROGRESS)
  startedAt              DateTime     @default(now()) @db.Timestamptz()
  /// ADR-0005 / US-6.6 — instante exacto en que el triador asignó el nivel
  /// Manchester. Fuente de verdad del cronómetro server-authoritative.
  levelAssignedAt        DateTime?    @db.Timestamptz()
  /// ADR-0005 / US-6.6 — deadline calculado = levelAssignedAt + maxWaitMinutes.
  /// Lo computa el servidor en la asignación; la UI sólo presenta.
  deadlineAt             DateTime?    @db.Timestamptz()
  /// ADR-0005 — timestamp cuando el job Inngest emitió MaxWaitWarning80.
  /// UPDATE condicional WHERE warning80EmittedAt IS NULL garantiza idempotencia.
  warning80EmittedAt     DateTime?    @db.Timestamptz()
  /// ADR-0005 — timestamp cuando el job Inngest emitió MaxWaitExceeded.
  exceededEmittedAt      DateTime?    @db.Timestamptz()
  /// US-6.6 — instante en que un clínico tomó al paciente (mide SLI
  /// triage.attendedWithinMaxWait).
  attendedAt             DateTime?    @db.Timestamptz()
  /// US-6.6 — Left Without Being Seen — paciente abandonó antes de atención.
  lwbsAt                 DateTime?    @db.Timestamptz()
  completedAt            DateTime?    @db.Timestamptz()
  reTriageOfId           String?      @db.Uuid /// si es re-triage, apunta al original.
  /// US-6.8 — justificación obligatoria cuando el re-triage es manual.
  retriageReason         String?      @db.Text
  /// US-6.8 — discriminador disparador del re-triage automático
  /// (vital deteriorado, dolor escalado, warning80%).
  retriageTrigger        String?      @db.VarChar(40)
  triagistUserId         String?      @db.Uuid
  createdAt              DateTime     @default(now()) @db.Timestamptz()
  createdBy              String?      @db.Uuid
  updatedAt              DateTime     @updatedAt @db.Timestamptz()
  updatedBy              String?      @db.Uuid

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  establishment   Establishment      @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  serviceUnit     ServiceUnit?       @relation(fields: [serviceUnitId], references: [id], onDelete: SetNull)
  patient         Patient            @relation(fields: [patientId], references: [id], onDelete: Restrict)
  encounter       Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  flowchart       TriageFlowchart    @relation(fields: [flowchartId], references: [id], onDelete: Restrict)
  assignedLevel   TriageLevel        @relation(fields: [assignedLevelId], references: [id], onDelete: Restrict)
  reTriageOf      TriageEvaluation?  @relation("ReTriage", fields: [reTriageOfId], references: [id], onDelete: SetNull)
  reTriageOf_back TriageEvaluation[] @relation("ReTriage")

  vitalSigns        TriageVitalSign[]
  discriminatorHits TriageDiscriminatorHit[]

  @@index([patientId])
  @@index([organizationId, startedAt])
  @@index([assignedLevelId, startedAt])
  /// ADR-0005 — el job Inngest tickTriageDeadlines busca por deadline ascendente.
  @@index([organizationId, status, deadlineAt])
  @@schema("public")
}

/// TDR §9.2 — signos vitales medidos durante el triage. 4NF: separación por tipo en filas.
model TriageVitalSign {
  id           String   @id @default(uuid()) @db.Uuid
  evaluationId String   @db.Uuid
  vitalCode    String   @db.VarChar(40)
  valueNumeric Decimal? @db.Decimal(10, 3)
  valueText    String?  @db.VarChar(120)
  unit         String?  @db.VarChar(20)
  measuredAt   DateTime @default(now()) @db.Timestamptz()

  evaluation TriageEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, vitalCode, measuredAt])
  @@index([evaluationId])
  @@schema("public")
}

/// TDR §9.2 — registro de discriminadores positivos durante la evaluación.
model TriageDiscriminatorHit {
  id              String   @id @default(uuid()) @db.Uuid
  evaluationId    String   @db.Uuid
  discriminatorId String   @db.Uuid
  positive        Boolean
  observedAt      DateTime @default(now()) @db.Timestamptz()
  notes           String?  @db.VarChar(400)

  evaluation    TriageEvaluation    @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  discriminator TriageDiscriminator @relation(fields: [discriminatorId], references: [id], onDelete: Restrict)

  @@unique([evaluationId, discriminatorId])
  @@schema("public")
}

// =============================================================================
// §6 / ADR-0005 — Outbox de eventos de dominio (transaccional)
// El job tickTriageDeadlines y otros publishers escriben aquí dentro de la
// misma transacción que muta el aggregate. Un worker batch despacha hacia
// Supabase Realtime / Sentry breadcrumbs. Idempotencia por dedup_key.
// =============================================================================

/// ADR-0005 — outbox transaccional de eventos de dominio.
/// Indexada por (organizationId, occurredAt) para draining; (dedupKey unique)
/// para idempotencia bajo reintentos del job Inngest.
model DomainEvent {
  id             BigInt    @id @default(autoincrement())
  organizationId String    @db.Uuid
  aggregate      String    @db.VarChar(60) /// "triage_encounter", "lis_result"...
  aggregateId    String    @db.VarChar(80)
  eventType      String    @db.VarChar(80) /// "MaxWaitWarning80", "MaxWaitExceeded", "RetriageExecuted"...
  payload        Json
  /// Clave de deduplicación: aggregateId + eventType + bucketIso (`now hh:mm`).
  /// El UPDATE condicional del ticker garantiza emisión única pero esta key
  /// protege contra duplicados a nivel outbox si dos workers compiten.
  dedupKey       String    @unique @db.VarChar(160)
  occurredAt     DateTime  @default(now()) @db.Timestamptz()
  publishedAt    DateTime? @db.Timestamptz() /// NULL = pendiente de despacho.
  /// US-2.8 — para eventos críticos (MaxWaitExceeded, BackupVerified) anclamos
  /// al hash-chain de audit (ADR-0002). El auditEntryId enlaza con AuditLog.id.
  auditEntryId   BigInt?

  @@index([organizationId, occurredAt])
  @@index([publishedAt])
  @@index([aggregate, aggregateId])
  @@schema("public")
}

// =============================================================================
// §14 — EHR / SOAP Clinical Notes (Wave 1, Team Bravo)
// ADR-0002: append-only con `Addendum` encadenado, anclado al hash-chain de
// auditoría existente. UPDATE/DELETE bloqueados por trigger DB sobre nota
// firmada; sólo el state Drafted permite UPDATE.
// =============================================================================

/// US-11.x — tipo de nota clínica.
enum SoapNoteType {
  SOAP
  EVOLUTION
  INTERCONSULT
  DISCHARGE
  DEATH

  @@schema("public")
}

/// US-11.x — estado de la nota. Solo Drafted permite UPDATE.
enum SoapNoteStatus {
  Drafted
  Signed

  @@schema("public")
}

/// US-11.5 — motivo del adendum (Ley Firma Electrónica SV).
enum AddendumReason {
  MATERIAL_CORRECTION
  CLARIFICATION
  ADDITIONAL_INFO

  @@schema("public")
}

/// ADR-0006 — Discriminador del subject clínico que ancla una SoapNote.
/// 'encounter' = BC adt (Encounter ADT, default histórico).
/// 'outpatient_encounter' = BC ambulatory (ADR-0001).
/// Wave 2 sumará 'inpatient_stay', 'emergency_encounter', 'surgical_case'.
enum SoapNoteSubjectKind {
  encounter
  outpatient_encounter

  @@schema("public")
}

/// US-11.1 / US-11.2 / US-11.4 — agregado SoapNote.
/// Inmutable post-firma; trigger DB bloquea UPDATE/DELETE en estado Signed.
model SoapNote {
  id                 String         @id @default(uuid()) @db.Uuid
  organizationId     String         @db.Uuid
  /// ADR-0006 — Discriminador cross-BC del subject de la nota. Default
  /// preserva semántica histórica de filas pre-ADR-0006 (todas 'encounter').
  subjectKind        SoapNoteSubjectKind @default(encounter)
  /// ADR-0006 — Identidad opaca del subject clínico (encounterId ADT u
  /// outpatientEncounterId según `subjectKind`). El nombre físico
  /// `encounterId` se conserva para evitar migración destructiva en Sprint 1;
  /// rename físico a `subjectId` queda diferido a Wave 2 (cero impacto
  /// funcional). El campo se interpreta como `subjectId` en TS.
  encounterId        String         @db.Uuid
  patientId          String         @db.Uuid /// denormalizado para queries longitudinales (US-11.7).
  type               SoapNoteType   @default(SOAP)
  status             SoapNoteStatus @default(Drafted)
  /// S/O/A/P estructurado. Persistido como JSON normalizado por canonicalizeSoapPayload().
  content            Json
  effectiveAt        DateTime       @default(now()) @db.Timestamptz() /// momento clínico (≠ signedAt).
  authorId           String         @db.Uuid
  signedAt           DateTime?      @db.Timestamptz()
  /// sha256(canonicalSoapPayload). Sólo presente en Signed.
  contentHash        String?        @db.VarChar(120)
  /// Referencia opaca a la firma. Wave 1: token RFC 3161 (FreeTSA/DigiCert).
  /// Wave 2: ID en signature_event (HSM/PKI). TODO[Wave 2 PKI/HSM].
  signatureRef       String?        @db.VarChar(500)
  signatureProvider  String?        @db.VarChar(40) /// 'freetsa' | 'digicert' | 'pgcrypto-stub' | (Wave 2: 'hsm-pkcs11')
  /// FK al audit_log de la entrada NoteSigned. Ancla la cadena Merkle global.
  auditEntryId       BigInt?

  /// Wave 1 cont. · ADR-0008 — plantilla aplicada (snapshot inmutable).
  templateVersionId  String?        @db.Uuid
  /// Snapshot del schema de la TemplateVersion congelado al instanciar.
  templateSnapshot   Json?
  templateAppliedAt  DateTime?      @db.Timestamptz()
  /// Marcadores copy-forward por sección S/O/A/P (ADR-0008 §D-AS-09).
  copyForwardFlags   Json?

  createdAt          DateTime       @default(now()) @db.Timestamptz()
  createdBy          String?        @db.Uuid
  updatedAt          DateTime       @updatedAt @db.Timestamptz()
  updatedBy          String?        @db.Uuid

  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  templateVersion  SoapNoteTemplateVersion?  @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)

  diagnoses NoteDiagnosis[]
  addendums NoteAddendum[]

  /// ADR-0006 — unicidad ahora es por `(subjectKind, encounterId, type)`.
  /// Para `subjectKind='encounter'` queda funcionalmente equivalente al índice
  /// histórico `uniq_active_note_per_encounter_type` (idempotencia preservada).
  @@unique([subjectKind, encounterId, type], name: "uniq_active_note_per_subject_type")
  @@index([organizationId, signedAt])
  @@index([patientId, signedAt])
  @@index([encounterId])
  @@index([subjectKind, encounterId])
  @@map("clinical_note")
  @@schema("public")
}

/// US-11.5 — adendum encadenado por hash. Append-only.
model NoteAddendum {
  id                    String         @id @default(uuid()) @db.Uuid
  noteId                String         @db.Uuid
  organizationId        String         @db.Uuid
  authorId              String         @db.Uuid
  sequence              Int            /// 1..N
  reason                AddendumReason
  content               String         @db.Text
  /// sha256(canonicalAddendumPayload). Siempre presente (adendum nace firmado).
  contentHash           String         @db.VarChar(120)
  /// hash del adendum N-1 (NULL si sequence=1).
  previousAddendumHash  String?        @db.VarChar(120)
  signedAt              DateTime       @default(now()) @db.Timestamptz()
  signatureRef          String?        @db.VarChar(500)
  signatureProvider     String?        @db.VarChar(40)
  /// FK al audit_log de AddendumAppended.
  auditEntryId          BigInt?
  createdAt             DateTime       @default(now()) @db.Timestamptz()

  note SoapNote @relation(fields: [noteId], references: [id], onDelete: Restrict)

  @@unique([noteId, sequence])
  @@index([noteId])
  @@index([organizationId, signedAt])
  @@map("clinical_note_addendum")
  @@schema("public")
}

/// US-11.7 — diagnóstico CIE-10 asociado a la nota (snapshot de catálogo).
/// 4NF: encarna la relación N-aria nota↔código↔atributos (primary/chronic).
model NoteDiagnosis {
  id          String   @id @default(uuid()) @db.Uuid
  noteId      String   @db.Uuid
  /// Código CIE-10 (ej. "E11.9"). Validado por Zod en el contrato.
  code        String   @db.VarChar(10)
  /// Descripción cacheada del catálogo al momento de la firma (snapshot).
  description String   @db.VarChar(300)
  isPrimary   Boolean  @default(false)
  isChronic   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  note SoapNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, code])
  @@index([code])
  @@map("clinical_note_diagnosis")
  @@schema("public")
}

// =============================================================================
// §10 — Atención Ambulatoria (Wave 1, Team Alpha · BC `ambulatory`)
// ADR-0001: OutpatientEncounter es agregado raíz separado del Encounter ADT.
// Referencias a Patient y a User (provider) por id; RLS por organization_id.
// =============================================================================

/// US-10.1 — estado del slot dentro de la grilla del Schedule.
enum SlotStatus {
  Free
  Booked
  Blocked

  @@schema("public")
}

/// US-10.2 — ciclo de vida de la Appointment.
enum AppointmentStatus {
  Booked
  Confirmed
  CheckedIn
  InProgress
  Completed
  Cancelled
  NoShow
  Rescheduled

  @@schema("public")
}

/// ADR-0001 — estado del agregado raíz OutpatientEncounter.
enum OutpatientEncounterStatus {
  CheckedIn
  InConsult
  Completed
  Cancelled

  @@schema("public")
}

/// US-10.x — tipo funcional de la cita / slot.
enum AppointmentType {
  FIRST_VISIT
  FOLLOW_UP
  PROCEDURE
  TELEHEALTH /// placeholder Wave 1; integración telemedicina diferida.

  @@schema("public")
}

/// US-10.7 — tipo de incapacidad médica (TDR §10.3).
enum MedicalLeaveType {
  COMMON_ILLNESS
  WORK_ACCIDENT
  MATERNITY
  PATERNITY

  @@schema("public")
}

/// US-10.1 — agenda raíz por profesional/servicio (publicada N semanas adelante).
model Schedule {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  establishmentId String    @db.Uuid
  providerId      String    @db.Uuid /// User (médico) — JVPM validado en E7.
  serviceUnitId   String    @db.Uuid
  specialtyId     String?   @db.Uuid
  validFrom       DateTime  @db.Date
  validTo         DateTime? @db.Date
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  createdBy       String?   @db.Uuid
  updatedAt       DateTime  @updatedAt @db.Timestamptz()
  updatedBy       String?   @db.Uuid

  slots Slot[]

  @@index([organizationId, providerId, validFrom])
  @@index([serviceUnitId, validFrom])
  @@map("schedule")
  @@schema("public")
}

/// US-10.1 — slot concreto (instancia de plantilla expandida a fecha real).
model Slot {
  id              String          @id @default(uuid()) @db.Uuid
  scheduleId      String          @db.Uuid
  organizationId  String          @db.Uuid /// denormalizado para RLS rápida.
  providerId      String          @db.Uuid
  startsAt        DateTime        @db.Timestamptz()
  endsAt          DateTime        @db.Timestamptz()
  appointmentType AppointmentType @default(FOLLOW_UP)
  overbookFactor  Int             @default(1)
  status          SlotStatus      @default(Free)
  blockedReason   String?         @db.VarChar(200)
  createdAt       DateTime        @default(now()) @db.Timestamptz()

  schedule     Schedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([providerId, startsAt])
  @@index([organizationId, startsAt])
  @@index([scheduleId, startsAt])
  @@index([status])
  @@map("slot")
  @@schema("public")
}

/// US-10.2 / US-10.8 — reserva de cita ambulatoria.
model Appointment {
  id                   String            @id @default(uuid()) @db.Uuid
  organizationId       String            @db.Uuid
  establishmentId      String            @db.Uuid
  slotId               String            @db.Uuid
  providerId           String            @db.Uuid
  serviceUnitId        String            @db.Uuid
  patientId            String?           @db.Uuid /// puede ser NN al reservar (US-10.2 NN flow).
  unknownPatientLabel  String?           @db.VarChar(120)
  appointmentType      AppointmentType   @default(FOLLOW_UP)
  status               AppointmentStatus @default(Booked)
  reason               String            @db.VarChar(200)
  notes                String?           @db.VarChar(500)
  cancellationReason   String?           @db.VarChar(200)
  rescheduledFromId    String?           @db.Uuid
  scheduledAt          DateTime          @db.Timestamptz() /// = slot.startsAt al momento de la reserva.

  /// Wave 1 cont. · ADR-0012 — metadata No-Show cron.
  noShowMarkedAt          DateTime?      @db.Timestamptz()
  noShowGraceMinutes      Int?
  /// FK al último registro en appointment_state_transition_log.
  lastStateTransitionId   String?        @db.Uuid

  createdAt            DateTime          @default(now()) @db.Timestamptz()
  createdBy            String?           @db.Uuid
  updatedAt            DateTime          @updatedAt @db.Timestamptz()
  updatedBy            String?           @db.Uuid

  slot                  Slot                                @relation(fields: [slotId], references: [id], onDelete: Restrict)
  outpatientEncounter   OutpatientEncounter[]
  stateTransitions      AppointmentStateTransitionLog[]
  lastStateTransition   AppointmentStateTransitionLog?      @relation("AppointmentLastTransition", fields: [lastStateTransitionId], references: [id], onDelete: SetNull)

  @@index([organizationId, scheduledAt])
  @@index([providerId, scheduledAt])
  @@index([patientId, scheduledAt])
  @@index([status])
  @@index([organizationId, noShowMarkedAt])
  @@map("appointment")
  @@schema("public")
}

/// ADR-0001 — agregado raíz `OutpatientEncounter` (BC ambulatory).
model OutpatientEncounter {
  id                    String                    @id @default(uuid()) @db.Uuid
  organizationId        String                    @db.Uuid
  establishmentId       String                    @db.Uuid
  serviceUnitId         String                    @db.Uuid
  appointmentId         String                    @db.Uuid
  patientId             String                    @db.Uuid /// ref MPI (BC adt).
  providerId            String                    @db.Uuid
  status                OutpatientEncounterStatus @default(CheckedIn)
  /// Ref. opaca a `SoapNote.id` (BC ehr — Bravo). NO se modela como FK
  /// para preservar la integridad cross-BC; la consistencia es eventual.
  soapNoteRef           String?                   @db.Uuid
  primaryDiagnosisId    String?                   @db.Uuid /// ClinicalConcept (CIE-10).
  plan                  String?                   @db.Text
  checkedInAt           DateTime                  @default(now()) @db.Timestamptz()
  inConsultAt           DateTime?                 @db.Timestamptz()
  completedAt           DateTime?                 @db.Timestamptz()
  /// Por requerimiento ADR-0001, los cambios son `Cancelled` con motivo (no borrado).
  cancelledAt           DateTime?                 @db.Timestamptz()
  cancellationReason    String?                   @db.VarChar(200)
  createdAt             DateTime                  @default(now()) @db.Timestamptz()
  createdBy             String?                   @db.Uuid
  updatedAt             DateTime                  @updatedAt @db.Timestamptz()
  updatedBy             String?                   @db.Uuid

  appointment Appointment           @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  procedures  OutpatientProcedure[]
  leaves      MedicalLeave[]

  @@unique([appointmentId]) /// invariante: un encuentro por cita.
  @@index([organizationId, checkedInAt])
  @@index([providerId, status])
  @@index([patientId, checkedInAt])
  @@map("outpatient_encounter")
  @@schema("public")
}

/// US-10.6 — procedimiento menor ambulatorio (sutura, curación, retiro de puntos…).
model OutpatientProcedure {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @db.Uuid
  encounterId       String    @db.Uuid
  procedureCodeId   String    @db.Uuid /// ClinicalConcept (catálogo local de procedimientos).
  performerId       String?   @db.Uuid /// User ejecutante (puede diferir del provider del encuentro).
  startedAt         DateTime  @db.Timestamptz()
  endedAt           DateTime? @db.Timestamptz()
  notes             String?   @db.VarChar(500)
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  createdBy         String?   @db.Uuid

  encounter OutpatientEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@index([organizationId, startedAt])
  @@map("outpatient_procedure")
  @@schema("public")
}

/// US-10.7 — incapacidad médica emitida al cerrar la consulta.
/// Wave 1: solo emisión + firma local + outbox; integración SISSS/MINSAL diferida.
model MedicalLeave {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @db.Uuid
  encounterId     String           @db.Uuid
  patientId       String           @db.Uuid
  providerId      String           @db.Uuid
  leaveType       MedicalLeaveType
  /// Código MINSAL/ISSS opcional Wave 1 (TODO[@AS] integración SISSS Wave 2).
  minsalCode      String?          @db.VarChar(40)
  days            Int
  startDate       DateTime         @db.Date
  endDate         DateTime         @db.Date
  reason          String           @db.VarChar(500)
  /// Ref. opaca al PDF firmado en bucket Supabase `prescriptions-signed`.
  documentRef     String?          @db.VarChar(500)
  signatureRef    String?          @db.VarChar(500)
  /// FK al audit_log (hash-chain) — ADR-0002.
  auditEntryId    BigInt?
  issuedAt        DateTime         @default(now()) @db.Timestamptz()
  createdBy       String?          @db.Uuid

  encounter OutpatientEncounter @relation(fields: [encounterId], references: [id], onDelete: Restrict)

  /// Wave 1 cont. · ADR-0010 — PDF firmado en bucket cifrado (relación 1:1).
  signedBlob MedicalLeaveSignedBlob?

  @@index([organizationId, issuedAt])
  @@index([patientId, issuedAt])
  @@map("medical_leave")
  @@schema("public")
}

// =============================================================================
// §15 — Pharmacy (CPOE + Validación + Dispensación unidosis) + §16 — eMAR/5R
// Wave 1 · Team Charlie · ADR-0003 state machine three-actor coordination.
// Scope reducido (@Orq): EXCLUYE Pyxis/DERS/mezclas IV/farmacovigilancia.
// =============================================================================

/// ADR-0003 — estado del agregado `Prescription`.
enum PrescriptionStatus {
  Drafted
  Prescribed
  Validated
  Dispensed
  Administered
  Rejected
  Discontinued

  @@schema("public")
}

/// TDR §15.7 — clase regulatoria DNM (Drogas No Manipulables).
enum ControlledClass {
  NONE
  II
  III
  IV
  V

  @@schema("public")
}

/// Vía de administración (subset Wave 1).
enum AdministrationRoute {
  VO
  IV
  IM
  SC
  SL
  TOP
  INH
  REC
  OFT
  OTI

  @@schema("public")
}

/// Frecuencia (subset Wave 1; parser de schedule en eMAR).
enum AdministrationFrequency {
  QD
  BID
  TID
  QID
  Q4H
  Q12H
  STAT
  PRN

  @@schema("public")
}

/// Severidad de interacción (dataset estático Wave 1).
enum InteractionSeverity {
  minor
  moderate
  major
  contraindicated

  @@schema("public")
}

/// Razón de rechazo farmacéutico (US-12.2).
enum PrescriptionRejectionReason {
  ALLERGY
  INTERACTION
  DOSE_OUT_OF_RANGE
  ROUTE_INCORRECT
  DUPLICATE_THERAPY
  OTHER

  @@schema("public")
}

/// Kind de movimiento en `controlled_substance_ledger` (US-12.6).
enum ControlledLedgerKind {
  ENTRY_PURCHASE
  ENTRY_RETURN
  EXIT_PRESCRIPTION
  EXIT_LOSS
  ADJUSTMENT

  @@schema("public")
}

/// §15.3 — catálogo de fármacos (subset Wave 1; ampliar en Wave 2 con Lexicomp).
model Drug {
  id              String              @id @default(uuid()) @db.Uuid
  organizationId  String?             @db.Uuid /// null = catálogo global; no-null = override por org.
  atcCode         String              @db.VarChar(10) /// J01CA04, A10AB05...
  name            String              @db.VarChar(200)
  strength        String              @db.VarChar(60)
  form            String              @db.VarChar(60)
  defaultRoute    AdministrationRoute
  controlledClass ControlledClass     @default(NONE)
  isHighRisk      Boolean             @default(false) /// ISMP HighRiskList.
  /// Familias para chequeo cruzado con alergias (penicilínicos, sulfas...).
  allergyFamilies   String[]            @default([]) @db.VarChar(60)
  /// US.F2.6.10 — excipientes alergénicos (tartrazina, lactosa, gluten…).
  allergyExcipients String[]            @default([]) @db.VarChar(60)
  active            Boolean             @default(true)
  createdAt       DateTime            @default(now()) @db.Timestamptz()
  updatedAt       DateTime            @updatedAt @db.Timestamptz()

  prescriptionLines PrescriptionLine[]
  ledgerEntries     ControlledSubstanceLedger[]

  @@unique([organizationId, atcCode, strength, form])
  @@index([atcCode])
  @@index([isHighRisk])
  @@map("drug")
  @@schema("public")
}

/// §15.4 — dataset estático de interacciones (Wave 1). Wave 2: Lexicomp/Vademecum.
model DrugInteraction {
  id          String              @id @default(uuid()) @db.Uuid
  atcA        String              @db.VarChar(10) /// prefijo ATC fármaco A.
  atcB        String              @db.VarChar(10) /// prefijo ATC fármaco B.
  severity    InteractionSeverity
  description String              @db.VarChar(400)
  source      String              @db.VarChar(40) /// "stub-wave1" hasta Wave 2.
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now()) @db.Timestamptz()

  @@unique([atcA, atcB])
  @@index([severity])
  @@map("drug_interaction")
  @@schema("public")
}

/// ADR-0003 — agregado raíz Prescription.
/// Concurrencia: `version` para optimistic locking; locks pesimistas SELECT FOR
/// UPDATE en transiciones Dispense/Administer (router).
model Prescription {
  id                String                       @id @default(uuid()) @db.Uuid
  organizationId    String                       @db.Uuid
  encounterId       String                       @db.Uuid
  patientId         String                       @db.Uuid
  prescriberId      String                       @db.Uuid /// User (médico).
  status            PrescriptionStatus           @default(Drafted)
  /// Optimistic locking — se incrementa en cada transición.
  version           Int                          @default(1)
  notes             String                       @default("") @db.VarChar(2000)
  /// Firma electrónica (Wave 1: TSA RFC 3161). TODO[Wave 2 PKI/HSM].
  signedAt          DateTime?                    @db.Timestamptz()
  signatureRef      String?                      @db.VarChar(500)
  signatureProvider String?                      @db.VarChar(40)
  /// Trazabilidad de validación farmacéutica.
  validatedAt       DateTime?                    @db.Timestamptz()
  validatedById     String?                      @db.Uuid
  validationCheck   Json? /// snapshot de checks (allergyChecked, etc.) + override.
  /// Rechazo (Prescribed -> Rejected).
  rejectedAt        DateTime?                    @db.Timestamptz()
  rejectedById      String?                      @db.Uuid
  rejectionReason   PrescriptionRejectionReason?
  rejectionDetail   String?                      @db.VarChar(500)
  /// Discontinuación (terminal alternativo).
  discontinuedAt    DateTime?                    @db.Timestamptz()
  discontinuedById  String?                      @db.Uuid
  discontinueReason String?                      @db.VarChar(40)
  /// FK al audit_log (hash-chain primitiva D-03 de Bravo).
  auditEntryId      BigInt?
  createdAt         DateTime                     @default(now()) @db.Timestamptz()
  createdBy         String?                      @db.Uuid
  updatedAt         DateTime                     @updatedAt @db.Timestamptz()
  updatedBy         String?                      @db.Uuid

  lines           PrescriptionLine[]
  dispensations   DispensationEvent[]
  administrations AdministrationEvent[]

  @@index([organizationId, status, createdAt])
  @@index([patientId, createdAt])
  @@index([encounterId])
  @@map("prescription")
  @@schema("public")
}

/// ADR-0003 — línea de prescripción (1 fármaco con su dosis/vía/frecuencia).
model PrescriptionLine {
  id             String                  @id @default(uuid()) @db.Uuid
  prescriptionId String                  @db.Uuid
  organizationId String                  @db.Uuid /// denorm para RLS rápida.
  drugId         String                  @db.Uuid
  dose           Decimal                 @db.Decimal(12, 4)
  doseUnit       String                  @db.VarChar(20)
  route          AdministrationRoute
  frequency      AdministrationFrequency
  /// Duración total en horas — null = open-ended hasta discontinue.
  durationHours  Int?
  instructions   String                  @default("") @db.VarChar(400)
  createdAt      DateTime                @default(now()) @db.Timestamptz()

  prescription    Prescription          @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug            Drug                  @relation(fields: [drugId], references: [id], onDelete: Restrict)
  dispensations   DispensationEvent[]
  administrations AdministrationEvent[]

  @@index([prescriptionId])
  @@index([drugId])
  @@map("prescription_line")
  @@schema("public")
}

/// §15.5 — Dispensación unidosis (Validated -> Dispensed). Wave 1: sin Pyxis.
model DispensationEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  prescriptionId     String   @db.Uuid
  prescriptionLineId String   @db.Uuid
  organizationId     String   @db.Uuid
  units              Int /// número de unidosis dispensadas.
  lotNumber          String   @db.VarChar(60)
  expiryDate         DateTime @db.Date
  /// Barcode/QR del item — UNIQUE para idempotencia y trazabilidad.
  itemBarcode        String   @db.VarChar(80)
  dispensedAt        DateTime @default(now()) @db.Timestamptz()
  dispensedById      String   @db.Uuid
  /// FK al audit_log (hash-chain).
  auditEntryId       BigInt?

  prescription     Prescription     @relation(fields: [prescriptionId], references: [id], onDelete: Restrict)
  prescriptionLine PrescriptionLine @relation(fields: [prescriptionLineId], references: [id], onDelete: Restrict)

  @@unique([itemBarcode])
  @@index([prescriptionId])
  @@index([organizationId, dispensedAt])
  @@map("dispensation_event")
  @@schema("public")
}

/// §16.3 — Administración con 5R (Dispensed -> Administered, cíclico por dosis).
/// Idempotencia: UNIQUE (prescriptionLineId, scheduledTime) — doble-tap seguro.
model AdministrationEvent {
  id                 String   @id @default(uuid()) @db.Uuid
  prescriptionId     String   @db.Uuid
  prescriptionLineId String   @db.Uuid
  organizationId     String   @db.Uuid
  /// Hora programada del slot (sirve para idempotencia).
  scheduledTime      DateTime @db.Timestamptz()
  /// Hora real de administración (debe estar dentro de ±30 min de scheduled).
  administeredAt     DateTime @default(now()) @db.Timestamptz()
  administeredById   String   @db.Uuid
  /// Segundo enfermero (US-12.5) — requerido si drug.isHighRisk.
  secondNurseId      String?  @db.Uuid
  doubleVerified     Boolean  @default(false)
  /// Snapshot de 5R (scanned codes + flags).
  fiveRightsSnapshot Json
  fiveRightsOk       Boolean
  notes              String?  @db.VarChar(500)
  /// FK al audit_log (hash-chain).
  auditEntryId       BigInt?

  prescription     Prescription     @relation(fields: [prescriptionId], references: [id], onDelete: Restrict)
  prescriptionLine PrescriptionLine @relation(fields: [prescriptionLineId], references: [id], onDelete: Restrict)

  @@unique([prescriptionLineId, scheduledTime])
  @@index([organizationId, administeredAt])
  @@index([administeredById])
  @@map("administration_event")
  @@schema("public")
}

/// §15.7 / US-12.6 — Libro consecutivo DNM. Append-only (trigger DB bloquea
/// UPDATE/DELETE) con encadenamiento de hash por organización.
model ControlledSubstanceLedger {
  id              String               @id @default(uuid()) @db.Uuid
  organizationId  String               @db.Uuid
  /// Folio consecutivo gapless por organización (BIGSERIAL en SQL).
  folio           BigInt
  drugId          String               @db.Uuid
  kind            ControlledLedgerKind
  units           Int /// positivo en entradas, negativo en salidas.
  lotNumber       String               @db.VarChar(60)
  /// Documento soporte (OC, foto de receta retenida, ajuste...).
  documentRef     String               @db.VarChar(200)
  /// FK opcional al paciente cuando es EXIT_PRESCRIPTION.
  patientId       String?              @db.Uuid
  notes           String?              @db.VarChar(500)
  /// Encadenamiento Merkle local del libro DNM.
  prevHash        String?              @db.VarChar(120)
  currHash        String               @db.VarChar(120)
  /// FK al audit_log (hash-chain global).
  auditEntryId    BigInt?
  recordedAt      DateTime             @default(now()) @db.Timestamptz()
  recordedById    String               @db.Uuid

  drug Drug @relation(fields: [drugId], references: [id], onDelete: Restrict)

  @@unique([organizationId, folio])
  @@index([organizationId, recordedAt])
  @@index([drugId, recordedAt])
  @@map("controlled_substance_ledger")
  @@schema("public")
}

// =============================================================================
// §17 — LIS (Wave 1, Team Delta · BC `lis`)
// ADR-0004: LabResult agregado propio, 4-eyes como ValidationEvent encadenados,
// CriticalValueNotification paralelo al flujo de release, RLS por organization.
// =============================================================================

enum LabOrderPriority {
  ROUTINE
  URGENT
  STAT

  @@schema("public")
}

enum LabOrderStatus {
  Placed
  InProgress
  PartiallyResulted
  Completed
  Cancelled

  @@schema("public")
}

enum SpecimenStatus {
  Collected
  InTransit
  Received
  Accepted
  Rejected

  @@schema("public")
}

enum SpecimenTube {
  EDTA_PURPLE
  SST_YELLOW
  LITHIUM_HEPARIN_GREEN
  CITRATE_BLUE
  FLUORIDE_GRAY
  URINE_STERILE

  @@schema("public")
}

enum LabResultSource {
  AnalyzerHL7
  ManualEntry

  @@schema("public")
}

enum LabResultStatus {
  ReceivedFromAnalyzer
  ManualEntry
  AutoFlagged
  TechnologistValidated
  ClinicalValidated
  Released
  Amended
  Rejected

  @@schema("public")
}

enum ValidationRole {
  TECHNOLOGIST
  PATHOLOGIST
  BIOLOGIST

  @@schema("public")
}

enum CriticalNotificationStatus {
  Pending
  Acknowledged
  EscalatedToHead
  EscalatedToDirector
  Expired

  @@schema("public")
}

/// Catálogo de panel (Hemograma, Química básica, Electrolitos).
model LabPanel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid /// NULL = panel global (catálogo seed).
  code           String   @db.VarChar(40)
  name           String   @db.VarChar(160)
  loincCode      String?  @db.VarChar(20)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz()

  tests      LabPanelTest[]
  orderItems LabOrderItem[]

  @@unique([organizationId, code], name: "uniq_panel_per_org_code")
  @@index([organizationId])
  @@map("lab_panel")
  @@schema("public")
}

/// LabTest individual (un analito LOINC con rangos + crítico + delta threshold).
model LabTest {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String?  @db.Uuid
  loincCode         String   @db.VarChar(20)
  name              String   @db.VarChar(160)
  unit              String   @db.VarChar(20)
  refLow            Decimal? @db.Decimal(12, 4)
  refHigh           Decimal? @db.Decimal(12, 4)
  /// Umbrales críticos firmados por comité clínico (CA-09).
  criticalLow       Decimal? @db.Decimal(12, 4)
  criticalHigh      Decimal? @db.Decimal(12, 4)
  deltaThresholdPct Decimal  @default(30) @db.Decimal(5, 2)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz()

  panels     LabPanelTest[]
  orderItems LabOrderItem[]

  @@unique([organizationId, loincCode], name: "uniq_test_per_org_loinc")
  @@index([loincCode])
  @@map("lab_test")
  @@schema("public")
}

/// Tabla puente N:M panel↔test (4NF).
model LabPanelTest {
  panelId  String @db.Uuid
  testId   String @db.Uuid
  position Int    @default(0)

  panel LabPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  test  LabTest  @relation(fields: [testId], references: [id], onDelete: Restrict)

  @@id([panelId, testId])
  @@index([testId])
  @@map("lab_panel_test")
  @@schema("public")
}

/// Agregado raíz LabOrder (US-13.1).
model LabOrder {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @db.Uuid
  encounterId     String           @db.Uuid
  patientId       String           @db.Uuid
  requesterId     String           @db.Uuid
  status          LabOrderStatus   @default(Placed)
  priority        LabOrderPriority @default(ROUTINE)
  fastingRequired Boolean          @default(false)
  clinicalNotes   String?          @db.VarChar(500)
  placedAt        DateTime         @default(now()) @db.Timestamptz()
  signatureRef    String?          @db.VarChar(500)
  auditEntryId    BigInt?
  createdAt       DateTime         @default(now()) @db.Timestamptz()
  updatedAt       DateTime         @updatedAt @db.Timestamptz()

  items     LabOrderItem[]
  specimens Specimen[]
  results   LabResult[]

  @@index([organizationId, status, placedAt])
  @@index([patientId, placedAt])
  @@index([encounterId])
  @@map("lab_order")
  @@schema("public")
}

/// Item de orden: panel o test suelto.
model LabOrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  labOrderId String   @db.Uuid
  panelId    String?  @db.Uuid
  testId     String?  @db.Uuid
  loincCode  String   @db.VarChar(20)
  name       String   @db.VarChar(160)
  createdAt  DateTime @default(now()) @db.Timestamptz()

  order LabOrder  @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  panel LabPanel? @relation(fields: [panelId], references: [id], onDelete: Restrict)
  test  LabTest?  @relation(fields: [testId], references: [id], onDelete: Restrict)

  @@index([labOrderId])
  @@index([panelId])
  @@map("lab_order_item")
  @@schema("public")
}

/// Specimen (US-13.2). Ciclo independiente: Collected → Received → Accepted/Rejected.
model Specimen {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  labOrderId     String         @db.Uuid
  status         SpecimenStatus @default(Collected)
  tube           SpecimenTube
  barcode        String         @db.VarChar(40)
  collectorId    String         @db.Uuid
  collectedAt    DateTime       @default(now()) @db.Timestamptz()
  receivedAt     DateTime?      @db.Timestamptz()
  acceptedAt     DateTime?      @db.Timestamptz()
  rejectedAt     DateTime?      @db.Timestamptz()
  rejectReason   String?        @db.VarChar(40)
  rejectNote     String?        @db.VarChar(300)
  auditEntryId   BigInt?
  createdAt      DateTime       @default(now()) @db.Timestamptz()

  order   LabOrder    @relation(fields: [labOrderId], references: [id], onDelete: Restrict)
  results LabResult[]

  @@unique([organizationId, barcode], name: "uniq_specimen_barcode_per_org")
  @@index([labOrderId])
  @@index([organizationId, status])
  @@map("lab_specimen")
  @@schema("public")
}

/// LabResult — agregado raíz propio (ADR-0004).
model LabResult {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @db.Uuid
  labOrderId       String          @db.Uuid
  specimenId       String          @db.Uuid
  patientId        String          @db.Uuid
  encounterId      String          @db.Uuid
  loincCode        String          @db.VarChar(20)
  testName         String          @db.VarChar(160)
  valueNumeric     Decimal?        @db.Decimal(18, 6)
  valueText        String?         @db.VarChar(400)
  unit             String          @db.VarChar(20)
  refLow           Decimal?        @db.Decimal(12, 4)
  refHigh          Decimal?        @db.Decimal(12, 4)
  flags            Json            @default("{}")
  source           LabResultSource
  status           LabResultStatus @default(ReceivedFromAnalyzer)
  version          Int             @default(1)
  analyzerId       String?         @db.VarChar(40)
  messageControlId String?         @db.VarChar(60)
  observedAt       DateTime        @db.Timestamptz()
  receivedAt       DateTime        @default(now()) @db.Timestamptz()
  releasedAt       DateTime?       @db.Timestamptz()
  lastEventHash    String?         @db.VarChar(120)
  auditEntryId     BigInt?
  createdAt        DateTime        @default(now()) @db.Timestamptz()
  updatedAt        DateTime        @updatedAt @db.Timestamptz()

  order                 LabOrder                    @relation(fields: [labOrderId], references: [id], onDelete: Restrict)
  specimen              Specimen                    @relation(fields: [specimenId], references: [id], onDelete: Restrict)
  validations           LabValidationEvent[]
  criticalNotifications CriticalValueNotification[]

  @@unique([analyzerId, messageControlId], name: "uniq_oru_idempotency")
  @@index([organizationId, status, receivedAt])
  @@index([labOrderId])
  @@index([patientId, observedAt])
  @@map("lab_result")
  @@schema("public")
}

/// ValidationEvent encadenado (primitiva hash D-03 de Bravo).
model LabValidationEvent {
  id                           String         @id @default(uuid()) @db.Uuid
  organizationId               String         @db.Uuid
  labResultId                  String         @db.Uuid
  role                         ValidationRole
  validatorId                  String         @db.Uuid
  signedAt                     DateTime       @default(now()) @db.Timestamptz()
  signatureRef                 String?        @db.VarChar(500)
  signatureProvider            String?        @db.VarChar(40)
  comment                      String?        @db.VarChar(500)
  contentHash                  String         @db.VarChar(120)
  previousEventHash            String?        @db.VarChar(120)
  singleValidator              Boolean        @default(false)
  singleValidatorJustification String?        @db.VarChar(300)
  auditEntryId                 BigInt?

  result LabResult @relation(fields: [labResultId], references: [id], onDelete: Restrict)

  @@unique([labResultId, role], name: "uniq_validation_per_result_role")
  @@index([labResultId])
  @@index([organizationId, signedAt])
  @@map("lab_validation_event")
  @@schema("public")
}

/// CriticalValueNotification — paralelo al flujo (ADR-0004). SLA < 30 min p99.
model CriticalValueNotification {
  id                  String                     @id @default(uuid()) @db.Uuid
  organizationId      String                     @db.Uuid
  labResultId         String                     @db.Uuid
  patientId           String                     @db.Uuid
  attendingProviderId String?                    @db.Uuid
  status              CriticalNotificationStatus @default(Pending)
  raisedAt            DateTime                   @default(now()) @db.Timestamptz()
  deadlineAt          DateTime                   @db.Timestamptz()
  acknowledgedAt      DateTime?                  @db.Timestamptz()
  ackBy               String?                    @db.Uuid
  ackNote             String?                    @db.VarChar(500)
  escalatedAt         DateTime?                  @db.Timestamptz()
  auditEntryId        BigInt?

  result LabResult @relation(fields: [labResultId], references: [id], onDelete: Restrict)

  @@index([organizationId, status, deadlineAt])
  @@index([labResultId])
  @@map("lab_critical_value_notification")
  @@schema("public")
}

/// Inbound HL7 message log — idempotencia y trazabilidad (US-13.3).
/// TODO[Wave 2 Mirth Connect]: poblar con tráfico real; Wave 1 sólo stub.
model HL7InboundMessage {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @db.Uuid
  analyzerId       String    @db.VarChar(40)
  messageControlId String    @db.VarChar(60)
  messageType      String    @db.VarChar(20) /// ORU^R01 | OUL^R22
  rawMessage       String    @db.Text
  receivedAt       DateTime  @default(now()) @db.Timestamptz()
  processedAt      DateTime? @db.Timestamptz()
  outcome          String    @db.VarChar(20) /// 'OK' | 'DUPLICATE' | 'PARSE_ERROR' | 'NOT_MATCHED'
  errorMessage     String?   @db.VarChar(500)

  @@unique([analyzerId, messageControlId], name: "uniq_hl7_idempotency")
  @@index([organizationId, receivedAt])
  @@map("hl7_inbound_message")
  @@schema("public")
}

// =============================================================================
// §W1c — Wave 1 cont. · Allergy FHIR R4 (Bravo · CA-13 · ADR-0007)
// =============================================================================

enum AllergyClinicalStatus {
  active
  inactive
  resolved

  @@schema("public")
}

enum AllergyVerificationStatus {
  unconfirmed
  confirmed
  refuted
  entered_in_error @map("entered-in-error")

  @@schema("public")
}

enum AllergyCriticality {
  low
  high
  unable_to_assess @map("unable-to-assess")

  @@schema("public")
}

enum AllergyCategory {
  food
  medication
  environment
  biologic

  @@schema("public")
}

enum AllergyReactionSeverity {
  mild
  moderate
  severe

  @@schema("public")
}

/// ADR-0007 · CA-13 — Agregado raíz FHIR R4 AllergyIntolerance.
/// Coexiste con PatientAllergy (v1) durante ventana dual-emit (60 d).
model AllergyIntolerance {
  id                   String                       @id @default(uuid()) @db.Uuid
  organizationId       String                       @db.Uuid
  patientId            String                       @db.Uuid
  /// FHIR substance — code+system (SNOMED CT por defecto; RxNorm/ATC permitidos).
  substanceSystem      String                       @default("http://snomed.info/sct") @db.VarChar(60)
  substanceCode        String                       @db.VarChar(80)
  substanceDisplay     String                       @db.VarChar(200)
  category             AllergyCategory              @default(medication)
  criticality          AllergyCriticality           @default(unable_to_assess)
  verificationStatus   AllergyVerificationStatus    @default(unconfirmed)
  clinicalStatus       AllergyClinicalStatus        @default(active)
  onsetDateTime        DateTime?                    @db.Timestamptz()
  lastOccurrence       DateTime?                    @db.Timestamptz()
  recordedAt           DateTime                     @default(now()) @db.Timestamptz()
  recordedBy           String                       @db.Uuid
  asserterId           String?                      @db.Uuid
  note                 String?                      @db.Text
  /// Si la fila se promovió desde un legacy v1 (PatientAllergy.id).
  legacyAllergyId      String?                      @db.Uuid
  createdAt            DateTime                     @default(now()) @db.Timestamptz()
  createdBy            String?                      @db.Uuid
  updatedAt            DateTime                     @updatedAt @db.Timestamptz()
  updatedBy            String?                      @db.Uuid

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  patient      Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reactions    AllergyReaction[]
  legacyLinks  PatientAllergy[]

  @@index([patientId, clinicalStatus])
  @@index([organizationId, substanceCode])
  @@index([organizationId, recordedAt(sort: Desc)])
  @@map("allergy_intolerance")
  @@schema("public")
}

/// ADR-0007 — manifestaciones (FHIR reaction[]). Cascade vs AllergyIntolerance.
model AllergyReaction {
  id                     String                  @id @default(uuid()) @db.Uuid
  allergyIntoleranceId   String                  @db.Uuid
  organizationId         String                  @db.Uuid
  manifestationSystem    String                  @default("http://snomed.info/sct") @db.VarChar(60)
  manifestationCode      String                  @db.VarChar(80)
  manifestationDisplay   String                  @db.VarChar(200)
  severity               AllergyReactionSeverity
  onset                  DateTime?               @db.Timestamptz()
  description            String?                 @db.VarChar(500)
  exposureRoute          String?                 @db.VarChar(60)
  createdAt              DateTime                @default(now()) @db.Timestamptz()
  createdBy              String?                 @db.Uuid

  allergyIntolerance AllergyIntolerance @relation(fields: [allergyIntoleranceId], references: [id], onDelete: Cascade)
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([allergyIntoleranceId])
  @@index([organizationId, severity])
  @@map("allergy_reaction")
  @@schema("public")
}

// =============================================================================
// §W1c — Problem list (Bravo · CA-14 · ADR-0002 append-only · ADR-0013 LEIV)
// =============================================================================

enum ProblemClinicalStatus {
  active
  inactive
  resolved

  @@schema("public")
}

enum ProblemSeverity {
  mild
  moderate
  severe

  @@schema("public")
}

enum ProblemChangeKind {
  CREATED
  STATUS_CHANGED
  SEVERITY_CHANGED
  RESOLVED
  REOPENED
  LEIV_FLAGGED
  LEIV_UNFLAGGED
  CORRECTION
  NOTE_APPENDED

  @@schema("public")
}

/// CA-14 — Problem list longitudinal. Append-only: mutaciones via INSERT
/// nueva revisión + INSERT en problem_change_log. Trigger DB bloquea UPDATE/DELETE.
model ProblemListItem {
  id                 String                  @id @default(uuid()) @db.Uuid
  patientProblemKey  String                  @db.Uuid
  revision           Int                     @default(1)
  organizationId     String                  @db.Uuid
  patientId          String                  @db.Uuid
  icd10Code          String                  @db.VarChar(10)
  icd10Display       String                  @db.VarChar(300)
  clinicalStatus     ProblemClinicalStatus   @default(active)
  severity           ProblemSeverity?
  onsetDate          DateTime?               @db.Date
  resolvedDate       DateTime?               @db.Date
  /// ADR-0013 · LEIV — confidencialidad reforzada (RLS dual + retención ×1.5).
  leivFlag           Boolean                 @default(false)
  recordedBy         String                  @db.Uuid
  recordedAt         DateTime                @default(now()) @db.Timestamptz()
  note               String?                 @db.Text
  rootItemId         String?                 @db.Uuid

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  changes      ProblemChangeLog[]

  @@unique([patientProblemKey, revision])
  @@index([patientId, clinicalStatus])
  @@index([organizationId, recordedAt(sort: Desc)])
  @@index([organizationId, icd10Code])
  @@map("problem_list_item")
  @@schema("public")
}

/// CA-14 — bitácora de mutaciones del problem list (append-only).
model ProblemChangeLog {
  id                 String              @id @default(uuid()) @db.Uuid
  problemItemId      String              @db.Uuid
  patientProblemKey  String              @db.Uuid
  organizationId     String              @db.Uuid
  changeKind         ProblemChangeKind
  beforeJson         Json?
  afterJson          Json
  reason             String?             @db.VarChar(500)
  changedBy          String              @db.Uuid
  changedAt          DateTime            @default(now()) @db.Timestamptz()
  /// Ancla al audit_log (ADR-0002).
  auditEntryId       BigInt?

  problemItem  ProblemListItem @relation(fields: [problemItemId], references: [id], onDelete: Restrict)
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([problemItemId, changedAt(sort: Desc)])
  @@index([patientProblemKey, changedAt(sort: Desc)])
  @@index([organizationId, changedAt(sort: Desc)])
  @@map("problem_change_log")
  @@schema("public")
}

// =============================================================================
// §W1c — SOAP Templates (Bravo · CA-15 · ADR-0008)
// =============================================================================

enum TemplateStatus {
  DRAFT
  PUBLISHED
  RETIRED

  @@schema("public")
}

/// ADR-0008 — agregado raíz. organizationId NULL = template global Avante.
model SoapNoteTemplate {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String?          @db.Uuid
  code            String           @db.VarChar(80)
  name            String           @db.VarChar(200)
  status          TemplateStatus   @default(DRAFT)
  description     String?          @db.VarChar(500)
  createdBy       String           @db.Uuid
  createdAt       DateTime         @default(now()) @db.Timestamptz()
  updatedAt       DateTime         @updatedAt @db.Timestamptz()
  updatedBy       String?          @db.Uuid
  retiredAt       DateTime?        @db.Timestamptz()
  retiredBy       String?          @db.Uuid

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  versions     SoapNoteTemplateVersion[]
  bindings     TemplateSpecialtyBinding[]

  @@index([organizationId, status])
  @@map("soap_note_template")
  @@schema("public")
}

/// ADR-0008 — versión inmutable post-publish. Trigger DB enforce.
model SoapNoteTemplateVersion {
  id            String     @id @default(uuid()) @db.Uuid
  templateId    String     @db.Uuid
  semver        String     @db.VarChar(20)
  /// JSON Schema FHIR-Questionnaire-like.
  schema        Json
  publishedAt   DateTime?  @db.Timestamptz()
  publishedBy   String?    @db.Uuid
  retiredAt     DateTime?  @db.Timestamptz()
  retiredBy     String?    @db.Uuid
  contentHash   String     @db.VarChar(120)
  auditEntryId  BigInt?
  createdAt     DateTime   @default(now()) @db.Timestamptz()

  template      SoapNoteTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  appliedNotes  SoapNote[]

  @@unique([templateId, semver])
  @@index([templateId])
  @@index([publishedAt(sort: Desc)])
  @@map("soap_note_template_version")
  @@schema("public")
}

/// ADR-0008 — binding a especialidad (sugerencia UI, NO restrictivo cross-BC).
model TemplateSpecialtyBinding {
  id               String   @id @default(uuid()) @db.Uuid
  templateId       String   @db.Uuid
  specialtyId      String   @db.Uuid
  /// Hints orientativos: ['encounter','outpatient_encounter'].
  subjectKindHint  String[] @default([])
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now()) @db.Timestamptz()

  template  SoapNoteTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  specialty MedicalSpecialty  @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@unique([templateId, specialtyId])
  @@index([templateId])
  @@index([specialtyId])
  @@map("template_specialty_binding")
  @@schema("public")
}

// =============================================================================
// §W1c — Alpha · Signed documents + Cron observability (CA-16/CA-17)
// ADR-0010, ADR-0011, ADR-0012, ADR-0013
// =============================================================================

enum RetentionClass {
  adult
  pediatric
  leiv

  @@schema("public")
}

enum SignedDocumentType {
  medical_leave
  soap_addendum
  soap_note
  prescription_dnm
  lab_report
  consent

  @@schema("public")
}

enum CronStatus {
  running
  success
  failed
  partial

  @@schema("public")
}

enum TransitionedByKind {
  user
  system_cron
  admin_backfill

  @@schema("public")
}

/// ADR-0010 — metadata del PDF MedicalLeave firmado. PDF binario en bucket
/// Supabase Storage `medical-leaves-signed` (cifrado, RLS, retención).
model MedicalLeaveSignedBlob {
  id                  String           @id @default(uuid()) @db.Uuid
  leaveId             String           @unique @db.Uuid
  organizationId      String           @db.Uuid
  pdfStoragePath      String           @db.VarChar(500)
  pdfSizeBytes        BigInt
  contentHash         String           @db.VarChar(120) /// sha256(pdf bytes)
  signedAt            DateTime         @db.Timestamptz()
  signedBy            String           @db.Uuid
  certificateSerial   String?          @db.VarChar(120)
  certificateSubject  String?          @db.VarChar(300)
  tsaTimestampToken   Bytes?
  tsaProvider         String?          @db.VarChar(80)
  qrValidationToken   String?          @unique @db.VarChar(120)
  qrValidationUrl     String?          @db.VarChar(500)
  retentionClass      RetentionClass   @default(adult)
  purgeDate           DateTime         @db.Date
  legalHold           Boolean          @default(false)
  legalHoldReason     String?          @db.VarChar(500)
  tombstonedAt        DateTime?        @db.Timestamptz()
  tombstoneReason     String?          @db.VarChar(120)
  createdAt           DateTime         @default(now()) @db.Timestamptz()

  leave        MedicalLeave  @relation(fields: [leaveId], references: [id], onDelete: Restrict)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, signedAt(sort: Desc)])
  @@index([purgeDate])
  @@map("medical_leave_signed_blob")
  @@schema("public")
}

/// ADR-0010 §4.5 — anchor inmutable cross-tipo. INSERT-only por RLS+trigger.
model SignedDocumentAnchor {
  id                String              @id @default(uuid()) @db.Uuid
  organizationId    String              @db.Uuid
  documentType      SignedDocumentType
  documentId        String              @db.Uuid
  contentHash       String              @db.VarChar(120)
  signatureRef      String              @db.VarChar(500)
  signatureProvider String?             @db.VarChar(80)
  tsaToken          Bytes?
  tsaProvider       String?             @db.VarChar(80)
  tsaTime           DateTime?           @db.Timestamptz()
  sequenceNumber    BigInt
  /// Si es re-sello (TSA renewal), apunta al anchor previo.
  previousAnchorId  String?             @db.Uuid
  /// FK al audit_log central (hash-chain Merkle global).
  auditEntryId      BigInt
  signedAt          DateTime            @db.Timestamptz()
  createdAt         DateTime            @default(now()) @db.Timestamptz()

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  previousAnchor SignedDocumentAnchor?  @relation("AnchorChain", fields: [previousAnchorId], references: [id], onDelete: Restrict)
  nextAnchors    SignedDocumentAnchor[] @relation("AnchorChain")

  @@unique([organizationId, sequenceNumber])
  @@index([documentType, documentId])
  @@index([organizationId, signedAt(sort: Desc)])
  @@index([auditEntryId])
  @@map("signed_document_anchor")
  @@schema("public")
}

/// ADR-0012 — registro de ejecuciones de cron. RLS: service_role escribe; humanos solo SELECT.
model CronRun {
  id              String       @id @default(uuid()) @db.Uuid
  cronName        String       @db.VarChar(80)
  scanRunId       String       @unique @db.VarChar(40) /// ULID
  startedAt       DateTime     @default(now()) @db.Timestamptz()
  finishedAt      DateTime?    @db.Timestamptz()
  status          CronStatus   @default(running)
  itemsProcessed  Int          @default(0)
  itemsFailed     Int          @default(0)
  itemsSkipped    Int          @default(0)
  errorMessage    String?      @db.Text
  triggeredBy     String       @default("system") @db.VarChar(80)
  metadata        Json?

  @@index([cronName, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
  @@map("cron_run")
  @@schema("public")
}

/// ADR-0012 — bitácora append-only de transiciones de Appointment.
model AppointmentStateTransitionLog {
  id                 String               @id @default(uuid()) @db.Uuid
  appointmentId      String               @db.Uuid
  organizationId     String               @db.Uuid
  fromState          String               @db.VarChar(40)
  toState            String               @db.VarChar(40)
  transitionedBy     TransitionedByKind
  transitionedById   String?              @db.Uuid
  transitionedAt     DateTime             @default(now()) @db.Timestamptz()
  reason             String?              @db.VarChar(500)
  /// FK lógica a cron_run.scanRunId si transitionedBy='system_cron'.
  scanRunId          String?              @db.VarChar(40)

  appointment        Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lastForAppointment Appointment[]        @relation("AppointmentLastTransition")

  /// Idempotencia cron — el segundo INSERT (mismo scanRun) falla por UNIQUE.
  @@unique([appointmentId, scanRunId])
  @@index([appointmentId, transitionedAt(sort: Desc)])
  @@index([organizationId, transitionedAt(sort: Desc)])
  @@index([scanRunId])
  @@map("appointment_state_transition_log")
  @@schema("public")
}
