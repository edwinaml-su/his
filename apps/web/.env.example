# Ejemplo de variables de entorno para apps/web.
# Copiar a .env.local para desarrollo. En Vercel: Settings → Environment Variables.
# NUNCA commitear .env.local con valores reales.

# ── Supabase (ya existentes, normalmente vienen heredadas) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key

# ── Odoo XML-RPC ────────────────────────────────────────────────────────────
# Cliente en packages/infrastructure/src/odoo/client.ts.
# Usuario debe ser service-account dedicado con permisos mínimos.
# Rotar password trimestralmente. NUNCA hardcodear en código.
ODOO_URL=https://odoo.example.com
ODOO_DB=YourDatabaseName
ODOO_USER=service.account@example.com
ODOO_PASSWORD=set-via-vercel-env-vars

# ── GitHub (opcional — Wave 7 KPI gob_cambios_estandar) ─────────────────────
GITHUB_TOKEN=ghp_xxx
