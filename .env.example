# =============================================================================
# HIS Multipaís - Environment Variables Template
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA hagas commit del archivo .env real.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-secret

# -----------------------------------------------------------------------------
# Database (Postgres - Supabase)
# DATABASE_URL: pooler connection (PgBouncer transaction mode) - app runtime
# DIRECT_URL: direct connection - usado por Prisma migrate
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="HIS Avante"
NEXT_PUBLIC_DEFAULT_COUNTRY=SV
NEXT_PUBLIC_DEFAULT_LOCALE=es-SV
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/El_Salvador

# -----------------------------------------------------------------------------
# Auth - sesiones y JWT
# -----------------------------------------------------------------------------
AUTH_SECRET=run-`openssl rand -base64 32`-and-paste-here
SESSION_DURATION_MINUTES=480
PASSWORD_MIN_LENGTH=12
MFA_REQUIRED_FOR_ROLES=PHYSICIAN,PHARMACIST,ADMIN

# -----------------------------------------------------------------------------
# Observabilidad (opcional en desarrollo)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Notificaciones (opcional en MVP, integrarse en Fase 2+)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFICATIONS_FROM_EMAIL=no-reply@avante.example

# -----------------------------------------------------------------------------
# DTE El Salvador (Fase 5 - Facturación electrónica)
# -----------------------------------------------------------------------------
MH_DTE_BASE_URL=
MH_DTE_AUTH_URL=
MH_DTE_USER=
MH_DTE_PASSWORD=
MH_DTE_CERT_PATH=
MH_DTE_CERT_PASSWORD=

# -----------------------------------------------------------------------------
# HL7 / FHIR / DICOM (Fase 4+ - integraciones clínicas)
# -----------------------------------------------------------------------------
MIRTH_CONNECT_URL=
ORTHANC_PACS_URL=
ORTHANC_USER=
ORTHANC_PASSWORD=
