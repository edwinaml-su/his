# Ignorar en contexto de build Docker
# Ejecutar desde raíz del monorepo: docker build -f infra/docker/Dockerfile.web .

# Control de versiones
.git
.gitignore
.github

# Documentación
docs/
*.md
LICENSE

# Config de IDE / herramientas locales
.vscode/
.idea/
*.code-workspace
.editorconfig

# Dependencias (se instalan en el build)
node_modules/
**/node_modules/

# Artifacts de build (se generan en el build)
.next/
**/.next/
dist/
**/dist/
build/
**/build/

# Tests (no van en imagen de producción)
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/e2e/
coverage/
**/coverage/

# Secrets y env vars locales (NUNCA en imagen)
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Terraform / K8s (no pertenecen al runtime)
infra/

# Archivos de diagnóstico / scripts dev
scripts/
*.log

# Prisma — el schema.prisma sí se necesita; el resto no
packages/database/sql/
packages/database/scripts/

# Playwright / QA
e2e/
tests/
playwright-report/
test-results/
